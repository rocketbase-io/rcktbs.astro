---
import { Picture } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Navbar from '@/components/landing/Navbar.astro';
import LandingFooter from '@/components/landing/LandingFooter.astro';
import PolygonLuminary from '@/components/hero-backgrounds/PolygonLuminary.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { getCollection } from 'astro:content';
import { defaultLocale } from '@/i18n/config';
import { useTranslations } from '@/i18n/index';
import { getReadingTime } from '@/lib/utils';

const locale = defaultLocale;
const t = useTranslations(locale);

const allPosts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const posts = allPosts
  .filter((post) => post.data.locale === locale)
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());

// First featured post (newest) is rendered big; the rest is ordered as:
// remaining featured posts (newest first) → non-featured posts (newest first).
const featuredPost = posts.find((post) => post.data.featured);

const remainingFeatured = posts.filter(
  (post) => post.data.featured && post.id !== featuredPost?.id,
);
const nonFeatured = posts.filter((post) => !post.data.featured);
const otherPosts = [...remainingFeatured, ...nonFeatured];

const getPostUrl = (postId: string) => {
  const slug = postId.replace(`${locale}/`, '');
  return `/blog/${slug}`;
};
---

<BaseLayout
  title={t('blog.title')}
  description={t('blog.description')}
>
  <Navbar slot="header" />

  <!-- Hero Section -->
  <section class="border-border bg-background-secondary relative overflow-hidden border-b py-20 md:py-28">
    <PolygonLuminary />

    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <div class="max-w-3xl">
        <div class="mb-4 inline-flex items-center rounded-full border border-border bg-background px-3 py-1 shadow-sm">
          <Icon name="book" size="sm" class="text-brand-500 mr-2" />
          <span class="text-xs font-medium text-foreground-secondary">{t('blog.allPosts')}</span>
        </div>

        <h1 class="font-display text-4xl font-bold tracking-tight text-foreground md:text-5xl lg:text-6xl mb-6">
          {t('blog.title')}
        </h1>

        <p class="text-xl text-foreground-muted leading-relaxed" set:html={t('blog.descriptionHtml')}></p>
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16 bg-background-secondary">
    <div class="mx-auto max-w-6xl px-6">
      {posts.length === 0 ? (
        <div class="text-center py-16">
          <div class="mx-auto w-16 h-16 rounded-full bg-background flex items-center justify-center mb-4">
            <Icon name="file-text" size="lg" class="text-foreground-muted" />
          </div>
          <p class="text-foreground-muted text-lg">{t('blog.noPosts')}</p>
        </div>
      ) : (
        <div class="space-y-10">
          {featuredPost && (
            <article class="group overflow-hidden rounded-[2rem] border border-border bg-card shadow-[0_22px_55px_rgba(34,43,74,0.08)] transition-[transform,box-shadow] duration-500 hover:shadow-[0_30px_70px_rgba(34,43,74,0.12)] hover:border-border-strong will-change-transform [backface-visibility:hidden]">
              <a href={getPostUrl(featuredPost.id)} class="grid gap-0 md:grid-cols-2 md:items-stretch">
                {featuredPost.data.image ? (
                  <div class="overflow-hidden">
                    <Picture
                      src={featuredPost.data.image}
                      alt={featuredPost.data.imageAlt ?? featuredPost.data.title}
                      widths={[480, 720, 960, 1200]}
                      sizes="(max-width: 768px) 100vw, 50vw"
                      formats={['avif', 'webp']}
                      class="aspect-[16/10] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04] md:aspect-auto md:h-full"
                      loading="eager"
                    />
                  </div>
                ) : (
                  <div class="flex aspect-[16/10] flex-col justify-between bg-[linear-gradient(160deg,rgba(243,245,249,0.96),rgba(229,234,242,0.92))] p-8 md:aspect-auto md:min-h-[22rem] dark:bg-[linear-gradient(160deg,rgba(36,43,57,0.92),rgba(26,31,42,0.9))]">
                    <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                      Empfohlen
                    </p>
                    <p class="font-display text-foreground text-3xl leading-snug font-bold tracking-tight">
                      {featuredPost.data.title}
                    </p>
                  </div>
                )}

                <div class="flex flex-col justify-center p-8 lg:p-12">
                  <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                    Empfohlener Beitrag
                  </p>
                  <h2 class="font-display text-foreground mt-4 text-2xl font-bold leading-snug lg:text-3xl">
                    {featuredPost.data.title}
                  </h2>
                  <p class="text-foreground-secondary mt-4 text-base leading-7 line-clamp-4 lg:line-clamp-5">
                    {featuredPost.data.description}
                  </p>

                  <div class="mt-6 flex flex-wrap items-center gap-3 text-xs text-foreground-subtle">
                    <time datetime={featuredPost.data.publishedAt.toISOString()}>
                      {featuredPost.data.publishedAt.getFullYear()}
                    </time>
                    <span>·</span>
                    <span>{getReadingTime(featuredPost.body ?? '')} Min. Lesezeit</span>
                  </div>

                  <div class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-600 transition-transform duration-300 group-hover:translate-x-1">
                    Beitrag lesen
                    <Icon name="arrow-right" size="sm" />
                  </div>
                </div>
              </a>
            </article>
          )}

          {otherPosts.length > 0 && (
            <div class="grid gap-6 md:grid-cols-2">
              {otherPosts.map((post) => (
                <article class="group flex h-full flex-col overflow-hidden rounded-[2rem] border border-border bg-card shadow-sm transition-[transform,box-shadow,border-color] duration-300 hover:shadow-[0_20px_45px_rgba(34,43,74,0.1)] hover:border-border-strong will-change-transform [backface-visibility:hidden]">
                  <a href={getPostUrl(post.id)} class="flex h-full flex-col">
                    {post.data.image ? (
                      <div class="overflow-hidden">
                        <Picture
                          src={post.data.image}
                          alt={post.data.imageAlt ?? post.data.title}
                          widths={[480, 720, 960]}
                          sizes="(max-width: 768px) 100vw, 50vw"
                          formats={['avif', 'webp']}
                          class="aspect-[16/10] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                          loading="lazy"
                        />
                      </div>
                    ) : (
                      <div class="flex aspect-[16/10] flex-col justify-between bg-[linear-gradient(160deg,rgba(243,245,249,0.96),rgba(229,234,242,0.92))] p-7 dark:bg-[linear-gradient(160deg,rgba(36,43,57,0.92),rgba(26,31,42,0.9))]">
                        {post.data.tags.length > 0 && (
                          <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                            {post.data.tags[0]}
                          </p>
                        )}
                        <p class="font-display text-foreground text-2xl leading-snug font-bold tracking-tight">
                          {post.data.title}
                        </p>
                      </div>
                    )}

                    <div class="flex flex-1 flex-col p-6 lg:p-7">
                      {post.data.tags.length > 0 && (
                        <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                          {post.data.tags[0]}
                        </p>
                      )}
                      <h2 class="text-foreground mt-3 text-xl font-semibold leading-snug lg:text-2xl">
                        {post.data.title}
                      </h2>
                      <p class="text-foreground-secondary mt-3 text-sm leading-7 line-clamp-3">
                        {post.data.description}
                      </p>
                      <div class="mt-auto pt-6">
                        <div class="flex flex-wrap items-center gap-3 text-xs text-foreground-subtle">
                          <time datetime={post.data.publishedAt.toISOString()}>
                            {post.data.publishedAt.getFullYear()}
                          </time>
                          <span>·</span>
                          <span>{getReadingTime(post.body ?? '')} Min. Lesezeit</span>
                        </div>
                      </div>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          )}
        </div>
      )}
    </div>
  </section>

  <LandingFooter slot="footer" />
</BaseLayout>
