---
import LandingLayout from '@/layouts/LandingLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath } from '@/i18n/index';
import siteConfig from '@/config/site.config';
import heroBg from '@/assets/rocketbase/hero-bg.png';
import founderImage from '@/assets/rocketbase/founder-marten.jpg';
import statistaCaseImage from '@/assets/rocketbase/case-statista.png';
import bonprixCaseImage from '@/assets/rocketbase/case-bonprix.png';
import {
  cases,
  contactLinks,
  discoveryOffer,
  serviceAreas,
  strengths,
} from '@/data/rocketbase';

const locale = defaultLocale;
const servicesUrl = getLocalizedPath('services', locale);
const aboutUrl = getLocalizedPath('about', locale);
const contactUrl = getLocalizedPath('contact', locale);
const referencesUrl = '/referenzen';
const getReferenceUrl = (slug: string) => `${referencesUrl}/${slug}`;

const featuredCases = [
  { ...cases[0], image: bonprixCaseImage },
  { ...cases[1], image: statistaCaseImage },
  { ...cases[2] },
];

const leadClients = ['bonprix', 'Statista', 'FKC Consulting', 'B2B-Plattformen', 'Prozessdigitalisierung'];
const directCollaborationDefinition =
  'Bei Rocketbase arbeiten Sie direkt mit Marten Prieß. Analyse, Konzeption und technische Entscheidungen bleiben dadurch nah am Projekt und sein Know-how ist nicht nur im Erstgespräch, sondern in der Umsetzung mit an Bord.';
---

<LandingLayout
  title="Rocketbase | Individuelle Software mit direkter Begleitung durch Marten Prieß"
  description={siteConfig.description}
  includeOrgSchema
  lang={locale}
  routeId="home"
>
  <section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(99,114,165,0.14),transparent_36%),linear-gradient(180deg,rgba(255,255,255,0.98),rgba(249,250,252,0.96))] dark:bg-[radial-gradient(circle_at_top_right,rgba(99,114,165,0.18),transparent_36%),linear-gradient(180deg,rgba(18,22,31,0.98),rgba(18,22,31,0.96))]"></div>
    <div class="container relative grid gap-16 pb-24 pt-28 lg:grid-cols-[minmax(0,1.05fr)_minmax(360px,0.95fr)] lg:items-center">
      <div class="max-w-3xl">
        <div class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">
          Marten Prieß direkt im Projekt
        </div>

        <h1 class="mt-6 max-w-4xl font-display text-5xl font-bold tracking-tight text-foreground sm:text-6xl xl:text-7xl">
          Wir entwickeln nicht einfach Software. <span class="text-brand-500">Wir denken Prozesse weiter.</span>
        </h1>

        <p class="mt-6 max-w-2xl text-lg leading-8 text-foreground-secondary sm:text-xl">
          Rocketbase baut individuelle Software für Unternehmen, die nicht noch mehr Tool-Wildwuchs
          brauchen, sondern klare Abläufe, belastbare Plattformen und einen Partner, der fachlich
          wie technisch mitdenkt.
        </p>

        <div class="mt-8 max-w-2xl border-l-2 border-brand-300 pl-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">So arbeiten wir</p>
          <p class="mt-3 text-base leading-7 text-foreground-secondary">{directCollaborationDefinition}</p>
        </div>

        <div class="mt-8 flex flex-wrap gap-4">
          <Button size="lg" href={contactLinks.cal} target="_blank">
            Erstgespräch buchen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <Button size="lg" variant="outline" href={servicesUrl}>
            Leistungen ansehen
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <div class="mt-10 grid gap-4 border-t border-border/70 pt-6 text-sm text-foreground-muted sm:grid-cols-3">
          <div>
            <p class="font-semibold text-foreground">Seit 2016</p>
            <p class="mt-2 leading-6">Aufbau von Digitalprodukten und internen Plattformen.</p>
          </div>
          <div>
            <p class="font-semibold text-foreground">bonprix &amp; Statista</p>
            <p class="mt-2 leading-6">Konzern-Erfahrung, übertragen auf mittelständische Realitäten.</p>
          </div>
          <div>
            <p class="font-semibold text-foreground">Discovery bis Betrieb</p>
            <p class="mt-2 leading-6">Konzeption, Delivery, Integration und Weiterentwicklung aus einer Hand.</p>
          </div>
        </div>
      </div>

      <div class="relative lg:pl-6">
        <div class="absolute inset-x-12 top-12 -z-10 h-72 rounded-full bg-brand-300/15 blur-3xl dark:bg-brand-600/10"></div>
        <div class="space-y-5">
          <article class="overflow-hidden rounded-[2.25rem] border border-white/50 bg-card shadow-[0_22px_60px_rgba(34,43,74,0.1)] dark:border-white/10">
            <img src={heroBg.src} alt="Rocketbase Projektumfeld" class="h-72 w-full object-cover" />
            <div class="border-t border-border p-7">
              <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Rocketbase Ansatz</p>
              <p class="mt-3 text-xl font-semibold text-foreground">
                Kleine, starke Einheit. Direkte Entscheidungen. Architektur mit Blick auf den echten Betrieb.
              </p>
              <p class="mt-4 max-w-xl text-base leading-7 text-foreground-secondary">
                Keine unnötige Agenturdramaturgie, sondern klare Gespräche über Prozesse, Prioritäten und die sinnvollste technische Lösung.
              </p>
            </div>
          </article>

          <article class="rounded-[1.75rem] border border-border/80 bg-white/70 p-6 backdrop-blur dark:bg-white/5">
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Direkter Nutzen</p>
                <p class="mt-3 text-base leading-7 text-foreground-secondary">
                  Direkter Draht zu Marten Prieß statt Übergaben über mehrere Rollen.
                </p>
              </div>
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Technologie</p>
                <p class="mt-3 text-base leading-7 text-foreground-secondary">
                  Pragmatische Technologieauswahl mit Open Source dort, wo sie trägt.
                </p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-border bg-background-secondary py-8">
    <div class="container flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <span class="text-sm font-semibold uppercase tracking-[0.2em] text-foreground-muted">Erfahrung aus Projekten mit</span>
      <p class="text-sm leading-7 text-foreground-secondary">{leadClients.join(' · ')}</p>
    </div>
  </section>

  <section id="features" class="relative overflow-hidden py-32">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(99,114,165,0.1),transparent_30%)]"></div>
    <div class="container relative grid gap-16 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Warum Rocketbase</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Keine verlängerte Werkbank. <span class="text-brand-500">Ein Team, das mitdenkt.</span>
        </h2>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Rocketbase wurde nicht gegründet, um einzelne Entwickler in Projekte zu schicken. Der
          Anspruch ist ein anderer: Verantwortung inhaltlich und technisch übernehmen, Prozesse
          verstehen und Lösungen liefern, die langfristig funktionieren.
        </p>
        <div class="mt-8 border-l-2 border-brand-300 pl-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Kurz gesagt</p>
          <p class="mt-4 text-2xl font-semibold text-foreground">Direkter Zugriff auf jemanden, der Business-Logik und Architektur zusammen denkt.</p>
          <p class="mt-4 text-base leading-7 text-foreground-secondary">
            Genau deshalb entstehen weniger Missverständnisse, weniger Übergaben und schneller belastbare Entscheidungen.
          </p>
        </div>
      </div>

      <div class="relative max-w-4xl">
        <div class="absolute bottom-4 left-4 top-4 hidden w-px bg-border lg:block"></div>

        <div class="space-y-6">
          {strengths.map((strength, index) => (
            <article
              class:list={[
                'relative grid gap-4 lg:grid-cols-[72px_1fr] lg:items-start',
                index === 0
                  ? 'rounded-[2.25rem] border border-border bg-background-secondary/70 p-8'
                  : 'px-0 py-4',
                index > 0 && index % 2 === 0 ? 'lg:ml-10' : '',
                index > 0 && index % 2 === 1 ? 'lg:mr-10' : '',
              ]}
            >
              <div class="relative z-10 flex h-12 w-12 items-center justify-center rounded-2xl border border-border bg-background text-sm font-semibold text-brand-700 dark:text-brand-100">
                0{index + 1}
              </div>

              <div class:list={[index > 0 ? 'border-b border-border/70 pb-6 lg:pb-8' : '']}>
                <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                  <h3 class="max-w-2xl text-2xl font-semibold text-foreground">{strength.title}</h3>
                  {index === 0 && (
                    <span class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">
                      Rocketbase Haltung
                    </span>
                  )}
                </div>
                <p class="mt-4 max-w-2xl text-base leading-7 text-foreground-secondary">
                  {strength.description}
                </p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-border py-28">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Referenzen</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Konzern-Erfahrung, umgesetzt für den Mittelstand.
        </h2>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Drei Beispiele dafür, wie Rocketbase in sehr unterschiedlichen Ausgangslagen arbeitet:
          mit Konzernstrukturen, gewachsenen Kernsystemen und dem Schritt von Standardsoftware zu
          einer individuellen Lösung.
        </p>
      </div>

      <div class="mt-16 grid gap-10 border-t border-border pt-8 lg:grid-cols-3">
        {featuredCases.map((item) => (
          <article class="flex flex-col">
            <a href={getReferenceUrl(item.slug)} class="group block">
              {item.slug === 'fkc-consulting' ? (
                <div class="flex h-64 flex-col justify-between overflow-hidden rounded-[2rem] bg-[linear-gradient(160deg,rgba(243,245,249,0.96),rgba(229,234,242,0.92))] p-7 dark:bg-[linear-gradient(160deg,rgba(36,43,57,0.92),rgba(26,31,42,0.9))]">
                  <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">FKC Consulting</p>
                  <div>
                    <p class="font-display text-xl font-bold leading-snug tracking-tight text-foreground">Von Standardsoftware zur individuellen Plattform</p>
                    <p class="mt-2 line-clamp-2 text-sm leading-6 text-foreground-secondary">Migration, Datenübernahme und neuer Zuschnitt an echten Geschäftsprozessen.</p>
                  </div>
                </div>
              ) : (
                <div class="overflow-hidden rounded-[2rem]">
                  <img
                    src={item.image.src}
                    alt={item.title}
                    class="h-64 w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                  />
                </div>
              )}

              <p class="mt-6 text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">{item.client}</p>
              <h3 class="mt-3 text-2xl font-semibold text-foreground">{item.title}</h3>
              <p class="mt-4 text-base leading-8 text-foreground-secondary">{item.kicker}</p>
              <p class="mt-4 text-sm leading-7 text-foreground-muted">
                Prozess im Fokus: {item.processFocus}
              </p>
            </a>

            <ul class="mt-6 space-y-3 border-l border-border pl-5 text-sm leading-7 text-foreground-secondary">
              {item.highlights.slice(0, 2).map((highlight) => (
                <li>{highlight}</li>
              ))}
            </ul>

            <div class="mt-6">
              <a href={getReferenceUrl(item.slug)} class="text-sm font-semibold text-brand-600 transition-colors hover:text-brand-500">
                Mehr Hintergründe ansehen
              </a>
            </div>
          </article>
        ))}

        <div class="flex lg:col-span-3">
          <Button variant="outline" href={referencesUrl}>
            Alle Referenzen ansehen
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-32">
    <div class="container grid gap-14 lg:grid-cols-[0.86fr_1.14fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Leistungen</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Beratung, Konzeption und Umsetzung <span class="text-brand-500">mit möglichst wenig Reibung.</span>
        </h2>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Rocketbase verbindet Prozessperspektive, Technologieverständnis und Delivery. Das
          reduziert Übergaben und beschleunigt Entscheidungen in anspruchsvollen Projekten.
        </p>
        <div class="mt-8 text-sm leading-7 text-foreground-muted">
          Discovery · Konzeption · Individualsoftware · Integration &amp; Betrieb
        </div>
      </div>

      <div class="space-y-8">
        {serviceAreas.map((service, index) => (
          <article class="grid gap-5 border-t border-border pt-8 md:grid-cols-[72px_1fr] md:items-start">
            <div class="text-sm font-semibold text-brand-600">
              0{index + 1}
            </div>
            <div>
              <h3 class="text-2xl font-semibold text-foreground">{service.title}</h3>
              <p class="mt-3 max-w-2xl text-base leading-7 text-foreground-secondary">{service.description}</p>
              <ul class="mt-6 grid gap-x-8 gap-y-3 sm:grid-cols-2 text-sm text-foreground-secondary">
                {service.bullets.map((bullet) => (
                  <li class="flex gap-3">
                    <Icon name="arrow-right" size="sm" class="mt-0.5 shrink-0 text-brand-400" />
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-surface-invert py-28 text-on-invert">
    <div class="container grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-300">Presales mit Substanz</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-on-invert sm:text-5xl">
          {discoveryOffer.title}
        </h2>
        <p class="mt-4 text-xl text-on-invert-secondary">{discoveryOffer.subtitle}</p>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-on-invert-secondary">
          {discoveryOffer.description}
        </p>
      </div>

      <div class="border-l border-white/10 pl-6">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-200">Typische Ergebnisse</p>
        <ul class="mt-6 space-y-4 text-base leading-7 text-on-invert-secondary">
          {discoveryOffer.deliverables.map((item) => (
            <li class="flex gap-3">
              <Icon name="check-circle" size="sm" class="mt-1 shrink-0 text-brand-300" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <div class="mt-8">
          <Button href={contactLinks.cal} target="_blank">
            Workshop oder Erstgespräch anfragen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-32">
    <div class="container grid gap-14 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div class="overflow-hidden rounded-[2rem]">
        <img src={founderImage.src} alt="Marten Prieß, Gründer von Rocketbase" class="h-full w-full object-cover" />
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Gründerstory</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Marten Prieß verbindet Fachbereich, Architektur und Delivery.
        </h2>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Das Fundament dafür entstand im dualen Studium in der Otto-Gruppe mit Einblicken in
          Einkauf, E-Commerce, Marketing, Vertrieb, Neukundengewinnung und Kundensupport. Später
          folgte die Arbeit als Softwarearchitekt bei Statista inklusive Teamaufbau und
          Plattformentwicklung.
        </p>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Diese Laufbahn erklärt, warum Rocketbase Anforderungen nicht isoliert technisch
          betrachtet. Prozesse, Verantwortlichkeiten und echte Arbeitsweisen gehören immer mit auf
          den Tisch.
        </p>
        <div class="mt-8 border-l-2 border-brand-300 pl-5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Was das in Projekten bedeutet</p>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div>
              <p class="text-lg font-semibold text-foreground">Direkte Begleitung</p>
              <p class="mt-2 text-sm leading-7 text-foreground-secondary">
                Marten Prieß ist von der ersten Idee bis zu Architekturentscheidungen selbst mit im Projekt.
              </p>
            </div>
            <div>
              <p class="text-lg font-semibold text-foreground">Konzernniveau</p>
              <p class="mt-2 text-sm leading-7 text-foreground-secondary">
                Erfahrung aus großen Plattformprojekten, übersetzt in praktikable Lösungen für mittelständische Teams.
              </p>
            </div>
          </div>
        </div>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href={aboutUrl}>
            Mehr über Rocketbase
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button variant="outline" href={contactUrl}>
            Kontakt aufnehmen
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section id="cta" class="border-t border-border bg-background-secondary py-28">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Nächster Schritt</p>
          <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
            Von Standardsoftware zur Lösung, die wirklich zu Ihrem Unternehmen passt.
          </h2>
          <p class="mt-6 max-w-2xl text-lg leading-8 text-foreground-secondary">
            Wenn Prozesse inzwischen mehr bremsen als tragen, lohnt ein strukturierter Blick.
            Rocketbase unterstützt bei der Einordnung, priorisiert sinnvolle Schritte und setzt
            tragfähige Lösungen mit um.
          </p>
        </div>
        <div class="border-l border-border pl-0 lg:pl-8">
          <div class="space-y-4 text-sm text-foreground-muted">
            <div class="flex items-center gap-3">
              <Icon name="clock" size="sm" class="text-brand-500" />
              30 Minuten direkt mit dem Gründer
            </div>
            <div class="flex items-center gap-3">
              <Icon name="mail" size="sm" class="text-brand-500" />
              {contactLinks.email}
            </div>
          </div>
          <div class="mt-8 flex flex-wrap gap-4">
            <Button href={contactLinks.cal} target="_blank">
              Erstgespräch buchen
              <Icon name="arrow-up-right" size="sm" />
            </Button>
            <Button variant="outline" href={contactUrl}>
              Kontaktseite
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
