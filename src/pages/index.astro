---
import LandingLayout from '@/layouts/LandingLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath } from '@/i18n/index';
import siteConfig from '@/config/site.config';
import heroBg from '@/assets/rocketbase/hero-bg.png';
import founderImage from '@/assets/rocketbase/founder-marten.jpg';
import statistaCaseImage from '@/assets/rocketbase/case-statista.png';
import bonprixCaseImage from '@/assets/rocketbase/case-bonprix.png';
import { cases, contactLinks, discoveryOffer, serviceAreas, strengths } from '@/data/rocketbase';
import toolsBefore from '@/assets/work/tools-before.png';
import toolsAfter from '@/assets/work/tools-after.png';

const locale = defaultLocale;
const servicesUrl = getLocalizedPath('services', locale);
const aboutUrl = getLocalizedPath('about', locale);
const contactUrl = getLocalizedPath('contact', locale);
const referencesUrl = '/referenzen';
const workUrl = getLocalizedPath('work', locale);
const getReferenceUrl = (slug: string) => `${referencesUrl}/${slug}`;

const featuredCases = [
  { ...cases[0], image: bonprixCaseImage },
  { ...cases[1], image: statistaCaseImage },
  { ...cases[2] },
];

const leadClients = [
  'bonprix',
  'Statista',
  'FKC Consulting',
  'B2B-Plattformen',
  'Prozessdigitalisierung',
];
const directCollaborationDefinition =
  'Bei Rocketbase arbeiten Sie direkt mit Marten Prieß. Analyse, Konzeption und technische Entscheidungen bleiben dadurch nah am Projekt und sein Know-how ist nicht nur im Erstgespräch, sondern in der Umsetzung mit an Bord.';
---

<LandingLayout
  title="Rocketbase | Individuelle Software mit direkter Begleitung durch Marten Prieß"
  description={siteConfig.description}
  includeOrgSchema
  lang={locale}
  routeId="home"
>
  <section class="border-border relative overflow-hidden border-b">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(99,114,165,0.14),transparent_36%),linear-gradient(180deg,rgba(255,255,255,0.98),rgba(249,250,252,0.96))] dark:bg-[radial-gradient(circle_at_top_right,rgba(99,114,165,0.18),transparent_36%),linear-gradient(180deg,rgba(18,22,31,0.98),rgba(18,22,31,0.96))]"
    >
    </div>
    <div
      class="relative container grid gap-16 pt-28 pb-24 lg:grid-cols-[minmax(0,1.05fr)_minmax(360px,0.95fr)] lg:items-center"
    >
      <div data-aos="fade-right" class="max-w-3xl">
        <div class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">
          Marten Prieß direkt im Projekt
        </div>

        <h1
          class="font-display text-foreground mt-6 max-w-4xl text-5xl font-bold tracking-tight sm:text-6xl xl:text-7xl"
        >
          Wir entwickeln nicht einfach Software. <span class="text-brand-500"
            >Wir denken Prozesse weiter.</span
          >
        </h1>

        <p class="text-foreground-secondary mt-6 max-w-2xl text-lg leading-8 sm:text-xl">
          Rocketbase baut individuelle Software für Unternehmen, die nicht noch mehr Tool-Wildwuchs
          brauchen, sondern klare Abläufe, belastbare Plattformen und einen Partner, der fachlich
          wie technisch mitdenkt.
        </p>

        <div class="border-brand-300 mt-8 max-w-2xl border-l-2 pl-5">
          <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
            So arbeiten wir
          </p>
          <p class="text-foreground-secondary mt-3 text-base leading-7">
            {directCollaborationDefinition}
          </p>
        </div>

        <div data-aos="fade-up" class="mt-8 flex flex-wrap gap-4">
          <Button size="lg" href={contactLinks.cal} target="_blank">
            Erstgespräch buchen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <Button size="lg" variant="outline" href={servicesUrl}>
            Leistungen ansehen
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>

        <div
          class="border-border/70 text-foreground-muted mt-10 grid gap-4 border-t pt-6 text-sm sm:grid-cols-3"
        >
          <div data-aos="zoom-in">
            <p class="text-foreground font-semibold">Seit 2016</p>
            <p class="mt-2 leading-6">Aufbau von Digitalprodukten und internen Plattformen.</p>
          </div>
          <div data-aos="zoom-in">
            <p class="text-foreground font-semibold">bonprix &amp; Statista</p>
            <p class="mt-2 leading-6">
              Konzern-Erfahrung, übertragen auf mittelständische Realitäten.
            </p>
          </div>
          <div data-aos="zoom-in">
            <p class="text-foreground font-semibold">Discovery bis Betrieb</p>
            <p class="mt-2 leading-6">
              Konzeption, Delivery, Integration und Weiterentwicklung aus einer Hand.
            </p>
          </div>
        </div>
      </div>

      <div data-aos="fade-left" class="relative lg:pl-6">
        <div
          class="bg-brand-300/15 dark:bg-brand-600/10 absolute inset-x-12 top-12 -z-10 h-72 rounded-full blur-3xl"
        >
        </div>
        <div class="space-y-5">
          <article
            data-aos="zoom-in"
            class="bg-card overflow-hidden rounded-[2.25rem] border border-white/50 shadow-[0_22px_60px_rgba(34,43,74,0.1)] dark:border-white/10"
          >
            <img src={heroBg.src} alt="Rocketbase Projektumfeld" class="h-72 w-full object-cover" />
            <div class="border-border border-t p-7">
              <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                Rocketbase Ansatz
              </p>
              <p class="text-foreground mt-3 text-xl font-semibold">
                Kleine, starke Einheit. Direkte Entscheidungen. Architektur mit Blick auf den echten
                Betrieb.
              </p>
              <p class="text-foreground-secondary mt-4 max-w-xl text-base leading-7">
                Keine unnötige Agenturdramaturgie, sondern klare Gespräche über Prozesse,
                Prioritäten und die sinnvollste technische Lösung.
              </p>
            </div>
          </article>

          <article
            data-aos="zoom-in"
            class="border-border/80 rounded-[1.75rem] border bg-white/70 p-6 backdrop-blur dark:bg-white/5"
          >
            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                  Direkter Nutzen
                </p>
                <p class="text-foreground-secondary mt-3 text-base leading-7">
                  Direkter Draht zu Marten Prieß statt Übergaben über mehrere Rollen.
                </p>
              </div>
              <div>
                <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                  Technologie
                </p>
                <p class="text-foreground-secondary mt-3 text-base leading-7">
                  Pragmatische Technologieauswahl mit Open Source dort, wo sie trägt.
                </p>
              </div>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="border-border bg-background-secondary border-b py-8">
    <div class="container flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
      <span data-aos="fade-right" class="text-foreground-muted text-sm font-semibold tracking-[0.2em] uppercase"
        >Erfahrung aus Projekten mit</span
      >
      <p data-aos="fade-left" class="text-foreground-secondary text-sm leading-7">{leadClients.join(' · ')}</p>
    </div>
  </section>

  <section id="features" class="relative overflow-hidden py-32 border-b">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(99,114,165,0.1),transparent_30%)]"
    >
    </div>
    <div class="relative container grid gap-16 lg:grid-cols-[0.78fr_1.22fr] lg:items-start">
      <div data-aos="fade-right" class="lg:sticky lg:top-28">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">
          Warum Rocketbase
        </p>
        <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Keine verlängerte Werkbank. <span class="text-brand-500">Ein Team, das mitdenkt.</span>
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Rocketbase wurde nicht gegründet, um einzelne Entwickler in Projekte zu schicken. Der
          Anspruch ist ein anderer: Verantwortung inhaltlich und technisch übernehmen, Prozesse
          verstehen und Lösungen liefern, die langfristig funktionieren.
        </p>
        <div class="border-brand-300 mt-8 border-l-2 pl-5">
          <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
            Kurz gesagt
          </p>
          <p class="text-foreground mt-4 text-2xl font-semibold">
            Direkter Zugriff auf jemanden, der Business-Logik und Architektur zusammen denkt.
          </p>
          <p class="text-foreground-secondary mt-4 text-base leading-7">
            Genau deshalb entstehen weniger Missverständnisse, weniger Übergaben und schneller
            belastbare Entscheidungen.
          </p>
        </div>
      </div>

      <div class="relative max-w-4xl">
        <div class="bg-border absolute top-4 bottom-4 left-4 hidden w-px lg:block"></div>

        <div data-aos="fade-left" class="space-y-6">
          {
            strengths.map((strength, index) => (
              <article
                class:list={[
                  'relative grid gap-4 lg:grid-cols-[72px_1fr] lg:items-start',
                  index === 0
                    ? 'border-border bg-background-secondary/70 rounded-[2.25rem] border p-8'
                    : 'px-0 py-4',
                  index > 0 && index % 2 === 0 ? 'lg:ml-10' : '',
                  index > 0 && index % 2 === 1 ? 'lg:mr-10' : '',
                ]}
              >
                <div data-aos="zoom-in" class="border-border bg-background text-brand-700 dark:text-brand-100 relative z-10 flex h-12 w-12 items-center justify-center rounded-2xl border text-sm font-semibold">
                  0{index + 1}
                </div>

                <div data-aos="zoom-in" class:list={[index > 0 ? 'border-border/70 border-b pb-6 lg:pb-8' : '']}>
                  <div class="flex flex-col gap-3 lg:flex-row lg:items-start lg:justify-between">
                    <h3 class="text-foreground max-w-2xl text-2xl font-semibold">
                      {strength.title}
                    </h3>
                    {index === 0 && (
                      <span class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                        Rocketbase Haltung
                      </span>
                    )}
                  </div>
                  <p class="text-foreground-secondary mt-4 max-w-2xl text-base leading-7">
                    {strength.description}
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="border-border relative overflow-hidden border-b">
    <a data-aos="zoom-in" href={workUrl} class="group mx-auto block max-w-6xl px-6 py-20">
      <div
        class="relative overflow-hidden rounded-3xl border bg-background-secondary/70 p-10 transition-all group-hover:scale-[1.01] group-hover:shadow-xl"
      >

        <div class="relative grid items-center gap-10 md:grid-cols-2">
          <div>
            <div class="mb-4 text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Unser Ansatz</div>

            <h2 class="text-3xl leading-tight font-bold md:text-4xl">
              Weniger Overhead. <br />
              <span class="text-brand-500">Mehr Geschwindigkeit.</span>
            </h2>

            <p class="text-foreground-secondary mt-6 text-lg leading-8">
              Wir zeigen dir konkret, wie moderne Softwareentwicklung heute funktioniert – und warum
              klassische Ansätze dich ausbremsen.
            </p>

            <div class="mt-8 flex items-center gap-3 font-semibold text-brand-600 border rounded-md w-fit px-4 p-2">
              Mehr erfahren
              <Icon name="arrow-right" size="sm" />
            </div>
          </div>

          <!-- VISUAL -->
          <div class="relative flex items-center justify-center">
            <!-- BEFORE -->
            <div class="absolute top-1/2 -left-1/12 -translate-y-1/2 scale-90 opacity-40 grayscale">
              <img src={toolsBefore.src} alt="Vorher" class="w-52 rounded-xl" />
            </div>

            <!-- AFTER -->
            <div class="relative z-10">
              <img
                src={toolsAfter.src}
                alt="Nachher"
                class="w-72 rounded-2xl shadow-lg"
              />
            </div>
          </div>
        </div>
      </div>
    </a>
  </section>

  <section class="border-border border-y py-28">
    <div  class="container">
      <div data-aos="fade-up" class="max-w-3xl">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Referenzen</p>
        <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Konzern-Erfahrung, umgesetzt für den Mittelstand.
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Drei Beispiele dafür, wie Rocketbase in sehr unterschiedlichen Ausgangslagen arbeitet: mit
          Konzernstrukturen, gewachsenen Kernsystemen und dem Schritt von Standardsoftware zu einer
          individuellen Lösung.
        </p>
      </div>

      <div class="border-border mt-16 grid gap-10 border-t pt-8 lg:grid-cols-3">
        {
          featuredCases.map((item) => (
            <article data-aos="zoom-in" class="flex flex-col">
              <a href={getReferenceUrl(item.slug)} class="group block">
                {item.slug === 'fkc-consulting' ? (
                  <div class="flex h-64 flex-col justify-between overflow-hidden rounded-[2rem] bg-[linear-gradient(160deg,rgba(243,245,249,0.96),rgba(229,234,242,0.92))] p-7 dark:bg-[linear-gradient(160deg,rgba(36,43,57,0.92),rgba(26,31,42,0.9))]">
                    <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                      FKC Consulting
                    </p>
                    <div>
                      <p class="font-display text-foreground text-xl leading-snug font-bold tracking-tight">
                        Von Standardsoftware zur individuellen Plattform
                      </p>
                      <p class="text-foreground-secondary mt-2 line-clamp-2 text-sm leading-6">
                        Migration, Datenübernahme und neuer Zuschnitt an echten Geschäftsprozessen.
                      </p>
                    </div>
                  </div>
                ) : (
                  <div class="overflow-hidden rounded-[2rem]">
                    <img
                      src={item.image.src}
                      alt={item.title}
                      class="h-64 w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
                    />
                  </div>
                )}

                <p class="text-brand-600 mt-6 text-xs font-semibold tracking-[0.22em] uppercase">
                  {item.client}
                </p>
                <h3 class="text-foreground mt-3 text-2xl font-semibold">{item.title}</h3>
                <p class="text-foreground-secondary mt-4 text-base leading-8">{item.kicker}</p>
                <p class="text-foreground-muted mt-4 text-sm leading-7">
                  Prozess im Fokus: {item.processFocus}
                </p>
              </a>

              <ul class="border-border text-foreground-secondary mt-6 space-y-3 border-l pl-5 text-sm leading-7">
                {item.highlights.slice(0, 2).map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>

              <div class="mt-6">
                <a
                  href={getReferenceUrl(item.slug)}
                  class="text-brand-600 hover:text-brand-500 text-sm font-semibold transition-colors"
                >
                  Mehr Hintergründe ansehen
                </a>
              </div>
            </article>
          ))
        }

        <div class="flex lg:col-span-3">
          <Button variant="outline" href={referencesUrl}>
            Alle Referenzen ansehen
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-32">
    <div class="container grid gap-14 lg:grid-cols-[0.86fr_1.14fr] lg:items-start">
      <div data-aos="fade-right" class="lg:sticky lg:top-28">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Leistungen</p>
        <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Beratung, Konzeption und Umsetzung <span class="text-brand-500"
            >mit möglichst wenig Reibung.</span
          >
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Rocketbase verbindet Prozessperspektive, Technologieverständnis und Delivery. Das
          reduziert Übergaben und beschleunigt Entscheidungen in anspruchsvollen Projekten.
        </p>
        <div class="text-foreground-muted mt-8 text-sm leading-7">
          Discovery · Konzeption · Individualsoftware · Integration &amp; Betrieb
        </div>
      </div>

      <div data-aos="fade-left" class="space-y-8">
        {
          serviceAreas.map((service, index) => (
            <article class="border-border grid gap-5 border-t pt-8 md:grid-cols-[72px_1fr] md:items-start">
              <div data-aos="zoom-in" class="text-brand-600 text-sm font-semibold">0{index + 1}</div>
              <div data-aos="zoom-in">
                <h3 class="text-foreground text-2xl font-semibold">{service.title}</h3>
                <p class="text-foreground-secondary mt-3 max-w-2xl text-base leading-7">
                  {service.description}
                </p>
                <ul class="text-foreground-secondary mt-6 grid gap-x-8 gap-y-3 text-sm sm:grid-cols-2">
                  {service.bullets.map((bullet) => (
                    <li data-aos="zoom-in" class="flex gap-3">
                      <Icon name="arrow-right" size="sm" class="text-brand-400 mt-0.5 shrink-0" />
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-border bg-surface-invert text-on-invert border-y py-28">
    <div class="container grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div data-aos="fade-right">
        <p class="text-brand-300 text-sm font-semibold tracking-[0.22em] uppercase">
          Presales mit Substanz
        </p>
        <h2 class="font-display text-on-invert mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          {discoveryOffer.title}
        </h2>
        <p class="text-on-invert-secondary mt-4 text-xl">{discoveryOffer.subtitle}</p>
        <p class="text-on-invert-secondary mt-6 max-w-2xl text-lg leading-8">
          {discoveryOffer.description}
        </p>
      </div>

      <div data-aos="fade-left" class="border-l border-white/10 pl-6">
        <p class="text-brand-200 text-xs font-semibold tracking-[0.22em] uppercase">
          Typische Ergebnisse
        </p>
        <ul class="text-on-invert-secondary mt-6 space-y-4 text-base leading-7">
          {
            discoveryOffer.deliverables.map((item) => (
              <li data-aos="zoom-in" class="flex gap-3">
                <Icon name="check-circle" size="sm" class="text-brand-300 mt-1 shrink-0" />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-8">
          <Button href={contactLinks.cal} target="_blank">
            Workshop oder Erstgespräch anfragen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-32">
    <div class="container grid gap-14 lg:grid-cols-[0.92fr_1.08fr] lg:items-center">
      <div data-aos="fade-right" class="overflow-hidden rounded-[2rem]">
        <img
          src={founderImage.src}
          alt="Marten Prieß, Gründer von Rocketbase"
          class="h-full w-full object-cover"
        />
      </div>

      <div data-aos="fade-left">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Gründerstory</p>
        <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Marten Prieß verbindet Fachbereich, Architektur und Delivery.
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Das Fundament dafür entstand im dualen Studium in der Otto-Gruppe mit Einblicken in
          Einkauf, E-Commerce, Marketing, Vertrieb, Neukundengewinnung und Kundensupport. Später
          folgte die Arbeit als Softwarearchitekt bei Statista inklusive Teamaufbau und
          Plattformentwicklung.
        </p>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Diese Laufbahn erklärt, warum Rocketbase Anforderungen nicht isoliert technisch
          betrachtet. Prozesse, Verantwortlichkeiten und echte Arbeitsweisen gehören immer mit auf
          den Tisch.
        </p>
        <div class="border-brand-300 mt-8 border-l-2 pl-5">
          <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
            Was das in Projekten bedeutet
          </p>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            <div>
              <p class="text-foreground text-lg font-semibold">Direkte Begleitung</p>
              <p class="text-foreground-secondary mt-2 text-sm leading-7">
                Marten Prieß ist von der ersten Idee bis zu Architekturentscheidungen selbst mit im
                Projekt.
              </p>
            </div>
            <div>
              <p class="text-foreground text-lg font-semibold">Konzernniveau</p>
              <p class="text-foreground-secondary mt-2 text-sm leading-7">
                Erfahrung aus großen Plattformprojekten, übersetzt in praktikable Lösungen für
                mittelständische Teams.
              </p>
            </div>
          </div>
        </div>
        <div data-aos="fade-up" class="mt-8 flex flex-wrap gap-4">
          <Button href={aboutUrl}>
            Mehr über Rocketbase
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button variant="outline" href={contactUrl}> Kontakt aufnehmen </Button>
        </div>
      </div>
    </div>
  </section>

  <section id="cta" class="border-border bg-background-secondary border-t py-28">
    <div class="container">
      <div class="grid gap-10 lg:grid-cols-[1.2fr_0.8fr] lg:items-end">
        <div data-aos="fade-right">
          <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">
            Nächster Schritt
          </p>
          <h2
            class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl"
          >
            Von Standardsoftware zur Lösung, die wirklich zu Ihrem Unternehmen passt.
          </h2>
          <p class="text-foreground-secondary mt-6 max-w-2xl text-lg leading-8">
            Wenn Prozesse inzwischen mehr bremsen als tragen, lohnt ein strukturierter Blick.
            Rocketbase unterstützt bei der Einordnung, priorisiert sinnvolle Schritte und setzt
            tragfähige Lösungen mit um.
          </p>
        </div>
        <div data-aos="fade-left" class="border-border border-l pl-0 lg:pl-8">
          <div class="text-foreground-muted space-y-4 text-sm">
            <div class="flex items-center gap-3">
              <Icon name="clock" size="sm" class="text-brand-500" />
              30 Minuten direkt mit dem Gründer
            </div>
            <div class="flex items-center gap-3">
              <Icon name="mail" size="sm" class="text-brand-500" />
              {contactLinks.email}
            </div>
          </div>
          <div class="mt-8 flex flex-wrap gap-4">
            <Button href={contactLinks.cal} target="_blank">
              Erstgespräch buchen
              <Icon name="arrow-up-right" size="sm" />
            </Button>
            <Button variant="outline" href={contactUrl}> Kontaktseite </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
