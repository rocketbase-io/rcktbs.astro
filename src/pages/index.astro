---
import LandingLayout from '@/layouts/LandingLayout.astro';
import type { ImageMetadata } from 'astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath } from '@/i18n/index';
import siteConfig from '@/config/site.config';
import founderImage from '@/assets/rocketbase/founder-marten.jpg';
import bonprixCaseImage from '@/assets/rocketbase/case-bonprix.png';
import statistaCaseImage from '@/assets/rocketbase/case-statista.png';
import heroBg from '@/assets/rocketbase/hero-bg.png';
import toolsBefore from '@/assets/work/tools-before.png';
import toolsAfter from '@/assets/work/tools-after.png';
import {
  cases,
  contactLinks,
  discoveryOffer,
  processSteps,
  serviceAreas,
  strengths,
} from '@/data/rocketbase';

const locale = defaultLocale;
const servicesUrl = getLocalizedPath('services', locale);
const contactUrl = getLocalizedPath('contact', locale);
const missionUrl = getLocalizedPath('mission', locale);
const referencesUrl = '/referenzen';
const workUrl = getLocalizedPath('work', locale);

type FeaturedCase = (typeof cases)[number] & { image?: ImageMetadata };

const featuredCases: FeaturedCase[] = [
  { ...cases[0], image: bonprixCaseImage },
  { ...cases[1], image: statistaCaseImage },
  { ...cases[2] },
];

const topStrengths = strengths.slice(0, 3);

const useCaseTeasers = [
  {
    icon: 'layers',
    title: 'Interne Plattformen',
    text: 'Wenn Produktdaten, Rollen und Prozesse in ein belastbares System zusammenlaufen sollen.',
  },
  {
    icon: 'box',
    title: 'Standardsoftware ablösen',
    text: 'Wenn ERP, CRM oder Branchensoftware den echten Arbeitsalltag eher verbiegt als trägt.',
  },
  {
    icon: 'database',
    title: 'CRM · PIM · PLM',
    text: 'Wenn Datenmodelle sauber werden müssen, statt nur mit Workarounds zu funktionieren.',
  },
  {
    icon: 'archive',
    title: 'Migration aus Altsystemen',
    text: 'Wenn Bestandsdaten, Parallelbetrieb und Umstellung ohne Chaos zusammen gedacht werden müssen.',
  },
  {
    icon: 'users',
    title: 'Self-Service-Portale',
    text: 'Wenn interne Teams oder B2B-Kunden klar geführte Oberflächen statt Tool-Sprünge brauchen.',
  },
  {
    icon: 'globe',
    title: 'Integrationsprojekte',
    text: 'Wenn APIs, Drittsysteme und Prozesse endlich ohne Datensilos zusammenspielen sollen.',
  },
];

const leadClients = [
  'bonprix',
  'Statista',
  'FKC Consulting',
  'Plattformmodernisierung',
  'Prozessdigitalisierung',
];

const directCollaborationDefinition =
  'Bei Rocketbase arbeiten Sie direkt mit Marten Prieß. Analyse, Konzeption und technische Entscheidungen bleiben dadurch nah am Projekt und sein Know-how ist nicht nur im Erstgespräch, sondern in der Umsetzung mit an Bord.';

const getReferenceUrl = (slug: string) => `${referencesUrl}/${slug}`;
---

<LandingLayout
  title="Rocketbase | Individuelle Software mit direkter Begleitung durch Marten Prieß"
  description={siteConfig.description}
  includeOrgSchema
  lang={locale}
  routeId="home"
>
  <section class="hero-landing border-border relative min-h-screen overflow-hidden border-b" data-hero-root>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(99,114,165,0.14),transparent_0,transparent_28%),radial-gradient(circle_at_82%_20%,rgba(99,114,165,0.16),transparent_0,transparent_32%),linear-gradient(135deg,rgba(255,255,255,0.98)_0%,rgba(248,250,253,0.97)_36%,rgba(242,246,251,0.96)_100%)] dark:bg-[radial-gradient(circle_at_18%_18%,rgba(99,114,165,0.18),transparent_0,transparent_28%),radial-gradient(circle_at_82%_20%,rgba(99,114,165,0.2),transparent_0,transparent_32%),linear-gradient(135deg,rgba(18,22,31,0.98)_0%,rgba(20,25,35,0.97)_36%,rgba(15,19,27,0.96)_100%)]"
    />
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.45] [background-image:linear-gradient(rgba(99,114,165,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(99,114,165,0.08)_1px,transparent_1px)] [background-size:clamp(48px,5vw,72px)_clamp(48px,5vw,72px)] [mask-image:linear-gradient(180deg,transparent_0%,black_16%,black_78%,transparent_100%)] dark:opacity-[0.22]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(99,114,165,0.22),transparent)]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute left-[8%] top-[14%] h-40 w-40 rounded-full border border-white/40 opacity-40 blur-[2px] dark:border-white/10 dark:opacity-25"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute right-[10%] bottom-[18%] h-56 w-56 rounded-full border border-brand-300/30 opacity-50 blur-[2px] dark:border-brand-300/15 dark:opacity-30"
      aria-hidden="true"
    />
    <div class="container relative z-10 flex min-h-screen flex-col justify-center pt-24 pb-14 max-[760px]:pt-20 max-[760px]:pb-10 sm:pt-30 lg:pt-28">
      <div class="hero-landing-grid grid gap-10 max-[760px]:gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(380px,0.92fr)] lg:items-center lg:gap-12">
        <div data-aos="fade-right" class="hero-landing-copy max-w-3xl will-change-transform" data-hero-copy>
          <div class="text-brand-600 text-sm font-semibold tracking-[0.24em] uppercase">
            Marten Prieß direkt im Projekt
          </div>

          <h1 class="hero-landing-title font-display text-foreground mt-6 max-w-5xl text-4xl font-bold tracking-tight max-[760px]:mt-5 max-[760px]:text-[2.15rem] sm:text-5xl xl:text-6xl">
            Wir entwickeln nicht einfach Software.
            <span class="mt-2 block text-brand-500">Wir denken Prozesse weiter.</span>
          </h1>

          <p class="hero-landing-intro text-foreground-secondary mt-6 max-w-2xl text-lg leading-8 max-[760px]:mt-5 max-[760px]:text-base max-[760px]:leading-7 sm:text-xl">
            Rocketbase baut individuelle Software für Unternehmen, die nicht noch mehr Tool-Wildwuchs
            brauchen, sondern klare Abläufe, belastbare Plattformen und einen Partner, der fachlich
            wie technisch mitdenkt.
          </p>

          <div class="hero-landing-definition border-brand-300/70 mt-8 max-w-2xl border-l-2 pl-5 max-[760px]:mt-6 max-[760px]:pl-4">
            <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
              So arbeiten wir
            </p>
            <p class="text-foreground-secondary mt-3 text-base leading-7 max-[760px]:text-sm max-[760px]:leading-6">
              {directCollaborationDefinition}
            </p>
          </div>

          <div data-aos="fade-up" data-aos-delay="80" class="hero-landing-actions mt-8 flex flex-wrap gap-4 max-[760px]:mt-6 max-[760px]:gap-3">
            <Button size="lg" href={contactLinks.cal} target="_blank">
              Erstgespräch buchen
              <Icon name="arrow-up-right" size="sm" />
            </Button>
            <Button size="lg" variant="secondary" href={servicesUrl}>
              Leistungen ansehen
              <Icon name="arrow-right" size="sm" />
            </Button>
          </div>

          <div
            class="hero-landing-facts text-foreground-muted mt-10 grid gap-4 text-sm max-[760px]:mt-7 max-[760px]:gap-4 max-[760px]:text-[13px] sm:grid-cols-3"
          >
            <div data-aos="fade-up" data-aos-delay="120">
              <p class="text-foreground font-semibold">Seit 2016</p>
              <p class="mt-2 leading-6">Aufbau von Digitalprodukten und internen Plattformen.</p>
            </div>
            <div data-aos="fade-up" data-aos-delay="190">
              <p class="text-foreground font-semibold">bonprix &amp; Statista</p>
              <p class="mt-2 leading-6">
                Konzern-Erfahrung, übertragen auf mittelständische Realitäten.
              </p>
            </div>
            <div data-aos="fade-up" data-aos-delay="260">
              <p class="text-foreground font-semibold">Discovery bis Betrieb</p>
              <p class="mt-2 leading-6">
                Konzeption, Delivery, Integration und Weiterentwicklung aus einer Hand.
              </p>
            </div>
          </div>
        </div>

        <div data-aos="fade-left" class="hero-landing-visual relative will-change-transform max-[760px]:px-0 lg:pl-2" data-hero-visual>
          <div class="rb-float-slow bg-brand-300/14 absolute -top-4 right-8 h-44 w-44 rounded-full blur-3xl" />
          <div class="relative mx-auto w-full max-w-xl">
            <article class="hero-landing-card border-border/70 bg-card/90 relative overflow-hidden rounded-[2.3rem] border p-5 shadow-[0_28px_70px_rgba(34,43,74,0.12)] backdrop-blur max-[760px]:rounded-[2rem] max-[760px]:p-4 sm:p-6">
              <img
                src={heroBg.src}
                alt="Rocketbase Projektumfeld"
                class="hero-landing-image h-[15rem] w-full rounded-[1.8rem] object-cover max-[760px]:h-[10.5rem] max-[760px]:rounded-[1.5rem] sm:h-[18rem] lg:h-[20rem]"
              />
              <div class="mt-5 max-[760px]:mt-4">
                <div>
                  <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                    Rocketbase Ansatz
                  </p>
                  <p class="text-foreground mt-3 text-xl font-semibold leading-tight max-[760px]:mt-2 max-[760px]:text-lg">
                    Kleine, starke Einheit. Direkte Entscheidungen. Architektur mit Blick auf den echten Betrieb.
                  </p>
                  <p class="text-foreground-secondary mt-4 max-w-xl text-base leading-7 max-[760px]:mt-3 max-[760px]:text-sm max-[760px]:leading-6">
                    Keine unnötige Agenturdramaturgie, sondern klare Gespräche über Prozesse,
                    Prioritäten und die sinnvollste technische Lösung.
                  </p>
                </div>
              </div>
            </article>

            <article class="hero-landing-meta border-border/80 bg-background/80 mt-4 rounded-[1.7rem] border p-5 backdrop-blur max-[760px]:mt-3 max-[760px]:rounded-[1.45rem] max-[760px]:p-4">
              <div class="grid gap-4 sm:grid-cols-2">
                <div>
                  <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                    Direkter Nutzen
                  </p>
                  <p class="text-foreground-secondary mt-3 text-base leading-7 max-[760px]:mt-2 max-[760px]:text-sm max-[760px]:leading-6">
                    Direkter Draht zu Marten Prieß statt Übergaben über mehrere Rollen.
                  </p>
                </div>
                <div>
                  <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                    Technologie
                  </p>
                  <p class="text-foreground-secondary mt-3 text-base leading-7 max-[760px]:mt-2 max-[760px]:text-sm max-[760px]:leading-6">
                    Pragmatische Technologieauswahl mit Open Source dort, wo sie trägt.
                  </p>
                </div>
              </div>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const hero = document.querySelector('[data-hero-root]');
      const copy = document.querySelector('[data-hero-copy]');
      const visual = document.querySelector('[data-hero-visual]');

      if (!hero || !copy || !visual) return;

      let ticking = false;

      const updateHeroProgress = () => {
        const rect = hero.getBoundingClientRect();
        const viewport = window.innerHeight || 1;
        const progress = Math.min(Math.max(-rect.top / viewport, 0), 1);

        copy.style.transform = `translate3d(0, ${progress * 36}px, 0)`;
        copy.style.opacity = `${1 - progress * 0.22}`;

        visual.style.transform = `translate3d(0, ${progress * 68}px, 0) scale(${1 - progress * 0.05})`;
        visual.style.opacity = `${1 - progress * 0.16}`;

        ticking = false;
      };

      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateHeroProgress);
      };

      updateHeroProgress();
      document.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
    })();
  </script>

  <section id="clients" class="border-border bg-background-secondary border-b py-8">
    <div class="container flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <span class="text-foreground-muted text-sm font-semibold tracking-[0.2em] uppercase" data-aos="fade-right">
        Erfahrung aus Projekten mit
      </span>
      <p class="text-foreground-secondary text-sm leading-7" data-aos="fade-left">
        {leadClients.join(' · ')}
      </p>
    </div>
  </section>

  <section class="border-border bg-background-secondary relative overflow-hidden border-b py-28 lg:py-36">
    <div class="bg-grid-pattern pointer-events-none absolute inset-0 opacity-25 [mask-image:radial-gradient(circle_at_center,black_24%,transparent_78%)]" />
    <div class="container relative z-10 space-y-14">
      <div class="grid gap-10 xl:grid-cols-[1.05fr_0.95fr] xl:items-end xl:gap-16">
        <div data-aos="fade-right">
          <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Warum Rocketbase</p>
          <h2 class="font-display text-foreground mt-4 max-w-4xl text-4xl font-bold tracking-tight sm:text-5xl xl:text-[3.5rem]">
            Keine verlängerte Werkbank.
            <span class="mt-2 block text-brand-500">Ein Team, das mitdenkt.</span>
          </h2>
          <p class="text-foreground-secondary mt-6 max-w-3xl text-lg leading-8">
            Rocketbase wurde nicht gegründet, um einzelne Entwickler in Projekte zu schicken. Der
            Anspruch ist ein anderer: Verantwortung inhaltlich und technisch übernehmen, Prozesse
            verstehen und Lösungen liefern, die langfristig funktionieren.
          </p>
        </div>

        <div data-aos="fade-left" class="border-brand-300/70 max-w-2xl border-l-2 pl-5 xl:justify-self-end">
          <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
            Kurz gesagt
          </p>
          <p class="text-foreground mt-4 text-2xl font-semibold leading-tight">
            Direkter Zugriff auf jemanden, der Business-Logik und Architektur zusammen denkt.
          </p>
          <p class="text-foreground-secondary mt-4 text-base leading-7">
            Genau deshalb entstehen weniger Missverständnisse, weniger Übergaben und schneller
            belastbare Entscheidungen.
          </p>
        </div>
      </div>

      <div class="why-rocketbase-track relative space-y-6">
        {
          topStrengths.map((strength, index) => (
            <article
              data-aos="fade-left"
              data-aos-delay={index * 70}
              data-why-card
              class:list={[
                'why-rocketbase-card rounded-[2rem] border p-8 transition-all duration-300',
                index === 0
                  ? 'border-brand-300 bg-card shadow-[0_20px_50px_rgba(34,43,74,0.08)]'
                  : 'border-border bg-background/80',
              ]}
            >
              <div class="grid gap-5 md:grid-cols-[72px_1fr] md:items-start">
                <div class="bg-background text-brand-600 flex h-13 w-13 items-center justify-center rounded-2xl border border-border text-sm font-semibold">
                  0{index + 1}
                </div>
                <div>
                  <h3 class="text-foreground text-2xl font-semibold">{strength.title}</h3>
                  <p class="text-foreground-secondary mt-4 max-w-2xl text-base leading-7">
                    {strength.description}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-border relative overflow-hidden border-b py-24 lg:py-32">
    <div class="container">
      <a data-aos="zoom-in" href={workUrl} class="how-we-work group block" data-how-we-work>
        <div class="relative overflow-hidden py-2 transition-all duration-500">
          <div class="bg-brand-300/12 absolute top-12 right-0 h-48 w-48 rounded-full blur-3xl transition-all duration-500 group-hover:bg-brand-300/20" />
          <div class="relative space-y-10">
            <div class="grid gap-10 xl:grid-cols-[0.9fr_1.1fr] xl:items-start xl:gap-12">
              <div>
                <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Wie wir arbeiten</p>
                <h2 class="font-display text-foreground mt-5 max-w-4xl text-4xl font-bold tracking-tight sm:text-5xl xl:text-[3.6rem]">
                  Weniger Overhead.
                  <span class="mt-2 block text-brand-500">Mehr Geschwindigkeit.</span>
                </h2>
                <p class="text-foreground-secondary mt-6 max-w-3xl text-lg leading-8">
                  Wir zeigen dir konkret, wie moderne Softwareentwicklung heute funktioniert und warum
                  klassische Ansätze Projekte unnötig ausbremsen.
                </p>
              </div>

              <div class="relative mx-auto w-full max-w-2xl xl:pt-2">
                <div class="relative min-h-[22rem] sm:min-h-[27rem]">
                  <div class="how-we-work-after absolute right-0 top-0 z-10 w-[74%] sm:w-[72%]" data-aos="fade-left" data-aos-delay="120">
                    <div class="relative overflow-hidden rounded-[2.4rem] shadow-[0_30px_70px_rgba(34,43,74,0.16)] transition-all duration-500 group-hover:z-20 group-hover:-translate-y-2 group-hover:scale-[1.03] group-hover:shadow-[0_38px_90px_rgba(34,43,74,0.22)]">
                      <img
                        src={toolsAfter.src}
                        alt="Nachher: integriertes System mit klaren Datenflüssen"
                        class="aspect-[4/3.8] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                      />
                      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-black/35 to-transparent" />
                      <div class="absolute right-5 bottom-5 rounded-full bg-white/88 px-3 py-1 text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-700 backdrop-blur">
                        Mit Rocketbase
                      </div>
                    </div>
                  </div>

                  <div class="how-we-work-before absolute bottom-0 left-0 z-0 w-[48%] sm:w-[46%]" data-aos="fade-right" data-aos-delay="60">
                    <div class="relative overflow-hidden rounded-[2rem] shadow-[0_20px_45px_rgba(34,43,74,0.08)] transition-all duration-500 group-hover:translate-y-2 group-hover:scale-[0.97] group-hover:opacity-85 group-hover:shadow-[0_16px_30px_rgba(34,43,74,0.08)]">
                      <img
                        src={toolsBefore.src}
                        alt="Vorher: gewachsener Tool-Zoo mit verteilten Systemen"
                        class="aspect-[4/4.5] w-full object-cover grayscale transition-all duration-700 group-hover:scale-[1.03] group-hover:grayscale-[0.15]"
                      />
                      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/35 to-transparent" />
                      <div class="absolute right-4 bottom-4 rounded-full bg-white/80 px-3 py-1 text-[11px] font-semibold tracking-[0.22em] uppercase text-foreground backdrop-blur">
                        Vorher
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="grid gap-8 border-t border-border/70 pt-8 lg:grid-cols-2 lg:gap-12">
              <div data-aos="fade-up" data-aos-delay="80">
                <p class="text-foreground text-lg font-semibold">Vorher</p>
                <p class="text-foreground-secondary mt-3 max-w-2xl text-base leading-7">
                  Gewachsener Tool-Zoo: Bestellungen in Excel, Kunden im CRM, Versand in Trello,
                  Reports per Mail. Daten leben in Silos, Prozesse laufen manuell, Doppelarbeit
                  überall.
                </p>
              </div>

              <div data-aos="fade-up" data-aos-delay="140">
                <p class="text-brand-600 text-lg font-semibold">Mit Rocketbase</p>
                <p class="text-foreground-secondary mt-3 max-w-2xl text-base leading-7">
                  Eine integrierte Lösung: Ein PIM, ein ERP-Backend, ein Dashboard. Bestellungen,
                  Stammdaten und Auswertungen verzahnt, eine Quelle der Wahrheit.
                </p>
              </div>
            </div>

            <div class="inline-flex items-center gap-3 text-sm font-semibold text-brand-600 transition-transform duration-300 group-hover:translate-x-1">
              Weitere Vergleiche ansehen
              <Icon name="arrow-right" size="sm" />
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const compareSection = document.querySelector('[data-how-we-work]');
      const compareBefore = document.querySelector('.how-we-work-before');
      const compareAfter = document.querySelector('.how-we-work-after');
      const cards = Array.from(document.querySelectorAll('[data-why-card]'));

      if (compareSection && compareBefore && compareAfter) {
        let compareTicking = false;

        const updateCompare = () => {
          const rect = compareSection.getBoundingClientRect();
          const viewport = window.innerHeight || 1;
          const progress = Math.min(Math.max((viewport - rect.top) / (viewport + rect.height), 0), 1);
          const eased = 1 - Math.pow(1 - progress, 2);

          compareAfter.style.transform = `translate3d(0, ${eased * -8}px, 0) scale(${1 + eased * 0.01})`;
          compareBefore.style.transform = `translate3d(0, ${eased * 6}px, 0) scale(${1 - eased * 0.01})`;
          compareAfter.style.opacity = `${0.96 + eased * 0.04}`;
          compareBefore.style.opacity = `${1 - eased * 0.08}`;

          compareTicking = false;
        };

        const onCompareScroll = () => {
          if (compareTicking) return;
          compareTicking = true;
          window.requestAnimationFrame(updateCompare);
        };

        updateCompare();
        document.addEventListener('scroll', onCompareScroll, { passive: true });
        window.addEventListener('resize', onCompareScroll);
      }

      if (cards.length === 0) return;

      let activeIndex = 0;

      const updateActiveCard = () => {
        const trigger = window.innerHeight * 0.42;
        let closestIndex = 0;
        let closestDistance = Number.POSITIVE_INFINITY;

        cards.forEach((card, index) => {
          const rect = card.getBoundingClientRect();
          const center = rect.top + rect.height / 2;
          const distance = Math.abs(center - trigger);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        activeIndex = closestIndex;
        cards.forEach((card, index) => {
          card.classList.toggle('is-active', index === activeIndex);
        });
      };

      const onChange = () => window.requestAnimationFrame(updateActiveCard);

      updateActiveCard();
      document.addEventListener('scroll', onChange, { passive: true });
      window.addEventListener('resize', onChange);
    })();
  </script>

  <section class="border-border border-b py-28 lg:py-36">
    <div class="container">
      <div data-aos="fade-up" class="max-w-3xl">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Typische Vorhaben</p>
        <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Lösungen für Prozesse,
          <span class="text-brand-500">nicht für Buzzwords.</span>
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Sechs Vorhaben, bei denen Rocketbase besonders gut trägt: wenn Abläufe gewachsen sind,
          Datenqualität leidet und Standardsoftware nicht mehr sauber zur Realität passt.
        </p>
      </div>

      <div class="mt-16 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {
          useCaseTeasers.map((useCase, index) => (
            <article
              data-aos="fade-up"
              data-aos-delay={index * 60}
              class="group relative overflow-hidden rounded-[1.8rem] border border-border bg-card p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-300 hover:shadow-[0_24px_50px_rgba(34,43,74,0.12)]"
            >
              <div class="bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-100 group-hover:bg-brand-500 group-hover:text-on-invert inline-flex h-12 w-12 items-center justify-center rounded-xl transition-all duration-300 group-hover:scale-110">
                <Icon name={useCase.icon} size="md" />
              </div>
              <h3 class="font-display text-foreground mt-6 text-xl font-semibold">{useCase.title}</h3>
              <p class="text-foreground-secondary mt-3 text-sm leading-7">{useCase.text}</p>
            </article>
          ))
        }
      </div>

      <div data-aos="fade-up" class="mt-10 flex justify-center">
        <Button variant="outline" href={servicesUrl}>
          Alle Leistungen im Detail
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <section class="border-border bg-background-secondary border-b py-28 lg:py-36">
    <div class="container grid gap-14 lg:grid-cols-[0.84fr_1.16fr] lg:items-start">
      <div data-aos="fade-right" class="lg:sticky lg:top-28">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Leistungen</p>
        <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Beratung, Konzeption und Umsetzung
          <span class="mt-2 block text-brand-500">mit möglichst wenig Reibung.</span>
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Rocketbase verbindet Prozessverständnis, technische Architektur und Delivery. Dadurch
          entstehen weniger Übergaben und schneller belastbare Entscheidungen.
        </p>
        <div class="text-foreground-muted mt-8 text-sm leading-7">
          Discovery · Konzeption · Individualsoftware · Integration · Betrieb
        </div>
      </div>

      <div class="space-y-6" data-aos="fade-left">
        {
          serviceAreas.map((service, index) => (
            <article class="rounded-[2rem] border border-border bg-card p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_45px_rgba(34,43,74,0.08)]">
              <div class="grid gap-5 md:grid-cols-[68px_1fr] md:items-start">
                <div class="text-brand-600 text-sm font-semibold">0{index + 1}</div>
                <div>
                  <h3 class="text-foreground text-2xl font-semibold">{service.title}</h3>
                  <p class="text-foreground-secondary mt-3 max-w-2xl text-base leading-7">
                    {service.description}
                  </p>
                  <ul class="text-foreground-secondary mt-6 grid gap-x-8 gap-y-3 text-sm sm:grid-cols-2">
                    {service.bullets.map((bullet) => (
                      <li class="flex gap-3">
                        <Icon name="arrow-right" size="sm" class="text-brand-400 mt-0.5 shrink-0" />
                        <span>{bullet}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-border border-b py-28 lg:py-36">
    <div class="container">
      <div data-aos="fade-up" class="max-w-3xl">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Referenzen</p>
        <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Konzern-Erfahrung, sauber übersetzt
          <span class="mt-2 block text-brand-500">in mittelständische Realität.</span>
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Drei Beispiele dafür, wie Rocketbase in sehr unterschiedlichen Ausgangslagen arbeitet:
          bei Konzernstrukturen, gewachsenen Kernsystemen und dem Schritt von Standardsoftware zu
          einer individuellen Lösung.
        </p>
      </div>

      <div class="mt-16 grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
        <article data-aos="fade-right" class="group overflow-hidden rounded-[2.4rem] border border-border bg-card shadow-[0_22px_55px_rgba(34,43,74,0.08)] transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(34,43,74,0.12)]">
          <a href={getReferenceUrl(featuredCases[0].slug)} class="grid h-full lg:grid-cols-[1.05fr_0.95fr]">
            <div class="overflow-hidden">
              <img
                src={featuredCases[0].image.src}
                alt={featuredCases[0].title}
                class="h-full min-h-[20rem] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
              />
            </div>
            <div class="flex flex-col justify-between p-8">
              <div>
                <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                  {featuredCases[0].client}
                </p>
                <h3 class="text-foreground mt-4 text-3xl font-semibold leading-tight">
                  {featuredCases[0].title}
                </h3>
                <p class="text-foreground-secondary mt-5 text-base leading-8">
                  {featuredCases[0].kicker}
                </p>
              </div>
              <div class="mt-8 border-t border-border pt-6">
                <p class="text-foreground-muted text-sm leading-7">
                  Prozess im Fokus: {featuredCases[0].processFocus}
                </p>
                <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-brand-600">
                  Case ansehen
                  <Icon name="arrow-right" size="sm" />
                </div>
              </div>
            </div>
          </a>
        </article>

        <div class="grid gap-6">
          {
            featuredCases.slice(1).map((item, index) => (
              <article
                data-aos="fade-left"
                data-aos-delay={index * 70}
                class="group overflow-hidden rounded-[2rem] border border-border bg-card shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_45px_rgba(34,43,74,0.1)]"
              >
                <a href={getReferenceUrl(item.slug)} class="grid h-full md:grid-cols-[0.85fr_1.15fr]">
                  {item.image ? (
                    <div class="overflow-hidden">
                      <img
                        src={item.image.src}
                        alt={item.title}
                        class="h-full min-h-[16rem] w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]"
                      />
                    </div>
                  ) : (
                    <div class="flex min-h-[16rem] flex-col justify-between bg-[linear-gradient(160deg,rgba(243,245,249,0.96),rgba(229,234,242,0.92))] p-7 dark:bg-[linear-gradient(160deg,rgba(36,43,57,0.92),rgba(26,31,42,0.9))]">
                      <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                        {item.client}
                      </p>
                      <p class="font-display text-foreground text-2xl leading-snug font-bold tracking-tight">
                        Von Standardsoftware zur individuellen Plattform
                      </p>
                    </div>
                  )}

                  <div class="p-7">
                    <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">{item.client}</p>
                    <h3 class="text-foreground mt-3 text-2xl font-semibold">{item.title}</h3>
                    <p class="text-foreground-secondary mt-4 text-sm leading-7">{item.kicker}</p>
                    <ul class="text-foreground-muted mt-5 space-y-2 text-sm leading-6">
                      {item.highlights.slice(0, 2).map((highlight) => (
                        <li class="flex gap-3">
                          <Icon name="check-circle" size="sm" class="text-brand-400 mt-0.5 shrink-0" />
                          <span>{highlight}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </a>
              </article>
            ))
          }
        </div>
      </div>

      <div class="mt-10 flex justify-start" data-aos="fade-up">
        <Button variant="outline" href={referencesUrl}>
          Alle Referenzen ansehen
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <section class="border-border bg-surface-invert text-on-invert border-b py-28 lg:py-36">
    <div class="container grid gap-14 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div data-aos="fade-right" class="lg:sticky lg:top-28">
        <p class="text-brand-300 text-sm font-semibold tracking-[0.22em] uppercase">Projektverlauf</p>
        <h2 class="font-display mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Kein Sprung ins Unklare.
          <span class="mt-2 block text-brand-200">Ein klarer Weg von Analyse bis Betrieb.</span>
        </h2>
        <p class="text-on-invert-secondary mt-6 text-lg leading-8">
          Projekte werden tragfähig, wenn Prioritäten, Architektur und Delivery in einer sauberen
          Reihenfolge passieren. Genau daran orientiert sich Rocketbase.
        </p>
      </div>

      <div class="space-y-5">
        {
          processSteps.map((step, index) => (
            <article
              data-aos="fade-left"
              data-aos-delay={index * 70}
              class="rounded-[2rem] border border-white/10 bg-white/5 p-7 backdrop-blur"
            >
              <div class="grid gap-5 md:grid-cols-[72px_1fr]">
                <div class="text-brand-300 text-sm font-semibold">0{index + 1}</div>
                <div>
                  <h3 class="text-on-invert text-2xl font-semibold">{step.title}</h3>
                  <p class="text-on-invert-secondary mt-3 text-base leading-7">{step.description}</p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-border bg-background-secondary border-b py-28 lg:py-36">
    <div class="container max-w-6xl">
      <div class="grid gap-10 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
        <div data-aos="fade-right">
          <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">
            Presales mit Substanz
          </p>
          <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
            {discoveryOffer.title}
          </h2>
          <p class="text-foreground-secondary mt-4 text-xl">{discoveryOffer.subtitle}</p>
          <p class="text-foreground-secondary mt-6 max-w-2xl text-lg leading-8">
            {discoveryOffer.description}
          </p>
        </div>

        <div
          data-aos="fade-left"
          class="rounded-[2.2rem] border border-border bg-card p-8 shadow-[0_22px_55px_rgba(34,43,74,0.08)]"
        >
          <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
            Typische Ergebnisse
          </p>
          <ul class="text-foreground-secondary mt-6 space-y-4 text-base leading-7">
            {
              discoveryOffer.deliverables.map((item, index) => (
                <li data-aos="zoom-in" data-aos-delay={index * 60} class="flex gap-3">
                  <Icon name="check-circle" size="sm" class="text-brand-500 mt-1 shrink-0" />
                  <span>{item}</span>
                </li>
              ))
            }
          </ul>
          <div class="mt-8">
            <Button href={contactLinks.cal} target="_blank">
              Workshop oder Erstgespräch anfragen
              <Icon name="arrow-up-right" size="sm" />
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-border relative overflow-hidden border-b py-28 lg:py-36">
    <div class="bg-brand-300/10 absolute left-0 top-1/3 h-80 w-80 rounded-full blur-3xl" />
    <div class="container relative z-10 grid items-center gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:gap-16">
      <div
        data-aos="fade-right"
        class="group overflow-hidden rounded-[2.4rem] border border-border shadow-[0_24px_60px_rgba(34,43,74,0.1)] transition-all duration-500 hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(34,43,74,0.14)]"
      >
        <img
          src={founderImage.src}
          alt="Marten Prieß, Gründer von Rocketbase"
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
      </div>

      <div data-aos="fade-left">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Über Rocketbase</p>
        <h2 class="font-display text-foreground mt-6 text-4xl font-bold tracking-tight sm:text-5xl">
          Marten Prieß
          <span class="mt-2 block text-brand-500">und ein kleines Remote-Team.</span>
        </h2>
        <p class="text-foreground-secondary mt-8 text-lg leading-8">
          Keine klassische Softwareagentur, kein Body-Leasing. Kunden arbeiten direkt mit dem
          Gründer zusammen und mit einem eingespielten Remote-Team im Rücken.
        </p>
        <p class="text-foreground-secondary mt-5 text-lg leading-8">
          Erfahrung aus Konzernprojekten, Produktentwicklung und Mittelstandsvorhaben fließt so in
          jedes Projekt ein, ohne dass Kommunikation unnötig aufgebläht wird.
        </p>
        <div data-aos="fade-up" class="mt-8 flex flex-wrap gap-4">
          <Button href={contactLinks.cal} target="_blank">
            Erstgespräch buchen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <Button variant="outline" href={missionUrl}>
            Zur Mission
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section id="cta" class="py-28 lg:py-36">
    <div class="container">
      <div class="overflow-hidden rounded-[2.8rem] border border-border bg-background-secondary p-8 shadow-[0_24px_60px_rgba(34,43,74,0.08)] sm:p-10 lg:p-12">
        <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-end">
          <div data-aos="fade-right">
            <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Nächster Schritt</p>
            <h2 class="font-display text-foreground mt-4 text-4xl font-bold tracking-tight sm:text-5xl">
              Von Standardsoftware zur Lösung,
              <span class="mt-2 block text-brand-500">die wirklich zu Ihrem Unternehmen passt.</span>
            </h2>
            <p class="text-foreground-secondary mt-6 max-w-2xl text-lg leading-8">
              Wenn Prozesse inzwischen mehr bremsen als tragen, lohnt ein strukturierter Blick.
              Rocketbase hilft bei der Einordnung, priorisiert sinnvolle Schritte und setzt tragfähige
              Lösungen anschließend mit um.
            </p>
          </div>

          <div data-aos="fade-left" class="rounded-[2rem] border border-border bg-card p-7">
            <div class="text-foreground-muted space-y-4 text-sm">
              <div class="flex items-center gap-3">
                <Icon name="clock" size="sm" class="text-brand-500" />
                30 Minuten direkt mit dem Gründer
              </div>
              <div class="flex items-center gap-3">
                <Icon name="mail" size="sm" class="text-brand-500" />
                {contactLinks.email}
              </div>
            </div>
            <div class="mt-8 flex flex-wrap gap-4">
              <Button href={contactLinks.cal} target="_blank">
                Erstgespräch buchen
                <Icon name="arrow-up-right" size="sm" />
              </Button>
              <Button variant="outline" href={contactUrl}>
                Kontaktseite
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</LandingLayout>
