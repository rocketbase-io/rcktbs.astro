---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { ClientLogoStrip } from '@/components/ui/marketing/ClientLogoStrip';
import { TestimonialCarousel } from '@/components/ui/marketing/TestimonialCarousel';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath } from '@/i18n/index';
import siteConfig from '@/config/site.config';
import founderImage from '@/assets/rocketbase/founder-marten-priess.jpg';
import bonprixCaseImage from '@/assets/references/teaser-bonprix.jpeg';
import statistaCaseImage from '@/assets/references/teaser-statista.jpeg';
import fkcCaseImage from '@/assets/references/teaser-fkc.jpeg';
import schlossereiCaseImage from '@/assets/references/teaser-schlosserei.jpeg';
import heroBg from '@/assets/rocketbase/hero-bg.png';
import toolsBefore from '@/assets/work/tools-before.png';
import toolsAfter from '@/assets/work/tools-after.png';
import {
  cases,
  additionalCases,
  contactLinks,
  discoveryOffer,
  processSteps,
  serviceAreas,
  strengths,
} from '@/data/rocketbase';

const locale = defaultLocale;
const servicesUrl = getLocalizedPath('services', locale);
const contactUrl = getLocalizedPath('contact', locale);
const missionUrl = getLocalizedPath('mission', locale);
const referencesUrl = '/referenzen';
const workUrl = getLocalizedPath('work', locale);

type FeaturedCase = (typeof cases)[number] & { image?: ImageMetadata };

const caseImageMap: Record<string, ImageMetadata> = {
  bonprix: bonprixCaseImage,
  statista: statistaCaseImage,
  'fkc-consulting': fkcCaseImage,
  'metall-pro': schlossereiCaseImage,
};

const featuredCases: FeaturedCase[] = cases
  .slice(0, 3)
  .map((entry) => ({ ...entry, image: caseImageMap[entry.slug] }));

const topStrengths = strengths.slice(0, 3);

const useCaseTeasers = [
  {
    icon: 'layers',
    title: 'Interne Plattformen',
    text: 'Wenn Produktdaten, Rollen und Prozesse in ein belastbares System zusammenlaufen sollen.',
  },
  {
    icon: 'box',
    title: 'Standardsoftware ablösen',
    text: 'Wenn ERP, CRM oder Branchensoftware den echten Arbeitsalltag eher verbiegt als trägt.',
  },
  {
    icon: 'database',
    title: 'CRM · PIM · PLM',
    text: 'Wenn Datenmodelle sauber werden müssen, statt nur mit Workarounds zu funktionieren.',
  },
  {
    icon: 'archive',
    title: 'Migration aus Altsystemen',
    text: 'Wenn Bestandsdaten, Parallelbetrieb und Umstellung ohne Chaos zusammen gedacht werden müssen.',
  },
  {
    icon: 'users',
    title: 'Self-Service-Portale',
    text: 'Wenn interne Teams oder B2B-Kunden klar geführte Oberflächen statt Tool-Sprünge brauchen.',
  },
  {
    icon: 'globe',
    title: 'Integrationsprojekte',
    text: 'Wenn APIs, Drittsysteme und Prozesse endlich ohne Datensilos zusammenspielen sollen.',
  },
];

const clientLogos = [
  { key: 'bonprix_logo', name: 'bonprix' },
  { key: 'statista-logo', name: 'Statista' },
  { key: 'stage_logo', name: 'Stage Entertainment' },
  { key: 'fkc_logo', name: 'FKC Consulting' },
  { key: 'mavox_logo', name: 'MAVOX Winterdienst' },
  { key: 'sam', name: 'Smart Active Media' },
  { key: 'yomei_logo', name: 'YOMEI' },
  { key: 'venus_logo', name: 'Venus' },
  { key: 'stueckgut', name: 'Stückgut' },
];

const portraitModules = import.meta.glob<{ default: ImageMetadata }>(
  '@/assets/testimonials/*.{jpeg,jpg,png,webp}',
  { eager: true },
);
const portraitMap: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(portraitModules).map(([path, mod]) => {
    const key = path.split('/').pop()!.replace(/\.(jpe?g|png|webp)$/i, '');
    return [key, mod.default];
  }),
);

const allCases = [...cases, ...additionalCases];
const testimonialItems = allCases
  .filter((c) => c.testimonial)
  .map((c) => {
    const t = c.testimonial!;
    return {
      quote: t.quote,
      author: t.author,
      position: t.position,
      client: c.client,
      portrait: t.portraitKey ? portraitMap[t.portraitKey] : undefined,
    };
  });

const getReferenceUrl = (slug: string) => `${referencesUrl}/${slug}`;
---

<LandingLayout
  title="Individuelle Software für den ambitionierten Mittelstand"
  description={siteConfig.description}
  includeOrgSchema
  lang={locale}
  routeId="home"
>
  <section class="hero-landing border-border relative min-h-screen overflow-hidden border-b max-[760px]:min-h-0" data-hero-root>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,rgba(99,114,165,0.14),transparent_0,transparent_28%),radial-gradient(circle_at_82%_20%,rgba(99,114,165,0.16),transparent_0,transparent_32%),linear-gradient(135deg,rgba(255,255,255,0.98)_0%,rgba(248,250,253,0.97)_36%,rgba(242,246,251,0.96)_100%)] dark:bg-[radial-gradient(circle_at_18%_18%,rgba(99,114,165,0.18),transparent_0,transparent_28%),radial-gradient(circle_at_82%_20%,rgba(99,114,165,0.2),transparent_0,transparent_32%),linear-gradient(135deg,rgba(18,22,31,0.98)_0%,rgba(20,25,35,0.97)_36%,rgba(15,19,27,0.96)_100%)]"
    />
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-[linear-gradient(90deg,transparent,rgba(99,114,165,0.22),transparent)]"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute left-[8%] top-[14%] h-40 w-40 rounded-full border border-white/40 opacity-40 blur-[2px] dark:border-white/10 dark:opacity-25"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute right-[10%] bottom-[18%] h-56 w-56 rounded-full border border-brand-300/30 opacity-50 blur-[2px] dark:border-brand-300/15 dark:opacity-30"
      aria-hidden="true"
    />
    <div class="container relative z-10 flex min-h-screen flex-col justify-center pt-24 pb-24 max-[760px]:min-h-0 max-[760px]:pt-20 max-[760px]:pb-28 sm:pt-30 lg:pt-28 lg:pb-28">
      <div class="hero-landing-grid grid gap-10 max-[760px]:gap-8 lg:grid-cols-[minmax(0,1.02fr)_minmax(380px,0.92fr)] lg:items-center lg:gap-12">
        <div data-reveal="fade-right" class="hero-landing-copy max-w-3xl will-change-transform" data-hero-copy>
          <h1 class="hero-landing-title font-display text-foreground max-w-5xl text-4xl font-bold tracking-tight max-[760px]:text-[2.15rem] sm:text-5xl xl:text-6xl">
            Wir entwickeln nicht einfach Software.
            <span class="mt-2 block text-brand-500">Wir denken Prozesse weiter.</span>
          </h1>

          <p class="hero-landing-intro text-foreground-secondary mt-6 max-w-2xl text-lg leading-8 max-[760px]:mt-5 max-[760px]:text-base max-[760px]:leading-7 sm:text-xl">
            RocketBase baut individuelle Software für Unternehmen, die nicht noch mehr Tool-Wildwuchs
            brauchen, sondern klare Abläufe, belastbare Plattformen und einen Partner, der fachlich
            wie technisch mitdenkt.
          </p>

          <div data-reveal class="hero-landing-actions mt-8 flex flex-wrap gap-4 max-[760px]:mt-6 max-[760px]:gap-3">
            <Button size="lg" href={contactLinks.cal} target="_blank">
              Erstgespräch buchen
              <Icon name="arrow-up-right" size="sm" />
            </Button>
            <Button size="lg" variant="secondary" href={servicesUrl}>
              Leistungen ansehen
              <Icon name="arrow-right" size="sm" />
            </Button>
          </div>

          <div
            class="hero-landing-facts text-foreground-muted mt-10 grid gap-4 text-sm max-[760px]:mt-7 max-[760px]:gap-4 max-[760px]:text-[13px] sm:grid-cols-3"
          >
            <div data-reveal>
              <p class="text-foreground font-semibold">Seit 2016</p>
              <p class="mt-2 leading-6">Aufbau von Digitalprodukten und internen Plattformen.</p>
            </div>
            <div data-reveal>
              <p class="text-foreground font-semibold">bonprix &amp; Statista</p>
              <p class="mt-2 leading-6">
                Konzern-Erfahrung, übertragen auf mittelständische Realitäten.
              </p>
            </div>
            <div data-reveal>
              <p class="text-foreground font-semibold">Discovery bis Betrieb</p>
              <p class="mt-2 leading-6">
                Konzeption, Delivery, Integration und Weiterentwicklung aus einer Hand.
              </p>
            </div>
          </div>
        </div>

        <div data-reveal="fade-left" class="hero-landing-visual relative will-change-transform max-[760px]:px-0 lg:pl-2" data-hero-visual>
          <div class="rb-float-slow bg-brand-300/14 absolute -top-4 right-8 h-44 w-44 rounded-full blur-3xl" />
          <div class="relative mx-auto w-full max-w-xl">
            <article class="hero-landing-card border-border/70 bg-card/90 relative overflow-hidden rounded-[2.3rem] border p-5 shadow-[0_28px_70px_rgba(34,43,74,0.12)] backdrop-blur max-[760px]:rounded-[2rem] max-[760px]:p-4 sm:p-6">
              <img
                src={heroBg.src}
                alt="RocketBase Projektumfeld"
                class="hero-landing-image h-[15rem] w-full rounded-[1.8rem] object-cover max-[760px]:h-[10.5rem] max-[760px]:rounded-[1.5rem] sm:h-[18rem] lg:h-[20rem]"
              />
              <div class="mt-5 max-[760px]:mt-4">
                <div>
                  <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                    RocketBase Ansatz
                  </p>
                  <p class="text-foreground mt-3 text-xl font-semibold leading-tight max-[760px]:mt-2 max-[760px]:text-lg">
                    Kleine, starke Einheit. Direkte Entscheidungen. Architektur mit Blick auf den echten Betrieb.
                  </p>
                  <p class="text-foreground-secondary mt-4 max-w-xl text-base leading-7 max-[760px]:mt-3 max-[760px]:text-sm max-[760px]:leading-6">
                    Keine unnötige Agenturdramaturgie, sondern klare Gespräche über Prozesse,
                    Prioritäten und die sinnvollste technische Lösung.
                  </p>
                </div>
              </div>
            </article>

          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const hero = document.querySelector('[data-hero-root]');
      const copy = document.querySelector('[data-hero-copy]');
      const visual = document.querySelector('[data-hero-visual]');

      if (!hero || !copy || !visual) return;

      let ticking = false;

      const updateHeroProgress = () => {
        const rect = hero.getBoundingClientRect();
        const viewport = window.innerHeight || 1;
        const progress = Math.min(Math.max(-rect.top / viewport, 0), 1);

        copy.style.transform = `translate3d(0, ${progress * 36}px, 0)`;
        copy.style.opacity = `${1 - progress * 0.22}`;

        visual.style.transform = `translate3d(0, ${progress * 68}px, 0) scale(${1 - progress * 0.05})`;
        visual.style.opacity = `${1 - progress * 0.16}`;

        ticking = false;
      };

      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(updateHeroProgress);
      };

      updateHeroProgress();
      document.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
    })();
  </script>

  <ClientLogoStrip
    heading="Erfahrung aus Projekten mit"
    logos={clientLogos}
    variant="subtle"
  />

  <section class="border-border relative overflow-hidden border-b py-24 lg:py-28">
    <div class="bg-brand-300/10 absolute left-0 top-1/3 h-80 w-80 rounded-full blur-3xl" />
    <div class="container relative z-10 grid items-center gap-12 lg:grid-cols-[0.7fr_1.3fr] lg:gap-16">
      <div
        data-reveal="fade-right"
        class="group relative mx-auto w-full max-w-[220px] sm:max-w-[260px] lg:max-w-none"
      >
        <div class="bg-brand-300/15 absolute -inset-3 -z-10 rounded-[2rem] blur-2xl" aria-hidden="true" />
        <div class="overflow-hidden rounded-[1.8rem] border border-border shadow-[0_20px_50px_rgba(34,43,74,0.12)] rotate-[-2.5deg] transition-transform duration-500 group-hover:rotate-0 group-hover:-translate-y-1">
          <Picture
            src={founderImage}
            alt="Marten Prieß, Gründer von RocketBase"
            widths={[220, 320, 420]}
            sizes="(max-width: 640px) 220px, (max-width: 1024px) 260px, 320px"
            formats={['avif', 'webp']}
            class="aspect-[2/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
            loading="lazy"
          />
        </div>
      </div>

      <div data-reveal="fade-left">
        <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Über RocketBase</p>
        <h2 class="font-display text-foreground mt-6 text-3xl font-bold tracking-tight sm:text-4xl">
          Marten Prieß
          <span class="mt-2 block text-brand-500">und ein kleines, festes Entwicklerteam.</span>
        </h2>
        <p class="text-foreground-muted mt-4 text-sm font-medium tracking-wide">
          Diplom-Wirtschaftsinformatiker
        </p>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Keine klassische Softwareagentur, kein Body-Leasing. Kunden arbeiten direkt mit dem
          Gründer zusammen und mit einem eingespielten Team fester Entwicklerinnen und Entwickler
          im Rücken.
        </p>
        <p class="text-foreground-secondary mt-5 hidden text-lg leading-8 sm:block">
          Erfahrung aus Konzernprojekten, Produktentwicklung und Mittelstandsvorhaben fließt so in
          jedes Projekt ein, ohne dass Kommunikation unnötig aufgebläht wird.
        </p>
        <div data-reveal class="mt-8 flex flex-wrap gap-4">
          <Button href={contactLinks.cal} target="_blank">
            Erstgespräch buchen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <Button variant="outline" href={missionUrl}>
            Zur Mission
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="border-border bg-background-secondary relative overflow-hidden border-b py-28 lg:py-36">
    <div class="bg-grid-pattern pointer-events-none absolute inset-0 opacity-25 [mask-image:radial-gradient(circle_at_center,black_24%,transparent_78%)]" />
    <div class="container relative z-10 space-y-14">
      <div class="grid gap-10 xl:grid-cols-[1.05fr_0.95fr] xl:items-end xl:gap-16">
        <div data-reveal="fade-right">
          <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Warum RocketBase</p>
          <h2 class="font-display text-foreground mt-4 max-w-4xl text-3xl font-bold tracking-tight sm:text-4xl">
            Keine verlängerte Werkbank.
            <span class="mt-2 block text-brand-500">Ein Team, das mitdenkt.</span>
          </h2>
          <p class="text-foreground-secondary mt-6 max-w-3xl text-lg leading-8">
            RocketBase wurde nicht gegründet, um einzelne Entwickler in Projekte zu schicken. Der
            Anspruch ist ein anderer: Verantwortung inhaltlich und technisch übernehmen, Prozesse
            verstehen und Lösungen liefern, die langfristig funktionieren.
          </p>
        </div>

        <div data-reveal="fade-left" class="border-brand-300/70 hidden max-w-2xl border-l-2 pl-5 sm:block xl:justify-self-end">
          <p class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
            Kurz gesagt
          </p>
          <p class="text-foreground mt-4 text-2xl font-semibold leading-tight">
            Direkter Zugriff auf jemanden, der Business-Logik und Architektur zusammen denkt.
          </p>
          <p class="text-foreground-secondary mt-4 text-base leading-7">
            Genau deshalb entstehen weniger Missverständnisse, weniger Übergaben und schneller
            belastbare Entscheidungen.
          </p>
        </div>
      </div>

      <div class="why-rocketbase-track relative space-y-6">
        {
          topStrengths.map((strength, index) => (
            <article
              data-reveal="fade-left"

              data-why-card
              class:list={[
                'why-rocketbase-card rounded-[2rem] border p-8 transition-all duration-300',
                index === 0
                  ? 'border-brand-300 bg-card shadow-[0_20px_50px_rgba(34,43,74,0.08)]'
                  : 'border-border bg-background/80',
              ]}
            >
              <div class="grid gap-5 md:grid-cols-[72px_1fr] md:items-start">
                <div class="bg-background text-brand-600 flex h-13 w-13 items-center justify-center rounded-2xl border border-border text-sm font-semibold">
                  0{index + 1}
                </div>
                <div>
                  <h3 class="text-foreground text-2xl font-semibold">{strength.title}</h3>
                  <p class="text-foreground-secondary mt-4 max-w-2xl text-base leading-7">
                    {strength.description}
                  </p>
                </div>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="border-border relative overflow-hidden border-b py-24 lg:py-32">
    <div class="container">
      <a data-reveal="zoom-in" href={workUrl} class="how-we-work group block" data-how-we-work>
        <div class="relative overflow-hidden py-2 transition-all duration-500">
          <div class="bg-brand-300/12 absolute top-12 right-0 h-48 w-48 rounded-full blur-3xl transition-all duration-500 group-hover:bg-brand-300/20" />
          <div class="relative space-y-10">
            <div class="grid gap-10 xl:grid-cols-[0.9fr_1.1fr] xl:items-start xl:gap-12">
              <div>
                <p class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase">Wie wir arbeiten</p>
                <h2 class="font-display text-foreground mt-5 max-w-4xl text-3xl font-bold tracking-tight sm:text-4xl">
                  Weniger Overhead.
                  <span class="mt-2 block text-brand-500">Mehr Geschwindigkeit.</span>
                </h2>
                <p class="text-foreground-secondary mt-6 max-w-3xl text-lg leading-8">
                  Wir zeigen dir konkret, wie moderne Softwareentwicklung heute funktioniert und warum
                  klassische Ansätze Projekte unnötig ausbremsen.
                </p>
              </div>

              <div class="relative mx-auto w-full max-w-2xl xl:pt-2">
                <div class="relative min-h-[22rem] sm:min-h-[27rem]">
                  <div class="how-we-work-after absolute right-0 top-0 z-10 w-[74%] sm:w-[72%]" data-reveal="fade-left">
                    <div class="relative overflow-hidden rounded-[2.4rem] shadow-[0_30px_70px_rgba(34,43,74,0.16)] transition-all duration-500 group-hover:z-20 group-hover:-translate-y-2 group-hover:scale-[1.03] group-hover:shadow-[0_38px_90px_rgba(34,43,74,0.22)]">
                      <img
                        src={toolsAfter.src}
                        alt="Nachher: integriertes System mit klaren Datenflüssen"
                        class="aspect-[4/3.8] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
                      />
                      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-28 bg-gradient-to-t from-black/35 to-transparent" />
                      <div class="absolute right-5 bottom-5 rounded-full bg-white/88 px-3 py-1 text-[11px] font-semibold tracking-[0.22em] uppercase text-brand-700 backdrop-blur">
                        Mit RocketBase
                      </div>
                    </div>
                  </div>

                  <div class="how-we-work-before absolute bottom-0 left-0 z-0 w-[48%] sm:w-[46%]" data-reveal="fade-right">
                    <div class="relative overflow-hidden rounded-[2rem] shadow-[0_20px_45px_rgba(34,43,74,0.08)] transition-all duration-500 group-hover:translate-y-2 group-hover:scale-[0.97] group-hover:opacity-85 group-hover:shadow-[0_16px_30px_rgba(34,43,74,0.08)]">
                      <img
                        src={toolsBefore.src}
                        alt="Vorher: gewachsener Tool-Zoo mit verteilten Systemen"
                        class="aspect-[4/4.5] w-full object-cover grayscale transition-all duration-700 group-hover:scale-[1.03] group-hover:grayscale-[0.15]"
                      />
                      <div class="pointer-events-none absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/35 to-transparent" />
                      <div class="absolute right-4 bottom-4 rounded-full bg-white/80 px-3 py-1 text-[11px] font-semibold tracking-[0.22em] uppercase text-foreground backdrop-blur">
                        Vorher
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <div class="hidden gap-8 border-t border-border/70 pt-8 sm:grid lg:grid-cols-2 lg:gap-12">
              <div data-reveal>
                <p class="text-foreground text-lg font-semibold">Vorher</p>
                <p class="text-foreground-secondary mt-3 max-w-2xl text-base leading-7">
                  Gewachsener Tool-Zoo: Bestellungen in Excel, Kunden im CRM, Versand in Trello,
                  Reports per Mail. Daten leben in Silos, Prozesse laufen manuell, Doppelarbeit
                  überall.
                </p>
              </div>

              <div data-reveal>
                <p class="text-brand-600 text-lg font-semibold">Mit RocketBase</p>
                <p class="text-foreground-secondary mt-3 max-w-2xl text-base leading-7">
                  Eine integrierte Lösung: Ein PIM, ein ERP-Backend, ein Dashboard. Bestellungen,
                  Stammdaten und Auswertungen verzahnt, eine Quelle der Wahrheit.
                </p>
              </div>
            </div>

            <div class="inline-flex items-center gap-3 text-sm font-semibold text-brand-600 transition-transform duration-300 group-hover:translate-x-1">
              Weitere Vergleiche ansehen
              <Icon name="arrow-right" size="sm" />
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <script is:inline>
    (() => {
      const compareSection = document.querySelector('[data-how-we-work]');
      const compareBefore = document.querySelector('.how-we-work-before');
      const compareAfter = document.querySelector('.how-we-work-after');
      const cards = Array.from(document.querySelectorAll('[data-why-card]'));

      if (compareSection && compareBefore && compareAfter) {
        let compareTicking = false;

        const updateCompare = () => {
          const rect = compareSection.getBoundingClientRect();
          const viewport = window.innerHeight || 1;
          const progress = Math.min(Math.max((viewport - rect.top) / (viewport + rect.height), 0), 1);
          const eased = 1 - Math.pow(1 - progress, 2);

          compareAfter.style.transform = `translate3d(0, ${eased * -8}px, 0) scale(${1 + eased * 0.01})`;
          compareBefore.style.transform = `translate3d(0, ${eased * 6}px, 0) scale(${1 - eased * 0.01})`;
          compareAfter.style.opacity = `${0.96 + eased * 0.04}`;
          compareBefore.style.opacity = `${1 - eased * 0.08}`;

          compareTicking = false;
        };

        const onCompareScroll = () => {
          if (compareTicking) return;
          compareTicking = true;
          window.requestAnimationFrame(updateCompare);
        };

        updateCompare();
        document.addEventListener('scroll', onCompareScroll, { passive: true });
        window.addEventListener('resize', onCompareScroll);
      }

      if (cards.length === 0) return;

      let activeIndex = 0;

      const updateActiveCard = () => {
        const trigger = window.innerHeight * 0.42;
        let closestIndex = 0;
        let closestDistance = Number.POSITIVE_INFINITY;

        cards.forEach((card, index) => {
          const rect = card.getBoundingClientRect();
          const center = rect.top + rect.height / 2;
          const distance = Math.abs(center - trigger);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        activeIndex = closestIndex;
        cards.forEach((card, index) => {
          card.classList.toggle('is-active', index === activeIndex);
        });
      };

      const onChange = () => window.requestAnimationFrame(updateActiveCard);

      updateActiveCard();
      document.addEventListener('scroll', onChange, { passive: true });
      window.addEventListener('resize', onChange);
    })();
  </script>

