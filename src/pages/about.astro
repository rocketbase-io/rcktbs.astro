---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import founderImage from '@/assets/rocketbase/founder-marten.jpg';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath } from '@/i18n/index';
import { contactLinks, strengths, teamPrinciples } from '@/data/rocketbase';

const locale = defaultLocale;
const contactUrl = getLocalizedPath('contact', locale);
const servicesUrl = getLocalizedPath('services', locale);

const timeline = [
  {
    title: 'Otto-Gruppe',
    text:
      'Im dualen Studium entstanden Einblicke in Einkauf, E-Commerce, Marketing, Vertrieb, Neukundengewinnung und Support. Dieses breite Fachbereichsverständnis prägt Rocketbase bis heute.',
  },
  {
    title: 'Statista',
    text:
      'Als Softwarearchitekt arbeitete Marten Prieß am Aufbau eines Teams und an der Entwicklung einer Plattform, mit der Redaktions- und Pflegeprozesse deutlich besser unterstützt wurden.',
  },
  {
    title: 'Rocketbase',
    text:
      'Seit 2016 unterstützt Rocketbase Unternehmen dabei, Prozesse zu digitalisieren, Plattformen neu aufzubauen und Standardsoftware dort abzulösen, wo sie Wachstum eher bremst als ermöglicht.',
  },
];

const principles = [
  'Direkte Zusammenarbeit mit Fachbereichen statt reinem Ticket-Abarbeiten',
  'Saubere, dokumentierbare Lösungen auf Basis bewährter Standards',
  'Individuelle Entwicklung nur dort, wo sie wirklichen Mehrwert schafft',
  'Verbindliche Zusammenarbeit in einem kleinen, eingespielten Team',
];

const directCollaborationDefinition =
  'Direkte Zusammenarbeit heißt bei Rocketbase: Marten Prieß ist nicht nur Gesicht der Website, sondern in Analyse, Konzeption und technischen Leitentscheidungen real eingebunden.';
---

<PageLayout
  title="Über Rocketbase"
  description="Erfahren Sie, warum Rocketbase fachliche Prozessperspektive mit technischer Delivery verbindet."
  lang={locale}
  routeId="about"
>
  <section class="border-b border-border bg-background-secondary py-24">
    <div class="container grid gap-14 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="overflow-hidden rounded-[2.25rem] border border-border shadow-lg">
        <img src={founderImage.src} alt="Marten Prieß, Gründer von Rocketbase" class="h-full w-full object-cover" />
      </div>

      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Über Rocketbase</p>
        <h1 class="mt-4 font-display text-5xl font-bold tracking-tight text-foreground sm:text-6xl">
          Direkt begleitet, prozessnah und gebaut für nachhaltige Entscheidungen.
        </h1>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Rocketbase ist keine klassische Softwareagentur und kein Body-Leasing-Modell. Kunden
          arbeiten direkt mit Marten Prieß zusammen, der Prozesse versteht, Anforderungen sauber
          übersetzt und Verantwortung in der Umsetzung übernimmt.
        </p>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Das Ergebnis ist eine eng verzahnte Zusammenarbeit zwischen Beratung, Konzeption und
          Delivery. Weniger Reibung, klarere Entscheidungen und Lösungen, die im Alltag wirklich
          tragfähig sind.
        </p>
        <div class="mt-8 rounded-[1.75rem] border border-brand-200 bg-brand-50 p-6 shadow-sm dark:border-brand-800 dark:bg-brand-900/20">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-700 dark:text-brand-200">So arbeiten wir</p>
          <p class="mt-3 text-base leading-7 text-foreground-secondary">{directCollaborationDefinition}</p>
        </div>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href={servicesUrl}>
            Leistungen ansehen
            <Icon name="arrow-right" size="sm" />
          </Button>
          <Button variant="outline" href={contactUrl}>
            Projekt besprechen
          </Button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-28">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Werdegang</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Die Gründerstory erklärt den Blick auf Fachlichkeit und Technik.
        </h2>
      </div>

      <div class="relative mt-14 max-w-5xl">
        <div class="absolute bottom-0 left-6 top-0 hidden w-px bg-border md:block"></div>
        <div class="grid gap-6">
          {timeline.map((item, index) => (
            <article class="grid gap-5 rounded-[1.75rem] border border-border bg-card p-7 shadow-sm md:grid-cols-[64px_1fr] md:items-start">
              <div class="relative flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-50 text-sm font-semibold text-brand-700 dark:bg-brand-900/30 dark:text-brand-100">
                0{index + 1}
              </div>
              <div>
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">{item.title}</p>
                <p class="mt-4 text-base leading-7 text-foreground-secondary">{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-background-secondary py-28">
    <div class="container grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Wofür Rocketbase steht</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Technologie ist Mittel zum Zweck. <span class="text-brand-500">Der Prozess bleibt der Maßstab.</span>
        </h2>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Rocketbase ist branchenoffen, aber nicht beliebig. Die eigentliche Stärke liegt darin,
          Prozesse strukturiert zu verstehen, unnötige Tätigkeiten zu reduzieren und digitale
          Lösungen so auszuwählen, dass sie echten Fortschritt erzeugen.
        </p>
        <div class="mt-8 rounded-[1.75rem] bg-surface-invert p-7 text-on-invert shadow-xl">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-300">Positionierung</p>
          <p class="mt-4 text-2xl font-semibold">Keine Branchen-Schablone. Stärke in Prozess- und Umsetzungsintelligenz.</p>
        </div>
      </div>

      <div class="grid gap-5">
        {strengths.map((strength, index) => (
          <article
            class:list={[
              'rounded-[1.75rem] border p-6 shadow-sm',
              index === 1 ? 'border-brand-200 bg-brand-50 dark:border-brand-800 dark:bg-brand-900/20' : 'border-border bg-card',
            ]}
          >
            <div class="flex items-start justify-between gap-4">
              <h3 class="text-xl font-semibold text-foreground">{strength.title}</h3>
              <span class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">0{index + 1}</span>
            </div>
            <p class="mt-3 text-base leading-7 text-foreground-secondary">{strength.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-28">
    <div class="container grid gap-12 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="rounded-[2rem] border border-border bg-card p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Arbeitsmodell</p>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-foreground">
          Eingespieltes Remote-Team statt Agenturkulisse.
        </h2>
        <ul class="mt-8 space-y-4 text-base text-foreground-secondary">
          {teamPrinciples.map((principle) => (
            <li class="flex gap-3">
              <Icon name="check-circle" size="sm" class="mt-1 shrink-0 text-brand-500" />
              <span>{principle}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-[2rem] border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-8 shadow-sm dark:border-brand-800 dark:from-brand-900/20 dark:to-background">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-700 dark:text-brand-200">Verlässlichkeit</p>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-foreground">
          Lösungen sollen auch im Worst Case noch übergebbar sein.
        </h2>
        <ul class="mt-8 space-y-4 text-base text-foreground-secondary">
          {principles.map((principle) => (
            <li class="flex gap-3">
              <Icon name="shield" size="sm" class="mt-1 shrink-0 text-brand-500" />
              <span>{principle}</span>
            </li>
          ))}
        </ul>
        <p class="mt-8 text-base leading-7 text-foreground-secondary">
          Zukunftssicherheit bedeutet für Rocketbase nicht nur sauberen Code, sondern auch
          nachvollziehbare Architektur, übergebbare Systeme und einen bewussten Umgang mit
          Abhängigkeiten.
        </p>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-24">
    <div class="container rounded-[2.25rem] border border-border bg-card p-10 shadow-sm">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Zusammenarbeit</p>
          <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground">
            Wenn Sie einen Partner suchen, der Prozesse ernst nimmt, sollten wir sprechen.
          </h2>
          <p class="mt-6 text-lg leading-8 text-foreground-secondary">
            Rocketbase passt zu Unternehmen, die nicht möglichst viele Agenturfolien wollen,
            sondern Klarheit, belastbare Architektur und pragmatische Umsetzung.
          </p>
        </div>
        <div class="space-y-4 rounded-[1.5rem] bg-background-secondary p-6">
          <Button href={contactLinks.cal} target="_blank">
            Erstgespräch buchen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <p class="text-sm text-foreground-muted">Oder direkt per Mail an {contactLinks.email}</p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
