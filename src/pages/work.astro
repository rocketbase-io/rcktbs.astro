---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { defaultLocale } from '@/i18n/config';
import { contactLinks } from '@/data/rocketbase';

const locale = defaultLocale;

import teamBefore from '@/assets/work/team-before.png';
import teamAfter from '@/assets/work/team-after.png';
import serverBefore from '@/assets/work/server-before.png';
import serverAfter from '@/assets/work/server-after.png';
import toolsBefore from '@/assets/work/tools-before.png';
import toolsAfter from '@/assets/work/tools-after.png';
import kiBefore from '@/assets/work/ki-before.png';
import kiAfter from '@/assets/work/ki-after.png';
import { cn } from '@/lib/cn.ts';

const sections = [
  {
    title: "Vom großen Standardteam zum schlanken Expertenteam",
    subline:
      "Weniger Abstimmung, mehr Fokus. Moderne Softwareentwicklung braucht keine großen Teams, sondern die richtigen Experten.",
    before: {
      title: "Großes Standardteam",
      text: "Viele Rollen, lange Abstimmungen und häufige Rework-Schleifen führen zu Verzögerungen und unnötigem Overhead.",
      image: teamBefore,
    },
    after: {
      title: "Schlankes Expertenteam",
      text: "Ein kleines Team aus erfahrenen Spezialisten arbeitet direkt zusammen und liefert schneller Ergebnisse – ohne Reibungsverluste.",
      image: teamAfter,
    },
  },
  {
    title: "Vom eigenen Server zur Cloud",
    subline:
      "Weg von Infrastrukturproblemen – hin zu skalierbarer, wartungsfreier Software.",
    before: {
      title: "Server im Büro",
      text: "Hoher Wartungsaufwand, Sicherheitsrisiken und eingeschränkter Zugriff bremsen Unternehmen aus.",
      image: serverBefore,
    },
    after: {
      title: "Cloud aus Deutschland",
      text: "Automatische Updates, Backups und Zugriff von überall sorgen für maximale Flexibilität und Sicherheit.",
      image: serverAfter,
    },
  },
  {
    title: "Von Tool-Chaos zur integrierten Lösung",
    subline:
      "Ein System statt vieler Einzellösungen – für echte Transparenz und Effizienz.",
    before: {
      title: "Viele Einzeltools",
      text: "Daten sind verteilt, Prozesse manuell und fehleranfällig – Überblick geht verloren.",
      image: toolsBefore,
    },
    after: {
      title: "Eine integrierte Lösung",
      text: "Alle Daten und Prozesse in einem System – für fundierte Entscheidungen in Echtzeit.",
      image: toolsAfter,
    },
  },
  {
    title: "Von klassischer Entwicklung zu KI-gestützter Umsetzung",
    subline:
      "Moderne Entwicklung nutzt Tools und KI, um schneller und effizienter zu liefern.",
    before: {
      title: "Alles selbst coden",
      text: "Viel manuelle Arbeit, langsame Entwicklung und unnötige Wiederholung bereits gelöster Probleme.",
      image: kiBefore,
    },
    after: {
      title: "KI + Open Source",
      text: "Mit KI-Unterstützung und bewährten Open-Source-Lösungen entstehen Features deutlich schneller und effizienter.",
      image: kiAfter,
    },
  },
];


---

<PageLayout
  title="Wie wir arbeiten"
  description="Weniger Overhead, mehr Fokus. Wir ersetzen komplexe Prozesse durch klare, effiziente Lösungen."
  lang={locale}
  routeId="work"
>
  <section class="border-b border-border bg-background-secondary py-24 text-center">
    <p data-aos="fade-down" class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Wie wir arbeiten</p>
    <h1 data-aos="fade-down" class="mt-4 font-display text-5xl font-bold tracking-tight text-foreground sm:text-6xl">
      So entwickeln wir Software heute
    </h1>

    <p data-aos="fade-down" class="mt-6 text-lg leading-8 text-foreground-secondary max-w-2xl mx-auto">
      Weniger Overhead, mehr Fokus. Wir ersetzen komplexe Prozesse durch klare, effiziente Lösungen.
    </p>
  </section>

  <div class="space-y-32 py-28">

    {sections.map((section, index) => (
      <section class="max-w-4xl mx-auto px-6 rounded-[1.9rem] border border-border bg-card p-7 shadow-sm hover:bg-background-secondary hover:shadow hover:scale-103" data-aos={index % 2 === 0 ? "fade-right" : "fade-left"} >

        <div data-aos={index % 2 === 0 ? "fade-right" : "fade-left"} class="text-foreground max-w-3xl mx-auto text-center mb-16">
          <h3 class="text-2xl font-semibold">{section.title}</h3>
          <p class="ext-foreground-secondary mt-6 text-lg leading-8">
            {section.subline}
          </p>
        </div>

        <div
          data-aos="zoom-in"
          class={cn(
            'flex flex-col gap-12 items-center',
            index % 2 === 0 && 'md:flex-row',
            index % 2 !== 0 && 'md:flex-row-reverse'
          )}>
          <!-- TEXT -->
          <div class="basis-1 md:basis-1/2">
            <div class="mb-8">
              <h3 class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                Vorher
              </h3>
              <p class="text-foreground-secondary mt-3 text-base leading-7">
                {section.before.text}
              </p>
            </div>

            <div>
              <h3 class="text-brand-600 text-xs font-semibold tracking-[0.22em] uppercase">
                Nachher
              </h3>
              <p class="text-foreground-secondary mt-3 text-base leading-7">
                {section.after.text}
              </p>
            </div>
          </div>

          <!-- VISUAL -->
          <div  data-aos="zoom-in" class="relative ml-5 mt-5 flex items-center justify-center h-[300px] basis-1 md:basis-1/2">

            <img
              src={section.before.image.src}
              alt={section.before.title}
              class="absolute -left-25 md:-left-5 top-1/6 md:top-1/4 -translate-y-1/2 w-42 opacity-50 grayscale rounded-xl hover:z-20 hover:opacity-100 hover:scale-150"
            />

            <img
              src={section.after.image.src}
              alt={section.after.title}
              class="relative z-10 w-64 rounded-2xl shadow-xl float hover:scale-125"
            />

          </div>
        </div>
      </section>
    ))}

  </div>

  <section class=" bg-background-secondary py-24">
    <div class="max-w-4xl mx-auto px-6 text-center">

      <h2 data-aos="fade-down"  class="text-3xl font-bold">
        Warum <span class="text-brand-500">moderne</span> Softwareentwicklung entscheidend ist
      </h2>

      <p data-aos="flip-left" class="mt-6 text-foreground-secondary text-lg">
        Unternehmen, die weiterhin auf klassische Prozesse setzen, verlieren wertvolle Zeit und Ressourcen.
        Durch schlanke Teams, Cloud-Infrastruktur und moderne Entwicklungsmethoden können Projekte schneller umgesetzt und besser skaliert werden.
      </p>

      <p data-aos="flip-left" class="mt-4 text-foreground-secondary">
        Unser Ansatz kombiniert technologische Exzellenz mit effizienten Prozessen – für nachhaltigen Erfolg in der digitalen Welt.
      </p>

    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-24">
    <div data-aos="zoom-in" class="max-w-4xl mx-auto rounded-[2.25rem] border border-border bg-card p-10 shadow-sm">
      <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Zusammenarbeit</p>
          <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground">
            Bereit für eine effizientere Softwareentwicklung?
          </h2>
          <p class="mt-6 text-lg leading-8 text-foreground-secondary">
            Lassen Sie uns gemeinsam herausfinden, wie wir Ihre Prozesse vereinfachen können.
          </p>
        </div>
        <div class="space-y-4 rounded-[1.5rem] bg-background-secondary p-6">
          <Button href={contactLinks.cal} target="_blank">
            Erstgespräch buchen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <p class="text-sm text-foreground-muted">Oder direkt per Mail an {contactLinks.email}</p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
