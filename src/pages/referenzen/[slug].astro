---
import { Picture, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import bonprixCaseImage from '@/assets/references/teaser-bonprix.jpeg';
import statistaCaseImage from '@/assets/references/teaser-statista.jpeg';
import fkcCaseImage from '@/assets/references/teaser-fkc.jpeg';
import schlossereiCaseImage from '@/assets/references/teaser-schlosserei.jpeg';
import statistaCanvaCaseImage from '@/assets/references/teaser-statista-canva.jpeg';
import stageCmlCaseImage from '@/assets/references/teaser-stage-cml.jpeg';
import samVorteilsguruCaseImage from '@/assets/references/teaser-sam-vorteilsguru.jpeg';
import mavoxCaseImage from '@/assets/references/teaser-mavox-winterdienst.jpeg';
import bonprixCollectionCaseImage from '@/assets/references/teaser-bonprix-collection-planning.jpeg';
import { defaultLocale } from '@/i18n/config';
import { cases, additionalCases, contactLinks } from '@/data/rocketbase';

const screenshotModules = import.meta.glob<{ default: ImageMetadata }>(
  '@/assets/references/*.{png,jpeg,webp}',
  { eager: true },
);
const screenshotImages: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(screenshotModules)
    .filter(([path]) => !path.includes('/teaser-'))
    .map(([path, mod]) => {
      const key = path.split('/').pop()!.replace(/\.(png|jpe?g|webp)$/i, '');
      return [key, mod.default];
    }),
);

const allCases = [...cases, ...additionalCases];

export function getStaticPaths() {
  const all = [...cases, ...additionalCases];
  return all.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const locale = defaultLocale;

const caseImages = {
  bonprix: bonprixCaseImage,
  statista: statistaCaseImage,
  'fkc-consulting': fkcCaseImage,
  'metall-pro': schlossereiCaseImage,
  'statista-canva': statistaCanvaCaseImage,
  'stage-cml': stageCmlCaseImage,
  'sam-vorteilsguru': samVorteilsguruCaseImage,
  'mavox-winterdienst': mavoxCaseImage,
  'bonprix-collection-planning': bonprixCollectionCaseImage,
} as const;

const hasImage = item.slug in caseImages;
const otherCases = allCases.filter((entry) => entry.slug !== item.slug).slice(0, 2);

const contextBlocks = [
  { label: 'Ausgangslage', text: item.challenge },
  { label: 'Beitrag von Rocketbase', text: item.approach },
  { label: 'Warum das relevant war', text: item.impact },
];

const resolvedScreenshots = await Promise.all(
  (item.screenshots ?? []).map(async (shot) => {
    const image = screenshotImages[shot.key];
    if (!image) return null;
    const large = await getImage({
      src: image,
      width: 1920,
      format: 'webp',
      quality: 85,
    });
    return { key: shot.key, alt: shot.alt, image, largeSrc: large.src };
  }),
).then((arr) => arr.filter((s): s is NonNullable<typeof s> => s !== null));
---

<PageLayout
  title={`${item.client} | Referenz`}
  description={item.description}
  lang={locale}
>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border bg-background-secondary py-24 lg:py-32">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_60%_-10%,rgba(var(--color-brand-200)/0.18),transparent)]"></div>
    <div class="pointer-events-none absolute -right-24 -top-24 h-96 w-96 rounded-full bg-brand-300/20 blur-3xl"></div>

    <div class="container relative grid gap-14 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div class="max-w-2xl" data-aos="fade-right">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Referenz · {item.client}</p>
        <h1 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
          {item.title}
        </h1>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">{item.kicker}</p>

        {item.highlights && item.highlights.length > 0 && (
          <ul class="mt-8 flex flex-wrap gap-2">
            {item.highlights.map((h) => (
              <li class="flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-3.5 py-1.5 text-xs font-medium text-brand-700 dark:border-brand-800 dark:bg-brand-950/40 dark:text-brand-400">
                <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-brand-500"></span>
                {h}
              </li>
            ))}
          </ul>
        )}
      </div>

      {hasImage ? (
        <div data-aos="fade-left" class="overflow-hidden rounded-[2rem] shadow-2xl shadow-brand-900/10">
          <Picture
            src={caseImages[item.slug as keyof typeof caseImages]}
            alt={item.title}
            widths={[480, 720, 960, 1280]}
            sizes="(max-width: 1024px) 100vw, 560px"
            formats={['avif', 'webp']}
            class="h-80 w-full object-cover"
          />
        </div>
      ) : (
        <div data-aos="fade-left" class="flex h-80 flex-col justify-between rounded-[2rem] border border-border bg-gradient-to-br from-background to-background-secondary p-8 shadow-xl shadow-brand-900/5">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">{item.client}</p>
          <div>
            <p class="font-display text-5xl font-bold tracking-tight text-foreground">{item.client.slice(0, 3).toUpperCase()}</p>
            <p class="mt-4 max-w-sm text-base leading-7 text-foreground-secondary">{item.description}</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Projektkontext — centered header + 3 cards -->
  <section class="relative overflow-hidden py-24 lg:py-32">
    <div class="container max-w-6xl">
      <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
        <div class="mx-auto flex max-w-md items-center gap-4">
          <span class="h-px flex-1 bg-border"></span>
          <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-brand-300 bg-card font-mono text-sm font-bold text-brand-600">
            01
          </span>
          <span class="text-xs font-semibold uppercase tracking-[0.22em] text-foreground-muted">Projektkontext</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>
        <h2 class="mt-8 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Worum es in diesem Projekt wirklich ging.
        </h2>
      </header>

      <div class="mt-16 grid gap-5 md:grid-cols-3">
        {contextBlocks.map((block, i) => (
          <article
            class="group rounded-2xl border border-border bg-card p-7 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-300 hover:shadow-lg"
            data-aos="fade-up"
            data-aos-delay={i * 80}
          >
            <span class="font-mono text-xs font-semibold tracking-[0.22em] text-brand-500">
              {String(i + 1).padStart(2, '0')}
            </span>
            <p class="mt-3 text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">{block.label}</p>
            <p class="mt-4 text-sm leading-7 text-foreground-secondary">{block.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Prozess & Ergebnisse — two-column content split -->
  <section class="relative overflow-hidden border-y border-border bg-background-secondary py-24 lg:py-32">
    <div class="pointer-events-none absolute -left-24 top-1/3 h-96 w-96 rounded-full bg-brand-300/10 blur-3xl"></div>
    <div class="container relative max-w-6xl">
      <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
        <div class="mx-auto flex max-w-md items-center gap-4">
          <span class="h-px flex-1 bg-border"></span>
          <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-brand-300 bg-card font-mono text-sm font-bold text-brand-600">
            02
          </span>
          <span class="text-xs font-semibold uppercase tracking-[0.22em] text-foreground-muted">Optimierter Prozess</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>
        <h2 class="mt-8 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Wo Rocketbase konkret Verbesserung geschaffen hat.
        </h2>
      </header>

      <div class="mt-16 grid gap-12 md:grid-cols-[1fr_1.1fr] md:items-start">
        <div data-aos="fade-right" class="rounded-2xl border border-border bg-card p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Prozess im Fokus</p>
          <p class="mt-4 text-base leading-8 text-foreground-secondary">{item.processFocus}</p>
          <div class="mt-6 border-t border-border pt-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-foreground-muted">Erbrachte Leistungen</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {item.services.map((service) => (
                <span class="inline-flex items-center gap-1.5 rounded-full border border-border bg-background-secondary px-3 py-1 text-xs font-medium text-foreground-secondary">
                  <span class="h-1.5 w-1.5 shrink-0 rounded-full bg-brand-500"></span>
                  {service}
                </span>
              ))}
            </div>
          </div>
        </div>

        <div data-aos="fade-left" data-aos-delay="80">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Wirkung im Alltag</p>
          <ul class="mt-4 space-y-3">
            {item.outcomes.map((outcome, i) => (
              <li
                class="flex items-start gap-3 rounded-xl border border-border bg-card px-4 py-3.5 text-sm leading-7 text-foreground-secondary transition-all duration-200 hover:border-brand-200 hover:bg-background-secondary"
                data-aos="fade-up"
                data-aos-delay={80 + i * 60}
              >
                <Icon name="check-circle" size="sm" class="mt-0.5 shrink-0 text-brand-500" />
                {outcome}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Screenshots -->
  {resolvedScreenshots.length > 0 && (
    <section class="py-24 lg:py-32">
      <div class="container max-w-6xl">
        <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
          <div class="mx-auto flex max-w-md items-center gap-4">
            <span class="h-px flex-1 bg-border"></span>
            <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-brand-300 bg-card font-mono text-sm font-bold text-brand-600">
              03
            </span>
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-foreground-muted">Einblicke</span>
            <span class="h-px flex-1 bg-border"></span>
          </div>
          <h2 class="mt-8 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
            Das System in der Praxis
          </h2>
        </header>

        <div
          class="screenshot-gallery mt-16 flex flex-wrap items-start justify-center gap-x-6 gap-y-12 sm:gap-x-8 sm:gap-y-14 md:gap-x-10"
          data-lightbox-gallery
        >
          {resolvedScreenshots.map((shot, i) => {
            const count = resolvedScreenshots.length;
            // Alternate tilt + subtle vertical offset, polaroid style
            const rotations = ['-rotate-2', 'rotate-1', '-rotate-1', 'rotate-2', '-rotate-1'];
            const offsets = ['md:mt-0', 'md:mt-10', 'md:mt-4', 'md:mt-12', 'md:mt-6'];
            // Sizing: smaller tiles, varied widths for a curated/editorial feel
            const widths =
              count === 2
                ? ['w-full sm:w-[46%]', 'w-full sm:w-[46%]']
                : count === 3
                  ? [
                      'w-full sm:w-[44%] md:w-[38%]',
                      'w-full sm:w-[44%] md:w-[30%]',
                      'w-full sm:w-[44%] md:w-[32%]',
                    ]
                  : count === 4
                    ? [
                        'w-full sm:w-[44%] md:w-[30%]',
                        'w-full sm:w-[44%] md:w-[24%]',
                        'w-full sm:w-[44%] md:w-[26%]',
                        'w-full sm:w-[44%] md:w-[28%]',
                      ]
                    : ['w-full sm:w-[44%] md:w-[28%]'];

            const rotation = rotations[i % rotations.length];
            const offset = offsets[i % offsets.length];
            const width = widths[i] || widths[widths.length - 1];

            return (
              <figure
                class:list={[
                  'screenshot-tile group relative',
                  width,
                  offset,
                ]}
                data-aos="fade-up"
                data-aos-delay={i * 80}
              >
                <button
                  type="button"
                  class:list={[
                    'relative block w-full cursor-zoom-in overflow-hidden rounded-xl',
                    'border border-border bg-card p-2 shadow-lg',
                    'transition-all duration-500 ease-out',
                    'hover:-translate-y-2 hover:shadow-2xl hover:shadow-brand-900/20',
                    'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 focus-visible:ring-offset-background',
                    rotation,
                    'hover:rotate-0',
                  ]}
                  data-lightbox-trigger
                  data-src={shot.largeSrc}
                  data-alt={shot.alt}
                  data-index={i}
                  aria-label={`${shot.alt} vergrößern`}
                >
                  <span
                    aria-hidden="true"
                    class="absolute left-3 top-3 z-10 font-mono text-[10px] font-bold tracking-[0.22em] text-foreground-muted/70"
                  >
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="relative block overflow-hidden rounded-md bg-background-secondary">
                    <Picture
                      src={shot.image}
                      alt={shot.alt}
                      widths={[320, 480, 640, 800]}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 44vw, 28vw"
                      formats={['avif', 'webp']}
                      class="aspect-[16/10] w-full object-cover object-top"
                      loading="lazy"
                    />
                    <span
                      aria-hidden="true"
                      class="pointer-events-none absolute inset-0 bg-gradient-to-br from-brand-500/0 via-brand-500/0 to-brand-500/30 opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                    ></span>
                    <span
                      aria-hidden="true"
                      class="pointer-events-none absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-foreground/70 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"
                    ></span>
                    <span
                      aria-hidden="true"
                      class="pointer-events-none absolute bottom-3 right-3 flex items-center gap-1.5 rounded-full bg-background/95 px-3 py-1.5 text-xs font-semibold text-brand-600 shadow-md translate-y-2 opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100"
                    >
                      Vergrößern
                      <Icon name="arrow-up-right" size="xs" />
                    </span>
                  </span>
                </button>
                <figcaption
                  class:list={[
                    'mt-3 px-1 text-left text-xs font-medium text-foreground-secondary transition-all duration-500',
                    'group-hover:text-foreground',
                    rotation,
                    'group-hover:rotate-0',
                  ]}
                >
                  {shot.alt}
                </figcaption>
              </figure>
            );
          })}
        </div>
      </div>

      <!-- Lightbox -->
      <div
        id="screenshot-lightbox"
        class="fixed inset-0 z-[60] hidden items-center justify-center"
        role="dialog"
        aria-modal="true"
        aria-label="Screenshot-Ansicht"
        data-lightbox
      >
        <div
          class="absolute inset-0 bg-foreground/85 opacity-0 backdrop-blur-md transition-opacity duration-300"
          data-lightbox-backdrop
          aria-hidden="true"
        ></div>

        <button
          type="button"
          class="absolute right-4 top-4 z-10 flex h-11 w-11 items-center justify-center rounded-full bg-background/90 text-foreground shadow-lg backdrop-blur-sm transition-transform hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500"
          data-lightbox-close
          aria-label="Schließen"
        >
          <Icon name="x" size="sm" />
        </button>

        <button
          type="button"
          class="absolute left-4 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-background/90 text-foreground shadow-lg backdrop-blur-sm transition-transform hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 sm:h-12 sm:w-12"
          data-lightbox-prev
          aria-label="Vorheriges Bild"
        >
          <Icon name="arrow-left" size="sm" />
        </button>

        <button
          type="button"
          class="absolute right-4 top-1/2 z-10 flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-full bg-background/90 text-foreground shadow-lg backdrop-blur-sm transition-transform hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 sm:h-12 sm:w-12"
          data-lightbox-next
          aria-label="Nächstes Bild"
        >
          <Icon name="arrow-right" size="sm" />
        </button>

        <figure
          class="relative z-0 mx-4 flex max-h-[90vh] w-full max-w-6xl scale-95 flex-col items-center opacity-0 transition-all duration-300"
          data-lightbox-panel
        >
          <img
            data-lightbox-image
            src=""
            alt=""
            class="max-h-[80vh] w-auto max-w-full rounded-xl border border-border/50 bg-card object-contain shadow-2xl"
          />
          <figcaption
            class="mt-4 flex items-center gap-3 rounded-full bg-background/90 px-4 py-2 text-sm text-foreground-secondary shadow-lg backdrop-blur-sm"
          >
            <span data-lightbox-caption></span>
            <span class="h-4 w-px bg-border"></span>
            <span class="font-mono text-xs text-foreground-muted" data-lightbox-counter></span>
          </figcaption>
        </figure>
      </div>

      <script>
        function initLightbox() {
          const lightbox = document.getElementById('screenshot-lightbox');
          if (!lightbox || lightbox.dataset.init) return;
          lightbox.dataset.init = 'true';

          const gallery = document.querySelector<HTMLElement>('[data-lightbox-gallery]');
          if (!gallery) return;

          const triggers = Array.from(
            gallery.querySelectorAll<HTMLButtonElement>('[data-lightbox-trigger]')
          );
          const backdrop = lightbox.querySelector<HTMLElement>('[data-lightbox-backdrop]');
          const panel = lightbox.querySelector<HTMLElement>('[data-lightbox-panel]');
          const image = lightbox.querySelector<HTMLImageElement>('[data-lightbox-image]');
          const caption = lightbox.querySelector<HTMLElement>('[data-lightbox-caption]');
          const counter = lightbox.querySelector<HTMLElement>('[data-lightbox-counter]');
          const closeBtn = lightbox.querySelector<HTMLElement>('[data-lightbox-close]');
          const prevBtn = lightbox.querySelector<HTMLElement>('[data-lightbox-prev]');
          const nextBtn = lightbox.querySelector<HTMLElement>('[data-lightbox-next]');

          let currentIndex = 0;
          let lastFocused: HTMLElement | null = null;

          function render(index: number) {
            const trigger = triggers[index];
            if (!trigger || !image || !caption || !counter) return;
            currentIndex = index;
            image.src = trigger.dataset.src || '';
            image.alt = trigger.dataset.alt || '';
            caption.textContent = trigger.dataset.alt || '';
            counter.textContent = `${index + 1} / ${triggers.length}`;
          }

          function open(index: number) {
            lastFocused = document.activeElement as HTMLElement;
            render(index);
            lightbox!.classList.remove('hidden');
            lightbox!.classList.add('flex');
            requestAnimationFrame(() => {
              backdrop?.classList.add('opacity-100');
              panel?.classList.remove('scale-95', 'opacity-0');
              panel?.classList.add('scale-100', 'opacity-100');
            });
            document.body.classList.add('overflow-hidden');
            closeBtn?.focus();
          }

          function close() {
            backdrop?.classList.remove('opacity-100');
            panel?.classList.add('scale-95', 'opacity-0');
            panel?.classList.remove('scale-100', 'opacity-100');
            setTimeout(() => {
              lightbox!.classList.add('hidden');
              lightbox!.classList.remove('flex');
              document.body.classList.remove('overflow-hidden');
              lastFocused?.focus();
            }, 280);
          }

          function next() {
            render((currentIndex + 1) % triggers.length);
          }

          function prev() {
            render((currentIndex - 1 + triggers.length) % triggers.length);
          }

          triggers.forEach((trigger, i) => {
            trigger.addEventListener('click', () => open(i));
          });
          closeBtn?.addEventListener('click', close);
          backdrop?.addEventListener('click', close);
          nextBtn?.addEventListener('click', next);
          prevBtn?.addEventListener('click', prev);

          document.addEventListener('keydown', (e) => {
            if (lightbox!.classList.contains('hidden')) return;
            if (e.key === 'Escape') close();
            else if (e.key === 'ArrowRight') next();
            else if (e.key === 'ArrowLeft') prev();
          });

          // Swipe support
          let touchStartX = 0;
          panel?.addEventListener('touchstart', (e) => {
            touchStartX = e.touches[0].clientX;
          });
          panel?.addEventListener('touchend', (e) => {
            const delta = e.changedTouches[0].clientX - touchStartX;
            if (Math.abs(delta) > 50) {
              if (delta < 0) next();
              else prev();
            }
          });
        }

        initLightbox();
        document.addEventListener('astro:page-load', initLightbox);
      </script>
    </section>
  )}

  <!-- Weitere Referenzen -->
  <section class="border-t border-border bg-background-secondary py-24 lg:py-32">
    <div class="container max-w-6xl">
      <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
        <div class="mx-auto flex max-w-md items-center gap-4">
          <span class="h-px flex-1 bg-border"></span>
          <span class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-brand-300 bg-card font-mono text-sm font-bold text-brand-600">
            {item.screenshots && item.screenshots.length > 0 ? '04' : '03'}
          </span>
          <span class="text-xs font-semibold uppercase tracking-[0.22em] text-foreground-muted">Mehr Einblicke</span>
          <span class="h-px flex-1 bg-border"></span>
        </div>
        <h2 class="mt-8 font-display text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Weitere Referenzen
        </h2>
      </header>

      <div class="mt-12 grid gap-6 lg:grid-cols-2">
        {otherCases.map((entry, i) => (
          <a
            href={`/referenzen/${entry.slug}`}
            class="group relative overflow-hidden rounded-2xl border border-border bg-card p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-brand-300 hover:shadow-lg"
            data-aos="fade-up"
            data-aos-delay={i * 80}
          >
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">{entry.client}</p>
            <h3 class="mt-3 text-xl font-semibold text-foreground transition-colors group-hover:text-brand-600">
              {entry.title}
            </h3>
            <p class="mt-3 text-sm leading-7 text-foreground-secondary">{entry.kicker}</p>
            <div class="mt-6 flex items-center gap-1.5 text-sm font-semibold text-brand-600">
              Referenz öffnen
              <Icon name="arrow-right" size="sm" class="transition-transform duration-200 group-hover:translate-x-1" />
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-border py-24">
