---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import bonprixCaseImage from '@/assets/rocketbase/case-bonprix.png';
import statistaCaseImage from '@/assets/rocketbase/case-statista.png';
import { defaultLocale } from '@/i18n/config';
import { cases, contactLinks } from '@/data/rocketbase';

export function getStaticPaths() {
  return cases.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const locale = defaultLocale;

const caseImages = {
  bonprix: bonprixCaseImage,
  statista: statistaCaseImage,
} as const;

const hasImage = item.slug in caseImages;
const otherCases = cases.filter((entry) => entry.slug !== item.slug).slice(0, 2);
---

<PageLayout
  title={`${item.client} | Referenz`}
  description={item.description}
  lang={locale}
>
  <section class="border-b border-border bg-background-secondary py-24">
    <div class="container grid gap-12 lg:grid-cols-[1fr_0.95fr] lg:items-end">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Referenz</p>
        <h1 class="mt-4 font-display text-5xl font-bold tracking-tight text-foreground sm:text-6xl">
          {item.title}
        </h1>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">{item.kicker}</p>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">{item.description}</p>
      </div>

      {hasImage ? (
        <div class="overflow-hidden rounded-[2rem]">
          <img
            src={caseImages[item.slug as keyof typeof caseImages].src}
            alt={item.title}
            class="h-80 w-full object-cover"
          />
        </div>
      ) : (
        <div class="flex h-80 flex-col justify-between rounded-[2rem] bg-[linear-gradient(160deg,rgba(243,245,249,0.96),rgba(229,234,242,0.92))] p-8 dark:bg-[linear-gradient(160deg,rgba(36,43,57,0.92),rgba(26,31,42,0.9))]">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">{item.client}</p>
          <div>
            <p class="font-display text-5xl font-bold tracking-tight text-foreground">FKC</p>
            <p class="mt-4 max-w-sm text-base leading-7 text-foreground-secondary">
              Migration aus Standardsoftware in eine Lösung, die reale Prozesse besser abbildet.
            </p>
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="py-28">
    <div class="container grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Projektkontext</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Worum es in diesem Projekt wirklich ging.
        </h2>
      </div>

      <div class="space-y-8">
        <article class="border-t border-border pt-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Ausgangslage</p>
          <p class="mt-4 text-base leading-8 text-foreground-secondary">{item.challenge}</p>
        </article>

        <article class="border-t border-border pt-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Beitrag von Rocketbase</p>
          <p class="mt-4 text-base leading-8 text-foreground-secondary">{item.approach}</p>
        </article>

        <article class="border-t border-border pt-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Warum das relevant war</p>
          <p class="mt-4 text-base leading-8 text-foreground-secondary">{item.impact}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-background-secondary py-24">
    <div class="container grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Optimierter Prozess</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Wo Rocketbase konkret Verbesserung geschaffen hat.
        </h2>
      </div>

      <div class="space-y-8">
        <article class="border-t border-border pt-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Prozess im Fokus</p>
          <p class="mt-4 text-base leading-8 text-foreground-secondary">{item.processFocus}</p>
        </article>

        <article class="border-t border-border pt-8">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Wirkung im Alltag</p>
          <ul class="mt-4 space-y-4 border-l border-border pl-5 text-base leading-8 text-foreground-secondary">
            {item.outcomes.map((outcome) => (
              <li>{outcome}</li>
            ))}
          </ul>
        </article>
      </div>
    </div>
  </section>

  <section class="border-y border-border bg-background-secondary py-24">
    <div class="container grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Leistungsanteile</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Welche Rolle Rocketbase übernommen hat.
        </h2>
      </div>

      <ul class="space-y-4 border-l border-border pl-5 text-base leading-8 text-foreground-secondary">
        {item.services.map((service) => (
          <li>{service}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="py-24">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Mehr Einblicke</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Weitere Referenzen
        </h2>
      </div>

      <div class="mt-12 grid gap-10 lg:grid-cols-2">
        {otherCases.map((entry) => (
          <article class="border-t border-border pt-6">
            <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">{entry.client}</p>
            <h3 class="mt-3 text-2xl font-semibold text-foreground">
              <a href={`/referenzen/${entry.slug}`}>{entry.title}</a>
            </h3>
            <p class="mt-4 text-base leading-8 text-foreground-secondary">{entry.kicker}</p>
            <div class="mt-6">
              <a href={`/referenzen/${entry.slug}`} class="text-sm font-semibold text-brand-600 transition-colors hover:text-brand-500">
                Referenz öffnen
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-24">
    <div class="container grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-end">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Projekt besprechen</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground">
          Wenn Ihr Vorhaben ähnliche Fragen aufwirft, sollten wir sprechen.
        </h2>
      </div>
      <div class="flex flex-wrap gap-4">
        <Button href={contactLinks.cal} target="_blank">
          Erstgespräch buchen
          <Icon name="arrow-up-right" size="sm" />
        </Button>
        <Button variant="outline" href="/referenzen">
          Zurück zu Referenzen
        </Button>
      </div>
    </div>
  </section>
</PageLayout>
