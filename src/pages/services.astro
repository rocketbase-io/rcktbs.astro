---
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath } from '@/i18n/index';
import {
  contactLinks,
  discoveryOffer,
  processSteps,
  serviceAreas,
} from '@/data/rocketbase';
import { cn } from '@/lib/cn';

const locale = defaultLocale;
const contactUrl = getLocalizedPath('contact', locale);
const workUrl = getLocalizedPath('work', locale);
const missionUrl = getLocalizedPath('mission', locale);

const serviceIcons = ['search', 'palette', 'code', 'monitor'];

const useCases = [
  {
    icon: 'layers',
    title: 'Interne Plattformen',
    text: 'Für Produktdaten, Content oder operative Kernprozesse – maßgeschneidert auf das Geschäft.',
  },
  {
    icon: 'box',
    title: 'Standardsoftware ablösen',
    text: 'Wenn ERP, CRM oder Standard-Tools Wachstum bremsen statt zu ermöglichen.',
  },
  {
    icon: 'database',
    title: 'CRM · CMS · PIM · PLM',
    text: 'Reporting-Lösungen mit individuellem Zuschnitt – passend zu echten Arbeitsabläufen.',
  },
  {
    icon: 'archive',
    title: 'Migration aus Altsystemen',
    text: 'Aus gewachsenen Altanwendungen oder proprietären Bestandssystemen – sauber überführt.',
  },
  {
    icon: 'users',
    title: 'Self-Service-Portale',
    text: 'Admin-Oberflächen und Prozesswerkzeuge für B2B-Teams – schlank, schnell, verständlich.',
  },
  {
    icon: 'globe',
    title: 'Integrationsprojekte',
    text: 'Zwischen bestehenden Systemen und neuer Business-Logik – API-first, ohne Datensilos.',
  },
];
---

<PageLayout
  title="Leistungen"
  description="Discovery, Konzeption, Individualsoftware und Betrieb. Sechs typische Vorhaben und ein produktisierter Discovery-Workshop."
  lang={locale}
  routeId="services"
>
  <!-- HERO -->
  <section
    class="border-border bg-background-secondary relative flex min-h-[60vh] items-center overflow-hidden border-b py-24 sm:py-32"
  >
    <div
      class="bg-grid-pattern pointer-events-none absolute inset-0 opacity-50 [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_75%)]"
      aria-hidden="true"
    />
    <div
      class="bg-brand-300/30 pointer-events-none absolute -top-24 -right-24 h-96 w-96 rounded-full blur-3xl"
      aria-hidden="true"
    />

    <div class="container relative z-10 max-w-5xl text-center">
      <p
        data-aos="fade-down"
        class="text-brand-600 text-sm font-semibold tracking-[0.22em] uppercase"
      >
        Leistungen
      </p>
      <h1
        data-aos="fade-down"
        class="font-display text-foreground mt-6 text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl"
      >
        Von Prozessanalyse bis Betrieb.
        <span
          class="from-brand-500 to-brand-400 mt-2 block bg-gradient-to-r bg-clip-text text-transparent"
        >
          Ohne künstliche Trennung.
        </span>
      </h1>
      <p
        data-aos="fade-up"
        class="text-foreground-secondary mx-auto mt-8 max-w-2xl text-lg leading-8 sm:text-xl"
      >
        Beratung, Produktdenken und technische Umsetzung greifen ineinander – fachlich wie
        technisch konsistent, von der ersten Discovery bis zum stabilen Betrieb.
      </p>
      <div data-aos="fade-up" class="mt-10 flex flex-wrap justify-center gap-4">
        <Button href={contactLinks.cal} target="_blank">
          Erstgespräch buchen
          <Icon name="arrow-up-right" size="sm" />
        </Button>
        <Button variant="outline" href={contactUrl}>
          Kontaktseite
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- LEISTUNGSBAUSTEINE -->
  <section class="relative overflow-hidden py-24 lg:py-32">
    <div class="container relative z-10 max-w-6xl">
      <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
        <div class="mx-auto flex max-w-md items-center gap-4">
          <span class="bg-border h-px flex-1" />
          <span class="border-brand-300 bg-card text-brand-600 flex h-10 w-10 items-center justify-center rounded-full border-2 font-mono text-sm font-bold">
            01
          </span>
          <span class="text-foreground-muted text-xs font-semibold tracking-[0.22em] uppercase">
            Leistungsbausteine
          </span>
          <span class="bg-border h-px flex-1" />
        </div>
        <h2 class="font-display text-foreground mt-8 text-3xl font-bold tracking-tight sm:text-4xl">
          Vier Bausteine, die sich an realen Projektverläufen orientieren.
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Statt austauschbarer Agenturmodule folgt die Struktur dem echten Verlauf
          anspruchsvoller Projekte: verstehen, priorisieren, bauen, sinnvoll betreiben.
        </p>
      </header>

      <div class="mt-16 grid gap-6 md:grid-cols-2">
        {
          serviceAreas.map((service: any, index: number) => (
            <article
              data-aos="fade-up"
              data-aos-duration="800"
              class="group border-border bg-card hover:border-brand-300 hover:shadow-lg relative overflow-hidden rounded-2xl border p-7 shadow-sm transition-all duration-300 ease-out hover:-translate-y-1"
            >
              <div class="flex items-start justify-between gap-4">
                <div class="bg-brand-50 text-brand-700 dark:bg-brand-900/30 dark:text-brand-100 group-hover:bg-brand-500 group-hover:text-on-invert group-hover:scale-110 inline-flex h-12 w-12 items-center justify-center rounded-xl transition-all duration-300">
                  <Icon name={serviceIcons[index] ?? 'box'} size="md" />
                </div>
                <span class="text-brand-600 font-mono text-sm font-bold tracking-[0.22em]">
                  0{index + 1}
                </span>
              </div>
              <h3 class="font-display text-foreground mt-6 text-2xl font-semibold">
                {service.title}
              </h3>
              <p class="text-foreground-secondary mt-3 text-base leading-7">
                {service.description}
              </p>
              <ul class="mt-6 space-y-3">
                {service.bullets.map((bullet: string) => (
                  <li class="text-foreground-secondary group/item flex gap-3 text-sm leading-6">
                    <Icon
                      name="check-circle"
                      size="sm"
                      class="text-brand-500 group-hover/item:scale-110 mt-0.5 shrink-0 transition-transform duration-300"
                    />
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- USE CASES -->
  <section class="border-border bg-background-secondary relative overflow-hidden border-y py-24 lg:py-32">
    <div
      class="bg-grid-pattern pointer-events-none absolute inset-0 opacity-30 [mask-image:radial-gradient(ellipse_at_center,black_20%,transparent_70%)]"
      aria-hidden="true"
    />
    <div
      class="bg-brand-300/15 pointer-events-none absolute -left-24 top-1/3 h-96 w-96 rounded-full blur-3xl"
      aria-hidden="true"
    />

    <div class="container relative z-10 max-w-6xl">
      <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
        <div class="mx-auto flex max-w-md items-center gap-4">
          <span class="bg-border h-px flex-1" />
          <span class="border-brand-300 bg-card text-brand-600 flex h-10 w-10 items-center justify-center rounded-full border-2 font-mono text-sm font-bold">
            02
          </span>
          <span class="text-foreground-muted text-xs font-semibold tracking-[0.22em] uppercase">
            Typische Vorhaben
          </span>
          <span class="bg-border h-px flex-1" />
        </div>
        <h2 class="font-display text-foreground mt-8 text-3xl font-bold tracking-tight sm:text-4xl">
          Lösungen für Prozesse, nicht für Buzzwords.
        </h2>
        <p class="text-foreground-secondary mt-6 text-lg leading-8">
          Branchenübergreifend. Entscheidender als die Branche sind Durchlaufzeiten,
          Informationsqualität, Medienbrüche – und die Frage, wie Teams effizienter
          zusammenarbeiten können.
        </p>
      </header>

      <div class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          useCases.map((useCase, index) => (
            <article
              data-aos="fade-up"
              data-aos-duration="800"
              data-aos-delay={index * 60}
              class="group border-border bg-card hover:border-brand-300 hover:shadow-lg relative overflow-hidden rounded-2xl border p-6 shadow-sm transition-all duration-300 ease-out hover:-translate-y-1"
            >
              <div class="bg-brand-50 text-brand-600 dark:bg-brand-900/30 dark:text-brand-100 group-hover:bg-brand-500 group-hover:text-on-invert group-hover:scale-110 inline-flex h-12 w-12 items-center justify-center rounded-xl transition-all duration-300">
                <Icon name={useCase.icon} size="md" />
              </div>
              <h3 class="font-display text-foreground mt-5 text-lg font-semibold">
                {useCase.title}
              </h3>
              <p class="text-foreground-secondary mt-3 text-sm leading-6">{useCase.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- VORGEHEN -->
  <section class="relative overflow-hidden py-24 lg:py-32">
    <div class="container relative z-10 max-w-6xl">
      <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
        <div class="mx-auto flex max-w-md items-center gap-4">
          <span class="bg-border h-px flex-1" />
          <span class="border-brand-300 bg-card text-brand-600 flex h-10 w-10 items-center justify-center rounded-full border-2 font-mono text-sm font-bold">
            03
          </span>
          <span class="text-foreground-muted text-xs font-semibold tracking-[0.22em] uppercase">
            Vorgehen
          </span>
          <span class="bg-border h-px flex-1" />
        </div>
        <h2 class="font-display text-foreground mt-8 text-3xl font-bold tracking-tight sm:text-4xl">
          So entsteht aus Prozesswissen eine belastbare Softwarelösung.
        </h2>
      </header>

      <div class="mt-16 grid gap-4 md:grid-cols-4">
        {
          processSteps.map((step: any, index: number) => (
            <article
              data-aos="fade-up"
              data-aos-duration="800"
              data-aos-delay={index * 80}
              class={cn(
                'group border-border bg-card hover:border-brand-300 hover:bg-background-secondary hover:-translate-y-1 hover:shadow-md relative flex flex-col rounded-2xl border p-6 transition-all duration-300 ease-out'
              )}
            >
              <span class="text-brand-500 font-mono text-xs font-semibold tracking-[0.22em] uppercase">
                Schritt {index + 1}
              </span>
              <h3 class="font-display text-foreground mt-3 text-xl font-semibold">{step.title}</h3>
              <p class="text-foreground-secondary mt-3 text-sm leading-6">{step.description}</p>
              {index < processSteps.length - 1 && (
                <Icon
                  name="arrow-right"
                  size="md"
                  class="text-brand-400 group-hover:translate-x-1 group-hover:text-brand-500 absolute top-1/2 -right-3 hidden -translate-y-1/2 transition-all duration-300 md:block"
                />
              )}
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- DISCOVERY WORKSHOP -->
  <section class="bg-surface-invert text-on-invert border-border border-t py-24 lg:py-32">
    <div class="container max-w-6xl">
      <header data-aos="fade-up" class="mx-auto max-w-3xl text-center">
        <div class="mx-auto flex max-w-md items-center gap-4">
          <span class="bg-white/20 h-px flex-1" />
          <span class="border-brand-300 text-brand-300 bg-white/5 flex h-10 w-10 items-center justify-center rounded-full border-2 font-mono text-sm font-bold">
            04
          </span>
          <span class="text-on-invert-secondary text-xs font-semibold tracking-[0.22em] uppercase">
            Produktisierte Vorleistung
          </span>
          <span class="bg-white/20 h-px flex-1" />
        </div>
        <h2 class="font-display text-on-invert mt-8 text-3xl font-bold tracking-tight sm:text-4xl">
          {discoveryOffer.title}
        </h2>
        <p class="text-on-invert-secondary mt-4 text-xl">{discoveryOffer.subtitle}</p>
        <p class="text-on-invert-secondary mx-auto mt-6 max-w-2xl text-lg leading-8">
          Statt kostenlos tiefe Vorarbeit zu leisten, schafft der Workshop eine belastbare
          Entscheidungsgrundlage – für beide Seiten.
        </p>
      </header>

      <div
        data-aos="fade-up"
        data-aos-duration="800"
        class="mt-16 rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur sm:p-10"
      >
        <p class="text-brand-300 text-xs font-semibold tracking-[0.22em] uppercase">
          Was Sie bekommen
        </p>
        <ul class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            discoveryOffer.deliverables.map((item: string) => (
              <li class="text-on-invert-secondary group flex gap-3 rounded-2xl border border-white/10 bg-white/5 p-4 text-base transition-all duration-300 hover:border-brand-300/40 hover:bg-white/10">
                <Icon
                  name="check-circle"
                  size="sm"
                  class="text-brand-300 group-hover:scale-110 mt-1 shrink-0 transition-transform duration-300"
                />
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href={contactLinks.cal} target="_blank">
            Workshop anfragen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <Button
            variant="outline"
            href={contactUrl}
            class="border-white/20 text-on-invert hover:border-white/40 hover:bg-white/10"
          >
            Kontakt
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- BRIDGE: WORK + MISSION -->
  <section class="border-border bg-background-secondary border-t py-24">
    <div class="container max-w-5xl">
      <div class="grid gap-6 md:grid-cols-2">
        <a
          href={workUrl}
          data-aos="fade-right"
          class="group border-border bg-card hover:border-brand-300 hover:shadow-lg block rounded-3xl border p-8 shadow-sm transition-all duration-300 ease-out hover:-translate-y-1"
        >
          <div class="bg-brand-50 text-brand-700 dark:bg-brand-900/30 dark:text-brand-100 group-hover:bg-brand-500 group-hover:text-on-invert group-hover:scale-110 inline-flex h-12 w-12 items-center justify-center rounded-xl transition-all duration-300">
            <Icon name="zap" size="md" />
          </div>
          <h3 class="font-display text-foreground mt-5 text-2xl font-semibold">
            So arbeiten wir konkret
          </h3>
          <p class="text-foreground-secondary mt-3 text-base leading-7">
            Discovery, Team, Cloud, Tools, KI – fünf Wechsel, die unsere Projekte heute
            schneller, leichter und tragfähiger machen.
          </p>
          <p class="text-brand-600 mt-5 inline-flex items-center gap-2 text-sm font-semibold">
            Zur Work-Seite
            <Icon
              name="arrow-right"
              size="sm"
              class="transition-transform duration-300 group-hover:translate-x-1"
            />
          </p>
        </a>

        <a
          href={missionUrl}
          data-aos="fade-left"
          class="group border-border bg-card hover:border-brand-300 hover:shadow-lg block rounded-3xl border p-8 shadow-sm transition-all duration-300 ease-out hover:-translate-y-1"
        >
          <div class="bg-brand-50 text-brand-700 dark:bg-brand-900/30 dark:text-brand-100 group-hover:bg-brand-500 group-hover:text-on-invert group-hover:scale-110 inline-flex h-12 w-12 items-center justify-center rounded-xl transition-all duration-300">
            <Icon name="heart" size="md" />
          </div>
          <h3 class="font-display text-foreground mt-5 text-2xl font-semibold">
            Unsere Haltung
          </h3>
          <p class="text-foreground-secondary mt-3 text-base leading-7">
            Acht Prinzipien hinter jedem Projekt – warum wir bestimmte Entscheidungen treffen,
            und welche Verantwortung wir übernehmen.
          </p>
          <p class="text-brand-600 mt-5 inline-flex items-center gap-2 text-sm font-semibold">
            Zur Mission
            <Icon
              name="arrow-right"
              size="sm"
              class="transition-transform duration-300 group-hover:translate-x-1"
            />
          </p>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
