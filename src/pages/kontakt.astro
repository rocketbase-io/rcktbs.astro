---
import { Picture } from 'astro:assets';
import PageLayout from '@/layouts/PageLayout.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import Input from '@/components/ui/form/Input/Input.astro';
import Textarea from '@/components/ui/form/Textarea/Textarea.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { defaultLocale } from '@/i18n/config';
import { getLocalizedPath, useTranslations } from '@/i18n/index';
import { contactLinks } from '@/data/rocketbase';
import founderStamp from '@/assets/rocketbase/founder-marten-priess-alt.jpg';

const locale = defaultLocale;
const t = useTranslations(locale);
const servicesUrl = getLocalizedPath('services', locale);

const reasonsToReachOut = [
  'Sie wollen prüfen, ob Standardsoftware noch trägt oder bereits bremst.',
  'Ein interner Prozess soll digitalisiert, vereinfacht oder beschleunigt werden.',
  'Ein bestehendes System muss modernisiert, integriert oder sauber abgelöst werden.',
  'Sie möchten eine Idee direkt mit Marten Prieß statt mit Vertrieb abstimmen.',
];

const nextSteps = [
  'Kurzer Austausch zu Zielbild, Prozess und aktuellem Engpass',
  'Ehrliche Einordnung, ob Discovery, Workshop oder direkter Projektstart sinnvoll ist',
  'Konkrete nächste Schritte statt unverbindlichem Follow-up',
];

const directCollaborationDefinition =
  'Bei RocketBase arbeiten Sie direkt mit Marten Prieß. Analyse, Lösungsrichtung und technische Entscheidungen bleiben dadurch nah an Ihrem Projekt.';
---

<PageLayout
  title={t('contact.meta.title')}
  description={t('contact.meta.description')}
  lang={locale}
  routeId="contact"
>
  <section class="border-b border-border bg-background-secondary py-24">
    <div class="container grid gap-24 lg:grid-cols-[1.05fr_0.95fr] lg:items-end lg:gap-12">
      <div data-reveal="fade-right" class="max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Kontakt</p>
        <h1 class="mt-4 font-display text-5xl font-bold tracking-tight text-foreground sm:text-6xl">
          Direkt zum Gespräch, <span class="text-brand-500">nicht erst durch Agenturfilter.</span>
        </h1>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Wenn ein Prozess hakt, ein System an Grenzen stößt oder ein Vorhaben sauber eingeordnet
          werden soll, sprechen Sie bei RocketBase direkt mit Marten Prieß über die sinnvollsten
          nächsten Schritte.
        </p>

        <div data-reveal="zoom-in" class="mt-8 rounded-[1.9rem] border border-brand-200 bg-brand-50 p-6 shadow-sm dark:border-brand-800 dark:bg-brand-900/20">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-700 dark:text-brand-200">
            So arbeiten wir
          </p>
          <p class="mt-3 text-base leading-7 text-foreground-secondary">{directCollaborationDefinition}</p>
        </div>

        <div data-reveal class="mt-8 flex flex-wrap gap-4">
          <Button href={contactLinks.cal} target="_blank">
            Erstgespräch buchen
            <Icon name="arrow-up-right" size="sm" />
          </Button>
          <Button href={servicesUrl} variant="outline">
            Leistungen ansehen
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>

      <div data-reveal="zoom-in" class="relative rounded-[2.25rem] border border-white/10 bg-surface-invert p-8 pt-16 text-on-invert shadow-[0_32px_90px_rgba(22,28,44,0.28)] sm:pt-20 lg:pt-24">
        <div class="absolute -top-8 left-6 rotate-[-4deg] sm:-top-12 sm:left-8 lg:-top-14">
          <div class="bg-brand-400/30 absolute -inset-3 -z-10 rounded-full blur-xl" aria-hidden="true" />
          <div class="overflow-hidden rounded-full border-4 border-surface-invert shadow-[0_14px_36px_rgba(22,28,44,0.5)] h-20 w-20 sm:h-28 sm:w-28 lg:h-32 lg:w-32">
            <Picture
              src={founderStamp}
              alt="Marten Prieß"
              widths={[128, 192, 256]}
              sizes="(max-width: 640px) 80px, (max-width: 1024px) 112px, 128px"
              formats={['avif', 'webp']}
              class="h-full w-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-300">Direkter Draht</p>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-on-invert">
          Sie sprechen hier nicht mit Vertrieb.
        </h2>
        <p class="mt-4 text-base leading-7 text-on-invert-secondary">
          Das Erstgespräch dient dazu, Prozess, Zielbild und Handlungsoptionen einzuordnen. Wenn
          RocketBase nicht der richtige Fit ist, wird das auch so benannt.
        </p>

        <div class="mt-8 grid gap-4">
          <a
            href={`mailto:${contactLinks.email}`}
            class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition-colors hover:bg-white/10"
          >
            <p class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-on-invert-muted">
              <Icon name="mail" size="xs" class="text-brand-300" />
              E-Mail
            </p>
            <p class="mt-2 break-words text-base font-semibold text-on-invert">{contactLinks.email}</p>
          </a>

          <a
            href={contactLinks.cal}
            target="_blank"
            class="rounded-[1.5rem] border border-white/10 bg-white/5 p-5 transition-colors hover:bg-white/10"
          >
            <p class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-on-invert-muted">
              <Icon name="clock" size="xs" class="text-brand-300" />
              Termin
            </p>
            <p class="mt-2 text-base font-semibold text-on-invert">Erstgespräch mit Marten Prieß</p>
          </a>
        </div>

        <div class="mt-8 border-t border-white/10 pt-6">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-300">Passt besonders gut, wenn ...</p>
          <ul class="mt-4 space-y-4 text-sm leading-6 text-on-invert-secondary">
            {reasonsToReachOut.slice(0, 3).map((reason) => (
              <li class="flex gap-3">
                <Icon name="check-circle" size="sm" class="mt-0.5 shrink-0 text-brand-300" />
                <span>{reason}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="py-28">
    <div class="container grid gap-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-start">
      <div data-reveal="fade-right" class="lg:sticky lg:top-28">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Anfrage stellen</p>
        <h2 class="mt-4 font-display text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Projekt, Prozess oder Discovery-Workshop anfragen.
        </h2>
        <p class="mt-6 text-lg leading-8 text-foreground-secondary">
          Nutzen Sie das Formular, wenn Sie Ihr Vorhaben strukturiert einordnen möchten. Für
          komplexere Themen ist der Discovery-Workshop oft der sinnvollere Einstieg als ein loses
          Sales-Gespräch.
        </p>

        <div data-reveal="zoom-in" class="mt-8 rounded-[1.9rem] border border-border bg-card p-7 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-brand-600">Was Sie nach dem Erstkontakt bekommen</p>
          <div class="mt-6 space-y-5">
            {nextSteps.map((step, index) => (
              <div class="grid gap-3 md:grid-cols-[42px_1fr] md:items-start">
                <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-brand-50 text-sm font-semibold text-brand-700 dark:bg-brand-900/30 dark:text-brand-100">
                  0{index + 1}
                </div>
                <p class="text-base leading-7 text-foreground-secondary">{step}</p>
              </div>
            ))}
          </div>
        </div>

      </div>

      <div data-reveal="zoom-in" class="relative">
        <div class="absolute inset-x-10 top-6 -z-10 h-56 rounded-full bg-brand-300/20 blur-3xl dark:bg-brand-600/15"></div>
        <div class="rounded-[2.25rem] border border-border bg-card p-8 shadow-[0_24px_80px_rgba(34,43,74,0.12)] sm:p-10">

          <!-- Success state (hidden until form submitted) -->
          <div id="form-success" class="hidden flex-col items-center py-12 text-center">
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-brand-50 dark:bg-brand-900/30">
              <Icon name="check-circle" size="lg" class="text-brand-500" />
            </div>
            <h3 class="mt-6 font-display text-2xl font-bold tracking-tight text-foreground">
              Nachricht erhalten.
            </h3>
            <p class="mt-3 max-w-sm text-base leading-7 text-foreground-secondary">
              Vielen Dank für Ihre Anfrage. Marten meldet sich in der Regel innerhalb eines Werktages.
            </p>
            <div class="mt-8 flex flex-wrap justify-center gap-3">
              <a
                href={contactLinks.cal}
                target="_blank"
                class="inline-flex items-center gap-2 rounded-xl bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 transition-colors"
              >
                <Icon name="clock" size="sm" />
                Direkt Termin buchen
              </a>
              <a
                href="/"
                class="inline-flex items-center gap-2 rounded-xl border border-border px-5 py-2.5 text-sm font-semibold text-foreground hover:bg-background-secondary transition-colors"
              >
                Zur Startseite
              </a>
            </div>
          </div>

          <!-- Form (shown by default) -->
          <div id="form-container">
            <div class="border-b border-border pb-6">
              <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">{t('contact.form.title')}</p>
              <h3 class="mt-3 font-display text-3xl font-bold tracking-tight text-foreground">
                Worum geht es konkret?
              </h3>
              <p class="mt-4 max-w-xl text-base leading-7 text-foreground-secondary">
                Je konkreter Zielbild, aktuelles System oder Engpass beschrieben sind, desto
                schneller wird das Erstgespräch substanziell.
              </p>
            </div>

            <form id="contact-form" action="/api/contact" method="POST" class="mt-8 space-y-6">
              <div class="grid gap-6 sm:grid-cols-2">
                <Input
                  label={t('contact.form.name')}
                  name="name"
                  type="text"
                  placeholder={t('contact.form.namePlaceholder')}
                  required
                  autocomplete="name"
                />

                <Input
                  label={t('contact.form.email')}
                  name="email"
                  type="email"
                  placeholder={t('contact.form.emailPlaceholder')}
                  required
                  autocomplete="email"
                />
              </div>

              <Input
                label={t('contact.form.subject')}
                name="subject"
                type="text"
                placeholder={t('contact.form.subjectPlaceholder')}
              />

              <Textarea
                label={t('contact.form.message')}
                name="message"
                placeholder={t('contact.form.messagePlaceholder')}
                rows={7}
                required
              />

              <div class="hidden" aria-hidden="true">
                <input type="text" name="honeypot" tabindex="-1" autocomplete="off" />
              </div>

              <div class="flex flex-col gap-4 border-t border-border pt-6 sm:flex-row sm:items-center sm:justify-between">
                <div id="form-message" class="hidden text-sm"></div>
                <Button type="submit" id="submit-button">
                  <Icon name="mail" size="sm" />
                  {t('contact.form.submit')}
                </Button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-border bg-background-secondary py-24">
    <div class="container grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div data-reveal="zoom-in" class="rounded-[2rem] border border-border bg-card p-8 shadow-sm">
        <p class="text-sm font-semibold uppercase tracking-[0.22em] text-brand-600">Alternative Kanäle</p>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-foreground">
          Wenn Sie lieber direkt schreiben oder einen Blick auf die Profile werfen möchten.
        </h2>
      </div>

      <div  class="grid gap-4 sm:grid-cols-2">
        <a
          data-reveal="zoom-in"
          href={contactLinks.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-[1.6rem] border border-border bg-card p-6 shadow-sm transition-colors hover:border-brand-300"
        >
          <Icon name="linkedin" size="md" class="text-brand-500" />
          <p class="mt-5 text-lg font-semibold text-foreground">LinkedIn</p>
          <p class="mt-2 text-sm leading-6 text-foreground-secondary">
            Einordnung, Updates und direkter Kontakt über das RocketBase-Profil.
          </p>
        </a>

        <a
          data-reveal="zoom-in"
          href={contactLinks.github}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-[1.6rem] border border-border bg-card p-6 shadow-sm transition-colors hover:border-brand-300"
        >
          <Icon name="github" size="md" class="text-brand-500" />
          <p class="mt-5 text-lg font-semibold text-foreground">GitHub</p>
          <p class="mt-2 text-sm leading-6 text-foreground-secondary">
            Technischer Hintergrund und Open-Source-Nähe statt reiner Agenturbehauptungen.
          </p>
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<script
  define:vars={{
    sendingText: t('contact.form.sending'),
    successText: t('contact.form.success'),
    errorText: t('contact.form.error'),
    submitText: t('contact.form.submit'),
  }}
>
  function initContactForm() {
    const form = document.getElementById('contact-form');
    const button = document.getElementById('submit-button');
    const message = document.getElementById('form-message');

    if (!(form instanceof HTMLFormElement) || !(button instanceof HTMLButtonElement) || !(message instanceof HTMLDivElement)) {
      return;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      button.disabled = true;
      button.textContent = sendingText;
      message.classList.add('hidden');

      try {
        const formData = new FormData(form);
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.success) {
          const formContainer = document.getElementById('form-container');
          const formSuccess = document.getElementById('form-success');
          if (formContainer && formSuccess) {
            formContainer.classList.add('hidden');
            formSuccess.classList.remove('hidden');
            formSuccess.classList.add('flex');
          }
          return;
        } else {
          const errors = data.errors ? Object.values(data.errors).flat().join(', ') : errorText;
          message.textContent = errors;
          message.className = 'text-sm text-destructive';
        }
      } catch {
        message.textContent = errorText;
        message.className = 'text-sm text-destructive';
      } finally {
        button.disabled = false;
        button.textContent = submitText;
        message.classList.remove('hidden');
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
