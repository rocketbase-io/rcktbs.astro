---
import type { ImageMetadata } from 'astro';
import BaseLayout from './BaseLayout.astro';
import Navbar from '@/components/landing/Navbar.astro';
import LandingFooter from '@/components/landing/LandingFooter.astro';
import Breadcrumbs from '@/components/seo/Breadcrumbs.astro';
import ArticleHero from '@/components/blog/ArticleHero.astro';
import AuthorBio from '@/components/blog/AuthorBio.astro';
import PostCTA from '@/components/blog/PostCTA.astro';
import ShareButtons from '@/components/blog/ShareButtons.astro';
import RelatedPosts from '@/components/blog/RelatedPosts.astro';
import { defaultLocale, type Locale } from '@/i18n/config';
import { useTranslations } from '@/i18n/index';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author?: string;
  image?: ImageMetadata;
  imageAlt?: string;
  tags?: string[];
  slug?: string;
  locale?: Locale;
  readingTime?: number;
  cta?: {
    eyebrow?: string;
    headline?: string;
    body?: string;
  };
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  author = 'Team',
  image,
  imageAlt,
  tags = [],
  slug = '',
  locale = defaultLocale,
  readingTime,
  cta,
} = Astro.props;

const t = useTranslations(locale);
// Prefer the generated OG composite (hero image + branded overlay) over the raw hero.
// Falls back to the raw image.src only if the generated route is unavailable.
const ogImage = `/og${Astro.url.pathname}.png`;

// Build breadcrumbs with locale-aware URLs
const blogUrl = locale === defaultLocale ? '/blog' : `/${locale}/blog`;
const homeUrl = locale === defaultLocale ? '/' : `/${locale}`;

const breadcrumbs = [
  { label: t('nav.home'), href: homeUrl },
  { label: t('nav.blog'), href: blogUrl },
  { label: title },
];

// Get full URL for sharing
const fullUrl = new URL(Astro.url.pathname, Astro.site).toString();
---

<BaseLayout
  title={title}
  description={description}
  image={ogImage}
  imageAlt={imageAlt || title}
  lang={locale}
  article={{
    publishedTime: publishedAt,
    modifiedTime: updatedAt,
    authors: [author],
    tags,
  }}
>
  <Navbar slot="header" />

  <!-- Article Hero -->
  <ArticleHero
    title={title}
    description={description}
    publishedAt={publishedAt}
    updatedAt={updatedAt}
    author={author}
    tags={tags}
    image={image}
    imageAlt={imageAlt}
    readingTime={readingTime}
  />

  <article class="py-12">
    <div class="mx-auto max-w-6xl px-6">
      <!-- Breadcrumbs -->
      <Breadcrumbs items={breadcrumbs} class="mb-8" />

      <!-- Article Content -->
      <div class="blog-content max-w-none">
        <slot />
      </div>

      <!-- Article Footer -->
      <footer class="mt-12 pt-8 border-t border-border">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
          <!-- Back link -->
          <a
            href={blogUrl}
            class="inline-flex items-center gap-2 text-sm font-medium text-brand-600 hover:text-brand-500 dark:text-brand-400 dark:hover:text-brand-300 transition-colors"
          >
            <svg
              class="h-4 w-4"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            {t('blog.backToBlog')}
          </a>

          <!-- Share buttons -->
          <ShareButtons title={title} url={fullUrl} />
        </div>
      </footer>

      <!-- Author bio -->
      <AuthorBio author={author} />

      <!-- Post CTA (always present, text overridable via frontmatter) -->
      <PostCTA
        eyebrow={cta?.eyebrow}
        headline={cta?.headline}
        body={cta?.body}
      />
    </div>
  </article>

  <!-- Related Posts: always show 3 other posts, ranked by tag relevance then recency -->
  <div class="mx-auto max-w-6xl px-6 pb-16">
    <RelatedPosts
      currentSlug={slug}
      tags={tags}
      locale={locale}
      maxPosts={3}
    />
  </div>

  <LandingFooter slot="footer" />
</BaseLayout>

<style is:global>
  /* Blog content typography - scoped to the article body only.
     Excludes .not-prose (CTAs, diagrams) which bring their own styling. */
  .blog-content > :not(.not-prose, :where(.not-prose *)) {
    /* Rhythm reset on direct children */
  }

  .blog-content h2:not(.not-prose *) {
    font-family: var(--theme-font-display, var(--font-display));
    font-weight: 700;
    font-size: 2rem; /* 32px */
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    color: var(--color-foreground);
  }

  .blog-content h3:not(.not-prose *) {
    font-family: var(--theme-font-display, var(--font-display));
    font-weight: 700;
    font-size: 1.5rem; /* 24px */
    line-height: 1.3;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--color-foreground);
  }

  .blog-content > p,
  .blog-content > ul > li,
  .blog-content > ol > li {
    font-size: 1.125rem; /* 18px = text-lg */
    line-height: 2rem; /* 32px = leading-8 */
    color: var(--color-foreground-secondary);
  }

  .blog-content > p {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .blog-content > p:first-child {
    margin-top: 0;
  }

  .blog-content > ul,
  .blog-content > ol {
    margin-top: 1.25rem;
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .blog-content > ul {
    list-style: disc;
  }

  .blog-content > ol {
    list-style: decimal;
  }

  .blog-content > ul > li,
  .blog-content > ol > li {
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .blog-content a:not(.not-prose *) {
    color: var(--color-brand-600, #5869a5);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .blog-content a:not(.not-prose *):hover {
    color: var(--color-brand-500, #6372a5);
  }

  .blog-content strong:not(.not-prose *) {
    color: var(--color-foreground);
    font-weight: 600;
  }

  .blog-content code:not(pre code):not(.not-prose *) {
    color: var(--color-brand-600, #5869a5);
    background: var(--color-brand-50, rgba(99, 114, 165, 0.08));
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  :global(.dark) .blog-content a:not(.not-prose *) {
    color: var(--color-brand-400, #8a97c4);
  }
  :global(.dark) .blog-content a:not(.not-prose *):hover {
    color: var(--color-brand-300, #a6b1d4);
  }
  :global(.dark) .blog-content code:not(pre code):not(.not-prose *) {
    color: var(--color-brand-400, #8a97c4);
    background: rgba(99, 114, 165, 0.15);
  }
</style>
