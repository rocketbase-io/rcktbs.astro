---
import '@/styles/global.css';
import SEO from '@/components/seo/SEO.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import Hreflang from '@/components/i18n/Hreflang.astro';
import Analytics from '@/components/layout/Analytics.astro';
import ScrollProgress from '@/components/layout/ScrollProgress.astro';
import ConsentBanner from '@/components/ui/overlay/ConsentBanner';
import { createWebsiteSchema, createOrganizationSchema } from '@/lib/schema';
import type { WebSite, Organization, WithContext } from 'schema-dts';
import siteConfig from '@/config/site.config';
import { type Locale, defaultLocale, getLocaleFromPath } from '@/i18n/config';
import { useTranslations } from '@/i18n/index';
import type { RouteId } from '@/i18n/routes';
import "aos/dist/aos.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  article?: {
    publishedTime?: Date;
    modifiedTime?: Date;
    authors?: string[];
    tags?: string[];
  };
  noindex?: boolean;
  nofollow?: boolean;
  includeOrgSchema?: boolean;
  lang?: Locale;
  /**
   * Route ID for generating proper hreflang tags.
   * If provided, uses translated URLs; otherwise falls back to path-based hreflang.
   */
  routeId?: RouteId;
}

const {
  title,
  description,
  image,
  imageAlt,
  article,
  noindex = false,
  nofollow = false,
  includeOrgSchema = false,
  lang,
  routeId,
} = Astro.props;

// Get locale from props or URL path
const currentLocale = lang || getLocaleFromPath(Astro.url.pathname);

// Build translated consent UI text
const tc = useTranslations(currentLocale);
const consentUi = {
  heading: tc('consent.heading'),
  description: tc('consent.description'),
  acceptAll: tc('consent.acceptAll'),
  declineAll: tc('consent.declineAll'),
  customize: tc('consent.customize'),
  savePreferences: tc('consent.savePreferences'),
  settingsHeading: tc('consent.settingsHeading'),
  privacyPolicyLabel: tc('consent.privacyPolicyLabel'),
};
const consentAlwaysOnLabel = tc('consent.alwaysOn');

// Build JSON-LD schemas
const schemas: Array<WithContext<WebSite> | WithContext<Organization>> = [createWebsiteSchema()];
if (includeOrgSchema) {
  schemas.push(createOrganizationSchema());
}
---

<!doctype html>
<html lang={currentLocale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Velocity Fonts: Outfit (display), Manrope (body), JetBrains Mono (code) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking font loading -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Manrope:wght@400;500;600;700&family=Outfit:wght@400;500;600;700&display=swap" rel="stylesheet" />
    </noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={siteConfig.branding.favicon.svg} />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content={siteConfig.branding.colors.themeColor} />

    <!-- SEO -->
    <SEO
      title={title}
      description={description}
      image={image}
      imageAlt={imageAlt}
      article={article}
      noindex={noindex}
      nofollow={nofollow}
    />

    <!-- Alternate language links for SEO (uses translated URLs when routeId provided) -->
    <Hreflang routeId={routeId} />

    <!-- JSON-LD Structured Data -->
    <JsonLd schema={schemas} />

    <!-- Analytics (loads if PUBLIC_GA_MEASUREMENT_ID or PUBLIC_GTM_ID is set) -->
    <Analytics />

    <!-- Theme script (runs before render to prevent flash) -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem('theme');
        const systemDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

        if (theme === 'dark' || (!theme && systemDark)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>

    <style is:inline>
      /* Before AOS boots, keep content visible. Doubled-attr specificity
         beats AOS's own [data-aos^=fade][data-aos^=fade]{opacity:0} rule. */
      html:not(.aos-ready) [data-aos][data-aos] {
        opacity: 1 !important;
        transform: none !important;
        transition: none !important;
      }
      /* While AOS is active but not settled, hide for the reveal animation. */
      html.aos-ready:not(.aos-settled) [data-aos][data-aos] {
        opacity: 0;
        transition-property: opacity, transform;
        transition-duration: 800ms;
      }
      html.aos-ready:not(.aos-settled) [data-aos][data-aos].aos-animate {
        opacity: 1;
        transform: none;
      }
      html.aos-ready:not(.aos-settled) [data-aos="fade-up"]:not(.aos-animate) { transform: translateY(24px); }
      html.aos-ready:not(.aos-settled) [data-aos="fade-down"]:not(.aos-animate) { transform: translateY(-24px); }
      html.aos-ready:not(.aos-settled) [data-aos="fade-left"]:not(.aos-animate) { transform: translateX(24px); }
      html.aos-ready:not(.aos-settled) [data-aos="fade-right"]:not(.aos-animate) { transform: translateX(-24px); }
      html.aos-ready:not(.aos-settled) [data-aos="zoom-in"]:not(.aos-animate) { transform: scale(0.94); }
      /* Once settled, force every data-aos element visible regardless of AOS state.
         Doubled-attr specificity + !important wins over AOS's own opacity:0 rule. */
      html.aos-settled [data-aos][data-aos] {
        opacity: 1 !important;
        transform: none !important;
      }
      @media (prefers-reduced-motion: reduce) {
        html [data-aos][data-aos] {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      }
    </style>

    <script is:inline>
      // Safety net: if AOS fails to boot (iOS Safari bfcache, stalled module
      // load, slow network) the aos-settled class unconditionally reveals all
      // [data-aos] content so the page never stays blank.
      (function () {
        var FALLBACK_MS = 600;
        var settled = false;
        var settle = function () {
          if (settled) return;
          settled = true;
          document.documentElement.classList.add('aos-settled');
        };
        setTimeout(settle, FALLBACK_MS);
        window.addEventListener('pageshow', function (e) {
          if (e.persisted) settle();
        });
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', function () {
            setTimeout(settle, 200);
          });
        } else {
          setTimeout(settle, 200);
        }
      })();
    </script>
  </head>

  <body class="min-h-screen bg-background text-foreground antialiased">
    <!-- Skip to content link -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground"
    >
      Skip to content
    </a>

    <slot name="header" />
    <ScrollProgress />
    <script>
      import AOS from "aos";

      const settle = () => {
        document.documentElement.classList.add("aos-settled");
      };

      const init = () => {
        try {
          document.documentElement.classList.add("aos-ready");
          AOS.init({
            duration: 800,
            once: true,
            disable: () =>
              window.matchMedia("(prefers-reduced-motion: reduce)").matches,
          });
          // After AOS has had a chance to mark above-the-fold elements as
          // animated, flip the safety class so nothing can stay invisible.
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              AOS.refresh();
              setTimeout(settle, 900);
            });
          });
        } catch {
          settle();
        }
      };

      init();
      window.addEventListener("pageshow", (e) => {
        const evt = e as PageTransitionEvent;
        if (evt.persisted) {
          settle();
          try {
            AOS.refreshHard();
          } catch {
            /* ignore */
          }
        }
      });
    </script>
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <ConsentBanner ui={consentUi} alwaysOnLabel={consentAlwaysOnLabel} />
  </body>
</html>
