---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { cn } from '@/lib/cn';

interface LogoItem {
  key: string;
  name: string;
  href?: string;
}

interface Props {
  heading?: string;
  logos: LogoItem[];
  variant?: 'light' | 'subtle';
  class?: string;
}

const { heading, logos, variant = 'subtle', class: className } = Astro.props;

const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  '@/assets/client-logos/*.{svg,png,webp,jpeg,jpg}',
  { eager: true },
);
const logoMap: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(logoModules).map(([path, mod]) => {
    const key = path.split('/').pop()!.replace(/\.(svg|png|webp|jpe?g)$/i, '');
    return [key, mod.default];
  }),
);

const resolved = logos.map((logo) => ({
  ...logo,
  image: logoMap[logo.key],
}));

const sectionBg = variant === 'light' ? 'bg-background' : 'bg-background-secondary';
---

<section class={cn('border-y border-border py-12 lg:py-16', sectionBg, className)}>
  <div class="container">
    {heading && (
      <p
        class="text-foreground-muted mb-8 text-center text-xs font-semibold uppercase tracking-[0.22em]"
        data-aos="fade-up"
      >
        {heading}
      </p>
    )}
    <ul
      class="flex flex-wrap items-center justify-center gap-x-10 gap-y-6 sm:gap-x-14 lg:gap-x-16"
      data-aos="fade-up"
      data-aos-delay="60"
    >
      {resolved.map((logo) => {
        const content = logo.image ? (
          <Image
            src={logo.image}
            alt={logo.name}
            widths={[120, 180, 240]}
            sizes="(max-width: 640px) 120px, 180px"
            class="h-8 w-auto object-contain opacity-70 grayscale transition-all duration-200 hover:opacity-100 hover:grayscale-0 sm:h-10"
            loading="lazy"
          />
        ) : (
          <span class="text-foreground-muted text-sm font-semibold tracking-wide">
            {logo.name}
          </span>
        );

        return (
          <li class="flex items-center">
            {logo.href ? (
              <a
                href={logo.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={logo.name}
                class="inline-flex items-center"
              >
                {content}
              </a>
            ) : (
              content
            )}
          </li>
        );
      })}
    </ul>
  </div>
</section>
