---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { cn } from '@/lib/cn';

interface Props {
  quote: string;
  author: string;
  position: string;
  portraitKey?: string;
  client?: string;
  class?: string;
}

const { quote, author, position, portraitKey, client, class: className } = Astro.props;

const portraitModules = import.meta.glob<{ default: ImageMetadata }>(
  '@/assets/testimonials/*.{jpeg,jpg,png,webp}',
  { eager: true },
);
const portraitMap: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(portraitModules).map(([path, mod]) => {
    const key = path.split('/').pop()!.replace(/\.(jpe?g|png|webp)$/i, '');
    return [key, mod.default];
  }),
);
const portrait = portraitKey ? portraitMap[portraitKey] : undefined;

const initials = author
  .split(' ')
  .map((word) => word[0])
  .join('')
  .slice(0, 2)
  .toUpperCase();
---

<figure
  class={cn(
    'bg-card border-border relative rounded-2xl border p-6 shadow-sm sm:p-7',
    className,
  )}
>
  <svg
    aria-hidden="true"
    viewBox="0 0 32 32"
    class="text-brand-500/30 mb-4 h-7 w-7"
    fill="currentColor"
  >
    <path d="M9.352 4C4.456 7.456 1 13.12 1 19.36c0 5.088 3.072 8.064 6.624 8.064 3.36 0 5.856-2.688 5.856-5.856 0-3.168-2.208-5.472-5.088-5.472-.576 0-1.344.096-1.536.192.48-3.264 3.552-7.104 6.624-9.024L9.352 4Zm16.512 0c-4.8 3.456-8.256 9.12-8.256 15.36 0 5.088 3.072 8.064 6.624 8.064 3.264 0 5.856-2.688 5.856-5.856 0-3.168-2.304-5.472-5.184-5.472-.576 0-1.248.096-1.44.192.48-3.264 3.456-7.104 6.528-9.024L25.864 4Z" />
  </svg>

  <blockquote>
    <p class="text-foreground-secondary text-sm leading-6 sm:text-base sm:leading-7">
      {quote}
    </p>
  </blockquote>

  <figcaption class="border-border mt-5 flex items-center gap-3 border-t pt-4">
    <div class="border-border bg-background-secondary flex h-10 w-10 shrink-0 items-center justify-center overflow-hidden rounded-full border">
      {portrait ? (
        <Image
          src={portrait}
          alt={author}
          widths={[48, 72, 96]}
          sizes="40px"
          class="h-full w-full object-cover"
          loading="lazy"
        />
      ) : (
        <span class="text-foreground-muted text-xs font-semibold">{initials}</span>
      )}
    </div>
    <div class="min-w-0 text-xs sm:text-sm">
      <p class="text-foreground font-semibold">{author}</p>
      <p class="text-foreground-muted">
        {position}{client && <span> · {client}</span>}
      </p>
    </div>
  </figcaption>
</figure>
