---
/**
 * Moon - bgjar-inspired hero background: a large soft moon with
 * a crescent shadow + floating particles. Subtle floating animation.
 */
---

<div class="hero-moon pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  <svg
    class="absolute inset-0 h-full w-full"
    viewBox="0 0 1440 720"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <radialGradient id="moonBody" cx="0.42" cy="0.38" r="0.7">
        <stop offset="0%" stop-color="var(--moon-center)" />
        <stop offset="60%" stop-color="var(--moon-mid)" />
        <stop offset="100%" stop-color="var(--moon-edge)" />
      </radialGradient>
      <radialGradient id="moonHalo" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0%" stop-color="var(--moon-halo-start)" />
        <stop offset="100%" stop-color="var(--moon-halo-end)" />
      </radialGradient>
      <radialGradient id="moonShadow" cx="0.35" cy="0.45" r="0.6">
        <stop offset="0%" stop-color="var(--moon-shadow-start)" />
        <stop offset="70%" stop-color="var(--moon-shadow-mid)" />
        <stop offset="100%" stop-color="var(--moon-shadow-end)" />
      </radialGradient>
    </defs>

    <!-- Halo glow -->
    <circle cx="1080" cy="260" r="360" fill="url(#moonHalo)" opacity="0.6" class="hero-moon-halo" />

    <!-- Slow-rotating orbit rings around the moon -->
    <g class="hero-moon-orbit hero-moon-orbit-1" style="transform-origin: 1080px 260px;">
      <ellipse cx="1080" cy="260" rx="280" ry="80" fill="none" stroke="var(--moon-orbit)" stroke-width="1" stroke-dasharray="3 8" />
    </g>
    <g class="hero-moon-orbit hero-moon-orbit-2" style="transform-origin: 1080px 260px;">
      <ellipse cx="1080" cy="260" rx="340" ry="110" fill="none" stroke="var(--moon-orbit)" stroke-width="0.8" stroke-dasharray="2 12" transform="rotate(-18 1080 260)" />
    </g>

    <!-- Moon body -->
    <g class="hero-moon-body">
      <circle cx="1080" cy="260" r="200" fill="url(#moonBody)" />
      <!-- Crescent shadow, offset to create dimension -->
      <circle cx="1020" cy="220" r="200" fill="url(#moonShadow)" opacity="0.85" />
    </g>

    <!-- Dense ambient starfield -->
    <g fill="var(--moon-star)">
      <circle cx="80" cy="140" r="1.1" />
      <circle cx="220" cy="380" r="1.3" />
      <circle cx="280" cy="240" r="1" />
      <circle cx="400" cy="560" r="1.2" />
      <circle cx="480" cy="80" r="1.4" />
      <circle cx="540" cy="460" r="1.1" />
      <circle cx="680" cy="260" r="1.3" />
      <circle cx="760" cy="620" r="1.2" />
      <circle cx="240" cy="520" r="1" />
      <circle cx="120" cy="320" r="1.2" />
      <circle cx="380" cy="180" r="1.1" />
      <circle cx="60" cy="560" r="1.3" />
      <circle cx="520" cy="380" r="1" />
      <circle cx="700" cy="440" r="1.2" />
      <circle cx="440" cy="660" r="1.1" />
    </g>

    <!-- Floating particles (brighter, animated) -->
    <g fill="var(--moon-particle)">
      <circle cx="180" cy="180" r="2.5" class="hero-moon-particle hero-moon-particle-1" />
      <circle cx="340" cy="420" r="1.8" class="hero-moon-particle hero-moon-particle-2" />
      <circle cx="620" cy="140" r="2" class="hero-moon-particle hero-moon-particle-3" />
      <circle cx="840" cy="520" r="1.5" class="hero-moon-particle hero-moon-particle-4" />
      <circle cx="260" cy="600" r="2.2" class="hero-moon-particle hero-moon-particle-5" />
      <circle cx="1280" cy="540" r="1.6" class="hero-moon-particle hero-moon-particle-6" />
      <circle cx="460" cy="320" r="1.4" class="hero-moon-particle hero-moon-particle-7" />
    </g>

    <!-- Twinkling bright stars -->
    <g fill="var(--moon-star-bright)">
      <circle cx="160" cy="440" r="2" class="hero-moon-twinkle hero-moon-twinkle-1" />
      <circle cx="560" cy="220" r="2.3" class="hero-moon-twinkle hero-moon-twinkle-2" />
      <circle cx="360" cy="300" r="1.8" class="hero-moon-twinkle hero-moon-twinkle-3" />
      <circle cx="720" cy="500" r="2.1" class="hero-moon-twinkle hero-moon-twinkle-4" />
    </g>
  </svg>
</div>

<style>
  .hero-moon {
    --moon-center: oklch(97.6% 0.012 255);
    --moon-mid: oklch(89.2% 0.038 255);
    --moon-edge: oklch(80.8% 0.06 255);
    --moon-shadow-start: oklch(80.8% 0.06 255);
    --moon-shadow-mid: oklch(89.2% 0.038 255 / 0.3);
    --moon-shadow-end: oklch(97.6% 0.012 255 / 0);
    --moon-halo-start: oklch(89.2% 0.038 255 / 0.45);
    --moon-halo-end: oklch(89.2% 0.038 255 / 0);
    --moon-particle: oklch(71.4% 0.082 255 / 0.6);
    --moon-star: oklch(71.4% 0.082 255 / 0.5);
    --moon-star-bright: oklch(61.2% 0.096 255 / 0.85);
    --moon-orbit: oklch(71.4% 0.082 255 / 0.35);
  }

  :global(.dark) .hero-moon {
    --moon-center: oklch(77% 0.13 295);
    --moon-mid: oklch(50% 0.22 295);
    --moon-edge: oklch(34% 0.14 295);
    --moon-shadow-start: oklch(24% 0.1 295);
    --moon-shadow-mid: oklch(34% 0.14 295 / 0.5);
    --moon-shadow-end: oklch(24% 0.1 295 / 0);
    --moon-halo-start: oklch(58% 0.25 295 / 0.35);
    --moon-halo-end: oklch(58% 0.25 295 / 0);
    --moon-particle: oklch(77% 0.13 295 / 0.75);
    --moon-star: oklch(77% 0.13 295 / 0.6);
    --moon-star-bright: oklch(87% 0.07 295 / 0.95);
    --moon-orbit: oklch(58% 0.25 295 / 0.4);
  }

  .hero-moon-body {
    animation: hero-moon-float 12s ease-in-out infinite;
    transform-origin: 1080px 260px;
  }

  .hero-moon-halo {
    animation: hero-moon-pulse 8s ease-in-out infinite;
    transform-origin: 1080px 260px;
  }

  @keyframes hero-moon-float {
    0%, 100% {
      transform: translate(0, 0);
    }
    25% {
      transform: translate(-14px, -22px);
    }
    50% {
      transform: translate(8px, -30px);
    }
    75% {
      transform: translate(16px, -12px);
    }
  }

  @keyframes hero-moon-pulse {
    0%, 100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 0.78;
      transform: scale(1.04);
    }
  }

  .hero-moon-particle {
    animation: hero-moon-drift 9s ease-in-out infinite;
  }
  .hero-moon-particle-1 { animation-delay: 0s; animation-duration: 10s; }
  .hero-moon-particle-2 { animation-delay: -2s; animation-duration: 13s; }
  .hero-moon-particle-3 { animation-delay: -4s; animation-duration: 11s; }
  .hero-moon-particle-4 { animation-delay: -1s; animation-duration: 14s; }
  .hero-moon-particle-5 { animation-delay: -3s; animation-duration: 12s; }
  .hero-moon-particle-6 { animation-delay: -5s; animation-duration: 10s; }
  .hero-moon-particle-7 { animation-delay: -2.5s; animation-duration: 13s; }

  @keyframes hero-moon-drift {
    0%, 100% {
      transform: translate(0, 0);
      opacity: 0.5;
    }
    50% {
      transform: translate(10px, -16px);
      opacity: 0.9;
    }
  }

  .hero-moon-orbit {
    animation: hero-moon-orbit-rotate linear infinite;
  }
  .hero-moon-orbit-1 { animation-duration: 60s; }
  .hero-moon-orbit-2 { animation-duration: 80s; animation-direction: reverse; }

  @keyframes hero-moon-orbit-rotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  .hero-moon-twinkle {
    animation: hero-moon-twinkle-pulse ease-in-out infinite;
    transform-origin: center;
    transform-box: fill-box;
  }
  .hero-moon-twinkle-1 { animation-duration: 4s;   animation-delay: 0s; }
  .hero-moon-twinkle-2 { animation-duration: 5.5s; animation-delay: -1.5s; }
  .hero-moon-twinkle-3 { animation-duration: 6s;   animation-delay: -3s; }
  .hero-moon-twinkle-4 { animation-duration: 4.8s; animation-delay: -2s; }

  @keyframes hero-moon-twinkle-pulse {
    0%, 100% { opacity: 0.35; transform: scale(0.85); }
    50%      { opacity: 1;    transform: scale(1.3); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-moon-body,
    .hero-moon-halo,
    .hero-moon-particle,
    .hero-moon-orbit,
    .hero-moon-twinkle {
      animation: none;
    }
  }
</style>
