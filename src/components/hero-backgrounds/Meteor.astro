---
/**
 * Meteor - bgjar-inspired hero background: vertical falling meteors
 * on a static gradient backdrop. Meteors use DOM positioning for
 * guaranteed vertical flow regardless of viewport aspect ratio.
 */
---

<div class="hero-meteor pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  <!-- Static ambient gradient backdrop -->
  <div class="hero-meteor-backdrop absolute inset-0" />

  <!-- Ambient glow areas + stars (scales with SVG viewBox) -->
  <svg
    class="absolute inset-0 h-full w-full"
    viewBox="0 0 1440 720"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <radialGradient id="meteorGlow" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0%" stop-color="var(--meteor-glow-start)" />
        <stop offset="100%" stop-color="var(--meteor-glow-end)" />
      </radialGradient>
    </defs>
    <circle cx="220" cy="140" r="280" fill="url(#meteorGlow)" opacity="0.55" />
    <circle cx="1240" cy="580" r="320" fill="url(#meteorGlow)" opacity="0.45" />

    <!-- Constellation connector lines (subtle) -->
    <g stroke="var(--meteor-line)" stroke-width="0.8" fill="none" stroke-linecap="round">
      <path d="M 140 220 L 300 160 L 380 90" />
      <path d="M 380 90 L 560 180 L 720 120" />
      <path d="M 720 120 L 880 200 L 960 180" />
      <path d="M 960 180 L 1120 280 L 1300 240" />
      <path d="M 140 220 L 260 360 L 300 500" />
      <path d="M 300 500 L 460 560 L 520 620" />
      <path d="M 520 620 L 720 580 L 860 540" />
      <path d="M 860 540 L 1060 500 L 1180 380" />
      <path d="M 720 340 L 880 420 L 960 360" />
    </g>

    <!-- Dense starfield -->
    <g fill="var(--meteor-star)">
      <circle cx="80" cy="80" r="1.2" />
      <circle cx="140" cy="220" r="1.5" />
      <circle cx="210" cy="140" r="1" />
      <circle cx="260" cy="360" r="1.4" />
      <circle cx="300" cy="160" r="1.3" />
      <circle cx="300" cy="500" r="1.6" />
      <circle cx="360" cy="250" r="0.9" />
      <circle cx="380" cy="90" r="1.8" />
      <circle cx="440" cy="190" r="1.1" />
      <circle cx="460" cy="560" r="1.3" />
      <circle cx="500" cy="420" r="1" />
      <circle cx="520" cy="620" r="1.7" />
      <circle cx="560" cy="180" r="1.2" />
      <circle cx="620" cy="280" r="1.4" />
      <circle cx="680" cy="460" r="1.1" />
      <circle cx="720" cy="120" r="1.3" />
      <circle cx="720" cy="340" r="1.4" />
      <circle cx="720" cy="580" r="1.2" />
      <circle cx="780" cy="200" r="1" />
      <circle cx="800" cy="380" r="1.3" />
      <circle cx="860" cy="540" r="1.5" />
      <circle cx="880" cy="200" r="1.1" />
      <circle cx="880" cy="420" r="1.2" />
      <circle cx="940" cy="300" r="1.3" />
      <circle cx="960" cy="180" r="1.6" />
      <circle cx="960" cy="360" r="1.1" />
      <circle cx="1020" cy="460" r="1.4" />
      <circle cx="1060" cy="260" r="1.2" />
      <circle cx="1060" cy="500" r="1.3" />
      <circle cx="1120" cy="280" r="1.1" />
      <circle cx="1180" cy="380" r="1.5" />
      <circle cx="1220" cy="160" r="1.3" />
      <circle cx="1300" cy="240" r="1.4" />
      <circle cx="1340" cy="440" r="1.1" />
      <circle cx="1380" cy="320" r="1.2" />
      <circle cx="1400" cy="120" r="1" />
    </g>

    <!-- Pulsing brighter stars -->
    <g fill="var(--meteor-star-bright)">
      <circle cx="220" cy="140" r="2.2" class="hero-meteor-twinkle hero-meteor-twinkle-1" />
      <circle cx="620" cy="480" r="2" class="hero-meteor-twinkle hero-meteor-twinkle-2" />
      <circle cx="1120" cy="180" r="2.4" class="hero-meteor-twinkle hero-meteor-twinkle-3" />
      <circle cx="380" cy="540" r="1.8" class="hero-meteor-twinkle hero-meteor-twinkle-4" />
      <circle cx="1280" cy="540" r="2.1" class="hero-meteor-twinkle hero-meteor-twinkle-5" />
    </g>
  </svg>

  <!-- Meteors as DOM elements: pixel-perfect vertical fall -->
  <div class="hero-meteor-streak hero-meteor-streak-1" style="left: 12%;">
    <span class="hero-meteor-trail" style="height: 120px;"></span>
    <span class="hero-meteor-head" style="width: 7px; height: 7px;"></span>
  </div>
  <div class="hero-meteor-streak hero-meteor-streak-2" style="left: 36%;">
    <span class="hero-meteor-trail" style="height: 90px;"></span>
    <span class="hero-meteor-head" style="width: 5.5px; height: 5.5px;"></span>
  </div>
  <div class="hero-meteor-streak hero-meteor-streak-3" style="left: 65%;">
    <span class="hero-meteor-trail" style="height: 150px;"></span>
    <span class="hero-meteor-head" style="width: 8px; height: 8px;"></span>
  </div>
  <div class="hero-meteor-streak hero-meteor-streak-4" style="left: 88%;">
    <span class="hero-meteor-trail" style="height: 80px;"></span>
    <span class="hero-meteor-head" style="width: 5px; height: 5px;"></span>
  </div>
</div>

<style>
  .hero-meteor {
    --meteor-head: oklch(61.2% 0.096 255);
    --meteor-tail: oklch(89.2% 0.038 255);
    --meteor-glow-start: oklch(89.2% 0.038 255 / 0.35);
    --meteor-glow-end: oklch(89.2% 0.038 255 / 0);
    --meteor-star: oklch(71.4% 0.082 255 / 0.55);
    --meteor-star-bright: oklch(61.2% 0.096 255 / 0.85);
    --meteor-line: oklch(71.4% 0.082 255 / 0.22);
    --meteor-bg-top: oklch(96% 0.003 255);
    --meteor-bg-mid: oklch(91% 0.004 255 / 0.6);
    --meteor-bg-bottom: oklch(98% 0.002 255);
    --meteor-bg-accent: oklch(85% 0.005 255 / 0.4);
  }

  :global(.dark) .hero-meteor {
    --meteor-head: oklch(77% 0.13 295);
    --meteor-tail: oklch(58% 0.25 295);
    --meteor-glow-start: oklch(58% 0.25 295 / 0.4);
    --meteor-glow-end: oklch(58% 0.25 295 / 0);
    --meteor-star: oklch(77% 0.13 295 / 0.75);
    --meteor-star-bright: oklch(87% 0.07 295 / 0.95);
    --meteor-line: oklch(58% 0.25 295 / 0.3);
    --meteor-bg-top: oklch(22% 0.008 295);
    --meteor-bg-mid: oklch(28% 0.01 295 / 0.6);
    --meteor-bg-bottom: oklch(16% 0.006 295);
    --meteor-bg-accent: oklch(38% 0.012 295 / 0.45);
  }

  .hero-meteor-twinkle {
    animation: hero-meteor-twinkle ease-in-out infinite;
    transform-origin: center;
    transform-box: fill-box;
  }
  .hero-meteor-twinkle-1 { animation-duration: 4.5s; animation-delay: 0s; }
  .hero-meteor-twinkle-2 { animation-duration: 6s;   animation-delay: -1.5s; }
  .hero-meteor-twinkle-3 { animation-duration: 5s;   animation-delay: -3s; }
  .hero-meteor-twinkle-4 { animation-duration: 7s;   animation-delay: -2s; }
  .hero-meteor-twinkle-5 { animation-duration: 5.5s; animation-delay: -4s; }

  @keyframes hero-meteor-twinkle {
    0%, 100% { opacity: 0.4; transform: scale(0.9); }
    50%      { opacity: 1;   transform: scale(1.25); }
  }

  .hero-meteor-backdrop {
    background:
      radial-gradient(ellipse at 18% 22%, var(--meteor-bg-accent), transparent 55%),
      radial-gradient(ellipse at 82% 78%, var(--meteor-bg-accent), transparent 55%),
      linear-gradient(180deg, var(--meteor-bg-top) 0%, var(--meteor-bg-mid) 50%, var(--meteor-bg-bottom) 100%);
  }

  .hero-meteor-streak {
    position: absolute;
    top: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateY(-200px);
    animation: hero-meteor-fall linear infinite;
    will-change: transform;
  }

  .hero-meteor-trail {
    display: block;
    width: 2px;
    background: linear-gradient(180deg, transparent 0%, var(--meteor-tail) 60%, var(--meteor-head) 100%);
    border-radius: 2px;
  }

  .hero-meteor-head {
    display: block;
    border-radius: 9999px;
    background: var(--meteor-head);
    box-shadow: 0 0 12px var(--meteor-head);
  }

  .hero-meteor-streak-1 { animation-duration: 7s;  animation-delay: 0s; }
  .hero-meteor-streak-2 { animation-duration: 9s;  animation-delay: -3s; }
  .hero-meteor-streak-3 { animation-duration: 8s;  animation-delay: -5.5s; }
  .hero-meteor-streak-4 { animation-duration: 11s; animation-delay: -1.5s; }

  @keyframes hero-meteor-fall {
    0% {
      transform: translateY(-220px);
      opacity: 0;
    }
    10% {
      opacity: 1;
    }
    85% {
      opacity: 1;
    }
    100% {
      transform: translateY(110vh);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-meteor-streak {
      animation: none;
      opacity: 0.5;
      transform: translateY(30vh);
    }
  }
</style>
