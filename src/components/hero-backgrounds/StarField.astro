---
/**
 * StarField - dunkler Hero-Hintergrund mit leicht glühenden, pulsierenden Sternen.
 * Dezente Animation: Sterne leuchten unterschiedlich schnell auf und ab.
 */
---

<div class="hero-starfield pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
  <svg
    class="absolute inset-0 h-full w-full"
    viewBox="0 0 1440 720"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <radialGradient id="starGlowSm" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0%" stop-color="rgba(255,255,255,1)" />
        <stop offset="40%" stop-color="rgba(255,255,255,0.6)" />
        <stop offset="100%" stop-color="rgba(255,255,255,0)" />
      </radialGradient>
      <radialGradient id="starGlowMd" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0%" stop-color="rgba(255,255,255,1)" />
        <stop offset="30%" stop-color="rgba(165,180,252,0.55)" />
        <stop offset="100%" stop-color="rgba(165,180,252,0)" />
      </radialGradient>
      <radialGradient id="starGlowBrand" cx="0.5" cy="0.5" r="0.5">
        <stop offset="0%" stop-color="rgba(199,210,254,1)" />
        <stop offset="30%" stop-color="rgba(129,140,248,0.55)" />
        <stop offset="100%" stop-color="rgba(129,140,248,0)" />
      </radialGradient>
      <radialGradient id="heroGlow" cx="0.5" cy="0.4" r="0.6">
        <stop offset="0%" stop-color="rgba(99,102,241,0.22)" />
        <stop offset="60%" stop-color="rgba(99,102,241,0.06)" />
        <stop offset="100%" stop-color="rgba(99,102,241,0)" />
      </radialGradient>
    </defs>

    <!-- Atmospheric brand glow -->
    <rect width="1440" height="720" fill="url(#heroGlow)" />

    <!-- Soft line grid (sehr dezent) -->
    <g stroke="rgba(255,255,255,0.04)" stroke-width="1">
      <line x1="0" y1="180" x2="1440" y2="180" />
      <line x1="0" y1="360" x2="1440" y2="360" />
      <line x1="0" y1="540" x2="1440" y2="540" />
      <line x1="360" y1="0" x2="360" y2="720" />
      <line x1="720" y1="0" x2="720" y2="720" />
      <line x1="1080" y1="0" x2="1080" y2="720" />
    </g>

    <!-- Glowing stars: unterschiedliche Größen + animierte Glimmer -->
    <!-- Große Glow-Sterne -->
    <g class="star-group-xl">
      <circle cx="180" cy="140" r="22" fill="url(#starGlowBrand)" class="star-pulse star-p1" />
      <circle cx="1240" cy="200" r="26" fill="url(#starGlowMd)" class="star-pulse star-p2" />
      <circle cx="560" cy="580" r="20" fill="url(#starGlowMd)" class="star-pulse star-p3" />
      <circle cx="1100" cy="520" r="24" fill="url(#starGlowBrand)" class="star-pulse star-p4" />
    </g>

    <!-- Mittlere Glow-Sterne -->
    <g class="star-group-md">
      <circle cx="340" cy="280" r="12" fill="url(#starGlowSm)" class="star-pulse star-p2" />
      <circle cx="780" cy="120" r="14" fill="url(#starGlowMd)" class="star-pulse star-p4" />
      <circle cx="1000" cy="380" r="11" fill="url(#starGlowSm)" class="star-pulse star-p1" />
      <circle cx="420" cy="460" r="13" fill="url(#starGlowBrand)" class="star-pulse star-p3" />
      <circle cx="860" cy="520" r="10" fill="url(#starGlowSm)" class="star-pulse star-p2" />
      <circle cx="1320" cy="430" r="12" fill="url(#starGlowMd)" class="star-pulse star-p1" />
      <circle cx="120" cy="420" r="11" fill="url(#starGlowSm)" class="star-pulse star-p4" />
    </g>

    <!-- Kleine harte Sternenpunkte (ambient) -->
    <g fill="rgba(255,255,255,0.85)">
      <circle cx="60" cy="80" r="1" class="star-twinkle star-t1" />
      <circle cx="240" cy="220" r="1.2" class="star-twinkle star-t2" />
      <circle cx="320" cy="60" r="0.9" class="star-twinkle star-t3" />
      <circle cx="480" cy="180" r="1" class="star-twinkle star-t1" />
      <circle cx="620" cy="340" r="1.1" class="star-twinkle star-t2" />
      <circle cx="720" cy="240" r="0.9" class="star-twinkle star-t3" />
      <circle cx="840" cy="80" r="1.2" class="star-twinkle star-t1" />
      <circle cx="940" cy="260" r="1" class="star-twinkle star-t2" />
      <circle cx="1060" cy="160" r="0.9" class="star-twinkle star-t3" />
      <circle cx="1180" cy="340" r="1.1" class="star-twinkle star-t1" />
      <circle cx="1320" cy="120" r="1" class="star-twinkle star-t2" />
      <circle cx="80" cy="320" r="0.9" class="star-twinkle star-t3" />
      <circle cx="200" cy="500" r="1" class="star-twinkle star-t1" />
      <circle cx="360" cy="620" r="1.2" class="star-twinkle star-t2" />
      <circle cx="520" cy="680" r="0.9" class="star-twinkle star-t3" />
      <circle cx="680" cy="480" r="1" class="star-twinkle star-t1" />
      <circle cx="820" cy="660" r="1.1" class="star-twinkle star-t2" />
      <circle cx="960" cy="620" r="0.9" class="star-twinkle star-t3" />
      <circle cx="1140" cy="680" r="1" class="star-twinkle star-t1" />
      <circle cx="1280" cy="620" r="1.2" class="star-twinkle star-t2" />
      <circle cx="1400" cy="540" r="0.9" class="star-twinkle star-t3" />
      <circle cx="140" cy="600" r="1" class="star-twinkle star-t1" />
    </g>
  </svg>
</div>

<style>
  .hero-starfield {
    background: radial-gradient(
        ellipse at top,
        rgba(20, 20, 22, 0.8) 0%,
        rgba(8, 8, 10, 0.95) 50%,
        rgb(0, 0, 0) 100%
      ),
      rgb(0, 0, 0);
  }

  @keyframes star-pulse {
    0%,
    100% {
      opacity: 0.35;
      transform: scale(0.9);
    }
    50% {
      opacity: 1;
      transform: scale(1.08);
    }
  }

  @keyframes star-twinkle {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 1;
    }
  }

  .star-pulse {
    transform-box: fill-box;
    transform-origin: center;
    animation: star-pulse 4s ease-in-out infinite;
    will-change: opacity, transform;
  }

  .star-p1 {
    animation-duration: 3.8s;
    animation-delay: 0s;
  }
  .star-p2 {
    animation-duration: 5.2s;
    animation-delay: 0.8s;
  }
  .star-p3 {
    animation-duration: 4.6s;
    animation-delay: 1.6s;
  }
  .star-p4 {
    animation-duration: 6s;
    animation-delay: 2.4s;
  }

  .star-twinkle {
    animation: star-twinkle 3s ease-in-out infinite;
    will-change: opacity;
  }

  .star-t1 {
    animation-duration: 2.8s;
    animation-delay: 0.2s;
  }
  .star-t2 {
    animation-duration: 3.6s;
    animation-delay: 1.1s;
  }
  .star-t3 {
    animation-duration: 4.2s;
    animation-delay: 2s;
  }

  @media (prefers-reduced-motion: reduce) {
    .star-pulse,
    .star-twinkle {
      animation: none;
    }
  }
</style>
