---
/**
 * LandingFooter Component (i18n-aware)
 * Footer for landing pages with translations
 */
import rocketbaseLogo from '@/assets/rocketbase/logo.svg';
import bsfzSiegel2025 from '@/assets/rocketbase/bsfz_siegel-2025.svg';
import bsfzSiegel2026 from '@/assets/rocketbase/bsfz_siegel-2026.svg';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import { type Locale, getLocaleFromPath } from '@/i18n/config';
import { useTranslations, getLocalizedPath } from '@/i18n/index';
import { contactLinks } from '@/data/rocketbase';

interface Props {
  locale?: Locale;
}

const { locale: localeProp } = Astro.props;

// Get locale from prop or infer from URL
const locale = localeProp || getLocaleFromPath(Astro.url.pathname);
const t = useTranslations(locale);

const navLinks = [
  { label: t('nav.services'), href: getLocalizedPath('services', locale) },
  { label: t('nav.work'), href: getLocalizedPath('work', locale) },
  { label: t('nav.references'), href: getLocalizedPath('references', locale) },
  { label: t('nav.mission'), href: getLocalizedPath('mission', locale) },
  { label: 'Discovery-Workshop', href: getLocalizedPath('discoveryWorkshop', locale) },
  { label: t('nav.contact'), href: getLocalizedPath('contact', locale) },
];

const socialLinks = [
  { label: 'LinkedIn', href: contactLinks.linkedin, icon: 'linkedin' },
  { label: 'GitHub', href: contactLinks.github, icon: 'github' },
  { label: 'Instagram', href: contactLinks.instagram, icon: 'instagram' },
];

const legalLinks = [
  { label: 'Impressum', href: '/impressum' },
  { label: 'Datenschutz', href: '/datenschutz' },
];

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-background-secondary">
  <div class="mx-auto max-w-7xl px-6">
    <!-- Main row -->
    <div class="grid gap-12 py-16 md:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)]">
      <!-- Brand -->
      <div class="flex flex-col gap-5">
        <a href={getLocalizedPath('home', locale)} class="flex items-center">
          <img src={rocketbaseLogo.src} alt="RocketBase" class="h-10 w-auto dark:invert" />
        </a>
        <p class="max-w-md font-display text-base leading-7 text-foreground-muted">
          Wir bauen nicht einfach Software.
          <span class="mt-1 block text-foreground">
            Wir verstehen Prozesse, denken sie weiter – und entwickeln Systeme, die Unternehmen wachsen lassen.
          </span>
        </p>

        <!-- BSFZ-Siegel: Bescheinigte Forschungszulage 2025 + 2026 -->
        <div class="mt-2 flex flex-col gap-3">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-foreground-subtle">
            Bescheinigte Forschung &amp; Entwicklung
          </p>
          <a
            href="https://www.bescheinigung-forschungszulage.de/"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-3 self-start"
            aria-label="BSFZ-Siegel: Bescheinigte Forschungszulage – mehr erfahren"
            title="Bescheinigte Forschungszulage 2025 und 2026 – mehr auf bescheinigung-forschungszulage.de"
          >
            <img
              src={bsfzSiegel2025.src}
              alt="BSFZ-Siegel 2025 – Bescheinigte Forschungszulage"
              width="64"
              height="64"
              class="h-16 w-16 transition-opacity group-hover:opacity-80"
              loading="lazy"
            />
            <img
              src={bsfzSiegel2026.src}
              alt="BSFZ-Siegel 2026 – Bescheinigte Forschungszulage"
              width="64"
              height="64"
              class="h-16 w-16 transition-opacity group-hover:opacity-80"
              loading="lazy"
            />
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div class="flex flex-col gap-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-foreground-subtle">Navigation</p>
        <nav class="flex flex-col gap-2.5">
          {navLinks.map((link) => (
            <a href={link.href} class="text-sm text-foreground-muted hover:text-foreground transition-colors">
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Kontakt -->
      <div class="flex flex-col gap-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-foreground-subtle">Kontakt</p>
        <div class="flex flex-col gap-2.5">
          <a
            href={`mailto:${contactLinks.email}`}
            class="text-sm text-foreground-muted hover:text-foreground transition-colors"
          >
            {contactLinks.email}
          </a>
          <a
            href={contactLinks.cal}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-foreground-muted hover:text-foreground transition-colors"
          >
            Erstgespräch buchen
          </a>
        </div>
      </div>

      <!-- Social -->
      <div class="flex flex-col gap-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-foreground-subtle">Folgen</p>
        <nav class="flex flex-col gap-2.5">
          {socialLinks.map((link) => (
            <a
              href={link.href}
              class="group inline-flex items-center gap-2.5 text-sm text-foreground-muted hover:text-foreground transition-colors"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
            >
              <Icon name={link.icon} size="sm" class="text-foreground-subtle group-hover:text-brand-500 transition-colors" />
              <span>{link.label}</span>
            </a>
          ))}
        </nav>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col gap-3 border-t border-border py-6 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-xs text-foreground-subtle">© {year} rocketbase.io software productions GmbH</p>
      <nav class="flex gap-5">
        {legalLinks.map((link) => (
          <a href={link.href} class="text-xs text-foreground-subtle hover:text-foreground-muted transition-colors">
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</footer>
