---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getEntry } from 'astro:content';
import PolygonLuminary from '@/components/hero-backgrounds/PolygonLuminary.astro';

interface Props {
  title: string;
  description: string;
  publishedAt: Date;
  updatedAt?: Date;
  author?: string;
  tags?: string[];
  image?: ImageMetadata;
  imageAlt?: string;
  readingTime?: number;
}

const {
  title,
  description,
  publishedAt,
  updatedAt,
  author = 'Team',
  tags = [],
  image,
  imageAlt,
  readingTime,
} = Astro.props;

const authorSlug = author
  .toLowerCase()
  .normalize('NFD')
  .replace(/[̀-ͯ]/g, '')
  .replace(/ß/g, 'ss')
  .split(/\s+/)[0];

const authorEntry = authorSlug ? await getEntry('authors', authorSlug) : undefined;
const authorAvatar = authorEntry?.data.avatar;
---

<header class="border-border bg-background-secondary relative overflow-hidden border-b pt-[var(--space-page-top)] pb-[var(--space-section)]">
  <PolygonLuminary />

  <div class:list={[
    'relative z-10 mx-auto px-6',
    image ? 'max-w-6xl' : 'max-w-4xl',
  ]}>
    <div class:list={[
      'grid gap-10',
      image ? 'md:min-h-[26rem] md:grid-cols-[1.05fr_0.95fr] md:items-center md:gap-12' : '',
    ]}>
      <div class="flex flex-col">
        <!-- Tags -->
        {tags.length > 0 && (
          <div class="mb-6 flex flex-wrap gap-2">
            {tags.slice(0, 4).map((tag) => (
              <span class="inline-flex items-center rounded-full bg-brand-100 dark:bg-brand-900/30 px-3 py-1 text-xs font-semibold text-brand-700 dark:text-brand-300 ring-1 ring-inset ring-brand-200 dark:ring-brand-800">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Title — stable size regardless of image presence;
             balanced wrapping + German hyphenation for clean breaks on narrow columns. -->
        <h1 class="font-display text-4xl font-bold tracking-tight text-foreground mb-6 lg:text-5xl text-balance hyphens-auto [-webkit-hyphens:auto]" lang="de">
          {title}
        </h1>

        <!-- Description — stable max-width -->
        <p class="text-lg text-foreground-muted leading-8 mb-8 text-pretty hyphens-auto" lang="de">
          {description}
        </p>

        <!-- Meta info -->
        <div class="flex flex-wrap items-center gap-[var(--space-stack-lg)] text-sm text-foreground-muted">
          <!-- Author -->
          <a
            href="#author-bio"
            class="group flex items-center gap-3 rounded-full transition-colors hover:text-brand-600 dark:hover:text-brand-400"
            aria-label={`Mehr über ${author}`}
          >
            {authorAvatar ? (
              <Image
                src={authorAvatar}
                alt={author}
                width={40}
                height={40}
                class="h-10 w-10 rounded-full object-cover ring-2 ring-border shadow-sm transition-transform group-hover:scale-105"
                loading="eager"
              />
            ) : (
              <div class="h-10 w-10 rounded-full bg-brand-500 flex items-center justify-center text-sm font-bold text-white shadow-sm">
                {author.charAt(0).toUpperCase()}
              </div>
            )}
            <p class="font-semibold text-foreground transition-colors group-hover:text-brand-600 dark:group-hover:text-brand-400">
              {author}
            </p>
          </a>

          <div class="h-8 w-px bg-border hidden md:block"></div>

          <!-- Published date -->
          <div class="flex items-center gap-2">
            <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
            </svg>
            <time datetime={publishedAt.toISOString()}>
              {publishedAt.getFullYear()}
            </time>
          </div>

          {updatedAt && (
            <>
              <div class="h-8 w-px bg-border hidden md:block"></div>
              <div class="flex items-center gap-2">
                <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
                </svg>
                <time datetime={updatedAt.toISOString()}>
                  Aktualisiert {updatedAt.getFullYear()}
                </time>
              </div>
            </>
          )}

          {readingTime && readingTime > 0 && (
            <>
              <div class="h-8 w-px bg-border hidden md:block"></div>

              <!-- Reading time -->
              <div class="flex items-center gap-2">
                <svg class="h-5 w-5 text-foreground-subtle" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{readingTime} Min. Lesezeit</span>
              </div>
            </>
          )}
        </div>
      </div>

      {image && (
        <div class="relative">
          <div class="bg-brand-300/20 absolute -inset-6 -z-10 rounded-[3rem] blur-3xl" aria-hidden="true"></div>
          <div class="group relative overflow-hidden rounded-[2rem] border border-border shadow-[0_30px_70px_rgba(34,43,74,0.16)] rotate-[2.5deg] transition-transform duration-500 will-change-transform [backface-visibility:hidden] hover:rotate-0 hover:-translate-y-1">
            <Image
              src={image}
              alt={imageAlt || title}
              widths={[480, 720, 960, 1280]}
              sizes="(max-width: 768px) 100vw, 50vw"
              class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-[1.03]"
              loading="eager"
            />
          </div>
        </div>
      )}
    </div>
  </div>
</header>
